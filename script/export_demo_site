#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"
require "cgi"
require "digest/sha1"
require "fileutils"
require "net/http"
require "nokogiri"
require "pathname"
require "set"
require "uri"

class DemoSiteExporter
  HTML_CONTENT_TYPES = ["text/html", "application/xhtml+xml"].freeze
  ASSET_EXTENSIONS = %w[
    .css .gif .ico .jpeg .jpg .js .json .pdf .png .svg .txt .webp .woff .woff2
  ].freeze
  INLINE_HTML_FRAME_SELECTORS = "turbo-frame[src]".freeze

  def initialize(base_url:, email:, password:, output_dir:, primary_person_name:)
    @base_url = URI(base_url)
    @email = email
    @password = password
    @output_dir = Pathname(output_dir)
    @primary_person_name = primary_person_name
    @cookies = {}
    @queued_pages = []
    @seen_pages = Set.new
    @downloaded_assets = Set.new
  end

  def run
    reset_output!
    write_support_files
    login!
    enqueue_page(@base_url)

    until @queued_pages.empty?
      page_uri = @queued_pages.shift
      next if @seen_pages.include?(page_key(page_uri))

      @seen_pages << page_key(page_uri)
      export_page(page_uri)
    end

    finalize_site!
  end

  private

  def reset_output!
    FileUtils.rm_rf(@output_dir)
    FileUtils.mkdir_p(@output_dir)
  end

  def login!
    login_uri = build_uri("/session/new")
    response = request(:get, login_uri)
    document = Nokogiri::HTML(response.body)
    token = document.at_css("input[name='authenticity_token']")&.[]("value")
    raise "Could not find authenticity token on #{login_uri}" if token.to_s.empty?

    login_response = request(
      :post,
      build_uri("/session"),
      form_data: {
        "authenticity_token" => token,
        "email_address" => @email,
        "password" => @password
      }
    )

    if redirect?(login_response)
      follow_redirect(login_response, build_uri("/session"))
    elsif login_response.code.to_i >= 400
      raise "Login failed with HTTP #{login_response.code}"
    end

    root_response = request(:get, @base_url)
    if root_response.uri.path == "/session/new"
      raise "Login did not stick. Check UNCLEDOC_DEMO_EMAIL and UNCLEDOC_DEMO_PASSWORD."
    end
  end

  def export_page(page_uri)
    response = request(:get, page_uri)
    content_type = response["content-type"].to_s.split(";").first
    return unless HTML_CONTENT_TYPES.include?(content_type)

    document = Nokogiri::HTML(response.body)
    inline_remote_frames!(document, response.uri)
    sanitize_document!(document, response.uri)
    write_html(response.uri, document.to_html)
  end

  def inline_remote_frames!(document, page_uri)
    document.css(INLINE_HTML_FRAME_SELECTORS).each do |frame|
      frame_uri = absolutize_uri(frame["src"], page_uri)
      next unless internal_uri?(frame_uri)

      frame_response = request(:get, frame_uri)
      next unless HTML_CONTENT_TYPES.include?(frame_response["content-type"].to_s.split(";").first)

      frame_document = Nokogiri::HTML(frame_response.body)
      nested_frame = frame_document.at_css("turbo-frame##{frame["id"]}") || frame_document.at_css("turbo-frame") || frame_document.at_css("body")
      next unless nested_frame

      frame.remove_attribute("src")
      frame.inner_html = nested_frame.inner_html
    end
  end

  def sanitize_document!(document, page_uri)
    strip_server_only_nodes!(document)
    strip_permission_warnings!(document)
    rewrite_urls!(document, page_uri)
    disable_live_forms!(document)
    inject_demo_assets!(document, page_uri)
    add_demo_banner!(document, page_uri)
  end

  def strip_server_only_nodes!(document)
    document.css("meta[name='csrf-token'], meta[name='csrf-param'], meta[name='csp-nonce'], meta[name='uncledoc-native-app-token'], meta[name='uncledoc-native-app-email']").remove
    document.css("script, turbo-cable-stream-source").remove
  end

  def strip_permission_warnings!(document)
    document.css("div, p, section").each do |node|
      text = node.text.strip
      next unless text.include?("permission to access") || text.include?("access that area")

      node.remove
    end
  end

  def rewrite_urls!(document, page_uri)
    document.css("a[href], link[href], img[src], source[src], iframe[src], object[data]").each do |node|
      attr_name = node.key?("href") ? "href" : node.key?("src") ? "src" : "data"
      rewrite_url_attribute!(node, attr_name, page_uri)
    end

    document.css("[srcset]").each do |node|
      node["srcset"] = rewrite_srcset(node["srcset"], page_uri)
    end

    document.css("form[action]").each do |form|
      form["action"] = "#"
    end
  end

  def rewrite_url_attribute!(node, attr_name, page_uri)
    original = node[attr_name].to_s.strip
    return if original.empty? || original.start_with?("#", "mailto:", "tel:", "javascript:")

    target_uri = absolutize_uri(original, page_uri)
    return unless internal_uri?(target_uri)

    local_path = if node.name == "a" && !asset_uri?(target_uri)
      normalized_target = normalize_page_uri(target_uri)
      enqueue_page(normalized_target)
      html_output_path(normalized_target)
    else
      download_asset(target_uri)
      asset_output_path(target_uri)
    end

    node[attr_name] = relative_reference(page_uri, local_path)
  end

  def rewrite_srcset(value, page_uri)
    value.to_s.split(",").map do |entry|
      url_part, descriptor = entry.strip.split(/\s+/, 2)
      if url_part && !url_part.empty?
        target_uri = absolutize_uri(url_part, page_uri)
        if internal_uri?(target_uri)
          download_asset(target_uri)
          [relative_reference(page_uri, asset_output_path(target_uri)), descriptor].compact.join(" ")
        else
          entry.strip
        end
      else
        entry.strip
      end
    end.join(", ")
  end

  def disable_live_forms!(document)
    document.css("form").each do |form|
      form["data-demo-disabled"] = "true"
      form["onsubmit"] = "return false"
    end

    document.css("button[formaction], input[type='submit'], button[type='submit']").each do |control|
      control["data-demo-disabled-control"] = "true"
    end
  end

  def inject_demo_assets!(document, page_uri)
    head = document.at_css("head") || document.root.add_child("<head></head>").first
    body = document.at_css("body") || document.root.add_child("<body></body>").first

    body["data-demo-path"] = page_uri.path

    demo_css = Nokogiri::XML::Node.new("link", document)
    demo_css["rel"] = "stylesheet"
    demo_css["href"] = relative_reference(page_uri, Pathname("demo/demo.css"))
    head.add_child(demo_css)

    demo_script = Nokogiri::XML::Node.new("script", document)
    demo_script["src"] = relative_reference(page_uri, Pathname("demo/demo.js"))
    demo_script["defer"] = "defer"
    head.add_child(demo_script)
  end

  def add_demo_banner!(document, page_uri)
    main = document.at_css("main") || document.at_css("body")
    return unless main

    banner = Nokogiri::HTML::DocumentFragment.parse(<<~HTML)
      <section class="uncledoc-demo-banner">
        <div>
          <strong>Offline demo mode</strong>
          <span>Local sample mirror generated from #{CGI.escapeHTML(@base_url.to_s)}.</span>
        </div>
        <span class="uncledoc-demo-pill">#{CGI.escapeHTML(page_uri.path.to_s.empty? ? "/" : page_uri.path)}</span>
      </section>
    HTML
    main.children.first ? main.children.first.add_previous_sibling(banner) : main.add_child(banner)
  end

  def download_asset(asset_uri)
    key = page_key(asset_uri)
    return if @downloaded_assets.include?(key)

    @downloaded_assets << key
    response = request(:get, asset_uri)
    body = response.body

    write_asset(asset_uri, body)
    return unless response["content-type"].to_s.start_with?("text/css")

    body.scan(/url\(([^)]+)\)/).flatten.each do |raw_reference|
      cleaned = raw_reference.to_s.delete_prefix("'").delete_prefix('"').delete_suffix('"').delete_suffix("'").strip
      next if cleaned.empty? || cleaned.start_with?("data:", "#")

      nested_uri = absolutize_uri(cleaned, asset_uri)
      next unless internal_uri?(nested_uri)

      download_asset(nested_uri)
    end
  end

  def write_html(page_uri, html)
    destination = @output_dir.join(html_output_path(page_uri))
    FileUtils.mkdir_p(destination.dirname)
    destination.write(html)
  end

  def write_asset(asset_uri, body)
    destination = @output_dir.join(asset_output_path(asset_uri))
    FileUtils.mkdir_p(destination.dirname)
    destination.binwrite(body)
  end

  def write_support_files
    demo_dir = @output_dir.join("demo")
    FileUtils.mkdir_p(demo_dir)
    demo_dir.join("demo.css").write(demo_css)
    demo_dir.join("demo.js").write(demo_js)
  end

  def finalize_site!
    write_root_redirect
  end

  def write_root_redirect
    destination = @output_dir.join("index.html")
    url = url_path(primary_entry_relative_path)
    destination.write(<<~HTML)
      <!DOCTYPE html>
      <html lang="en">
        <head>
          <meta charset="utf-8">
          <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
          <meta http-equiv="refresh" content="0; url=#{url}">
          <title>UncleDoc Demo</title>
          <script>
            window.location.replace(#{url.inspect});
          </script>
        </head>
        <body style="font-family:-apple-system, BlinkMacSystemFont, sans-serif; padding:24px; background:#fffaf1; color:#0f172a;">
          <p>Opening offline demo…</p>
          <p><a href=#{url.inspect}>Continue</a></p>
        </body>
      </html>
    HTML
  end

  def request(method, uri, form_data: nil, limit: 5)
    raise "Too many redirects for #{uri}" if limit <= 0

    request_uri = uri.dup
    http = Net::HTTP.new(request_uri.host, request_uri.port)
    http.use_ssl = request_uri.scheme == "https"

    request = case method
    when :get
      Net::HTTP::Get.new(request_uri)
    when :post
      Net::HTTP::Post.new(request_uri)
    else
      raise ArgumentError, "Unsupported method: #{method}"
    end

    request["Cookie"] = cookie_header if @cookies.any?
    request.set_form_data(form_data) if form_data

    response = http.request(request)
    store_cookies(response)
    response.define_singleton_method(:uri) { request_uri }

    return follow_redirect(response, request_uri, limit: limit - 1) if redirect?(response)

    response
  end

  def follow_redirect(response, from_uri, limit: 4)
    target = absolutize_uri(response["location"], from_uri)
    request(:get, target, limit: limit)
  end

  def redirect?(response)
    response.code.to_i.between?(300, 399) && response["location"].to_s != ""
  end

  def store_cookies(response)
    Array(response.get_fields("set-cookie")).each do |cookie|
      key, value = cookie.split(";", 2).first.split("=", 2)
      @cookies[key] = value
    end
  end

  def cookie_header
    @cookies.map { |key, value| "#{key}=#{value}" }.join("; ")
  end

  def build_uri(path)
    absolutize_uri(path, @base_url)
  end

  def absolutize_uri(reference, base_uri)
    URI.join(base_uri.to_s.end_with?("/") ? base_uri.to_s : "#{base_uri}/", reference.to_s)
  rescue URI::InvalidURIError
    base_uri
  end

  def internal_uri?(uri)
    uri.host == @base_url.host && uri.port == @base_url.port && %w[http https].include?(uri.scheme)
  end

  def enqueue_page(uri)
    normalized = normalize_page_uri(uri)
    return if @seen_pages.include?(page_key(normalized))

    @queued_pages << normalized unless @queued_pages.any? { |queued| page_key(queued) == page_key(normalized) }
  end

  def normalize_uri(uri)
    normalized = uri.dup
    normalized.fragment = nil
    normalized
  end

  def normalize_page_uri(uri)
    normalized = normalize_uri(uri)
    params = URI.decode_www_form(normalized.query.to_s).each_with_object({}) do |(key, value), hash|
      hash[key] ||= []
      hash[key] << value
    end

    kept = case normalized.path
    when "/settings"
      params.slice("section", "table")
    else
      {}
    end

    normalized.query = kept.empty? ? nil : URI.encode_www_form(kept.flat_map { |key, values| Array(values).map { |value| [key, value] } })
    normalized
  end

  def page_key(uri)
    normalized = normalize_page_uri(uri)
    [(normalized.path.to_s.empty? ? "/" : normalized.path), normalized.query.to_s].join("?")
  end

  def asset_uri?(uri)
    extension = File.extname(uri.path)
    ASSET_EXTENSIONS.include?(extension.downcase)
  end

  def html_output_path(uri)
    normalized = normalize_page_uri(uri)
    path = CGI.unescape(normalized.path.to_s)
    path = "/" if path.empty?
    query_suffix = normalized.query.to_s.empty? ? "" : "--#{Digest::SHA1.hexdigest(normalized.query)[0, 10]}"

    if path == "/"
      Pathname("index#{query_suffix}.html")
    elsif File.extname(path).empty?
      trimmed = path.delete_prefix("/")
      Pathname(trimmed).join("index#{query_suffix}.html")
    else
      directory = File.dirname(path).delete_prefix("/")
      basename = File.basename(path, File.extname(path))
      extension = File.extname(path)
      Pathname(directory).join("#{basename}#{query_suffix}#{extension}")
    end
  end

  def asset_output_path(uri)
    path = CGI.unescape(uri.path.to_s).delete_prefix("/")
    path = "asset-#{Digest::SHA1.hexdigest(uri.to_s)[0, 12]}" if path.empty?
    if uri.query.to_s.empty?
      Pathname(path)
    else
      directory = File.dirname(path)
      basename = File.basename(path, File.extname(path))
      extension = File.extname(path)
      Pathname(directory).join("#{basename}--#{Digest::SHA1.hexdigest(uri.query)[0, 10]}#{extension}")
    end
  end

  def relative_reference(from_uri, target_path)
    from_file = @output_dir.join(html_output_path(from_uri))
    target_file = @output_dir.join(target_path)
    url_path(target_file.relative_path_from(from_file.dirname).to_s)
  end

  def primary_person_slug
    @primary_person_name
  end

  def primary_entry_relative_path
    "#{primary_person_slug}/overview/index.html"
  end

  def url_path(path)
    path.split("/").map { |segment| CGI.escape(segment).gsub("+", "%20") }.join("/")
  end

  def demo_css
    <<~CSS
      .uncledoc-demo-banner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 1rem;
        border: 1px solid rgba(15, 23, 42, 0.08);
        background: rgba(255, 255, 255, 0.88);
        border-radius: 1.25rem;
        padding: 0.85rem 1rem;
        box-shadow: 0 12px 32px -24px rgba(15, 23, 42, 0.45);
        backdrop-filter: blur(12px);
      }

      .uncledoc-demo-banner strong {
        display: block;
        font-size: 0.875rem;
        color: #0f172a;
      }

      .uncledoc-demo-banner span {
        display: block;
        font-size: 0.75rem;
        color: #64748b;
      }

      .uncledoc-demo-pill {
        white-space: nowrap;
        border: 1px solid rgba(245, 158, 11, 0.24);
