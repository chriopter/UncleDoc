# LAN deployment secrets from 1Password

# Copy this file to .kamal/secrets.lan before deploying, then adjust the
# account and item names to match your 1Password setup.
SECRETS=$(kamal secrets fetch --adapter 1password --account my.1password.eu --from "Private/UncleDoc Production Secrets" RAILS_MASTER_KEY)

RAILS_MASTER_KEY=$(kamal secrets extract RAILS_MASTER_KEY $SECRETS)
