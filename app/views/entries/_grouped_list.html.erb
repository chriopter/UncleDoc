<div class="space-y-5">
  <% grouped_entries_by_day(entries).each do |date, day_entries| %>
    <section class="space-y-3">
      <div class="sticky top-0 z-[1] -mx-1 px-1 py-1 backdrop-blur-sm">
        <div class="inline-flex items-center rounded-full border border-white/10 bg-slate-950/80 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">
          <%= log_day_label(date) %>
        </div>
      </div>

      <% if day_entries.first.person.baby_mode? %>
        <div class="space-y-2">
          <% day_entries.each do |entry| %>
            <%= render "entries/entry", entry: entry %>
          <% end %>
        </div>
      <% else %>
        <div class="overflow-hidden rounded-[1.5rem] border border-white/10 bg-white/[0.03]">
          <% day_entries.each_with_index do |entry, index| %>
            <div class="<%= index.positive? ? 'border-t border-white/10' : '' %>">
              <%= render "entries/entry", entry: entry, grouped: true %>
            </div>
          <% end %>
        </div>
      <% end %>
    </section>
  <% end %>
</div>
