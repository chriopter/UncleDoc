<div class="space-y-4">
  <% grouped_entries_by_day(entries).each do |date, day_entries| %>
    <% if day_entries.first.person.baby_mode? %>
      <section class="space-y-3">
        <div class="sticky top-0 z-[1] -mx-1 px-1 py-1 backdrop-blur-sm">
          <div class="inline-flex items-center rounded-full border border-amber-200 bg-white/90 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-amber-800 shadow-sm ring-1 ring-amber-100/80">
            <%= log_day_label(date) %>
          </div>
        </div>

        <div class="space-y-2">
          <% day_entries.each do |entry| %>
            <%= render "entries/entry", entry: entry %>
          <% end %>
        </div>
      </section>
    <% else %>
      <section class="grid gap-3 xl:grid-cols-[10rem_minmax(0,1fr)] xl:gap-5 xl:items-start">
        <div class="xl:sticky xl:top-28 xl:self-start xl:pt-1">
          <div class="inline-flex items-center rounded-full border border-amber-200 bg-white/90 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-amber-800 shadow-sm ring-1 ring-amber-100/80">
            <%= log_day_label(date) %>
          </div>
        </div>

        <div class="overflow-hidden rounded-[1.35rem] border border-amber-100/80 bg-white/94 shadow-sm ring-1 ring-amber-100/30">
          <% day_entries.each_with_index do |entry, index| %>
            <div class="<%= index.positive? ? 'border-t border-slate-100' : '' %>">
              <%= render "entries/entry", entry: entry, grouped: true %>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  <% end %>
</div>
