<% display_time = entry.occurred_at || entry.created_at %>
<% summary_text = entry.fact_summary.presence || entry.input.presence || (entry.documents_attached? ? t("entries.documents.document_only") : nil) %>

<details class="group border-b border-slate-100 last:border-0">
  <summary class="flex cursor-pointer items-start gap-3 rounded-2xl px-3 py-3 transition hover:bg-amber-50/70">
    <div class="w-20 flex-shrink-0 text-[11px] text-slate-500">
      <div><%= l(display_time, format: "%m/%d") %></div>
      <div class="mt-0.5 text-[10px] text-slate-400"><%= l(display_time, format: "%H:%M") %></div>
    </div>

    <div class="flex-1 min-w-0">
      <div class="mb-1 flex items-center gap-2">
        <p class="line-clamp-1 min-w-0 flex-1 break-words text-sm font-medium leading-snug text-slate-900 [overflow-wrap:anywhere]"><%= summary_text %></p>
        <% if entry.source_ref.to_s.start_with?("healthkit:month:") %>
          <span class="inline-flex shrink-0 rounded-full bg-rose-100 px-2.5 py-1 text-[10px] font-semibold leading-none text-rose-600"><%= t("entries.source.healthkit_month") %></span>
        <% elsif entry.source_ref.to_s.start_with?("healthkit:day:") %>
          <span class="inline-flex shrink-0 rounded-full bg-rose-100 px-2.5 py-1 text-[10px] font-semibold leading-none text-rose-600"><%= t("entries.source.healthkit_day") %></span>
        <% elsif entry.healthkit_generated? %>
          <span class="inline-flex shrink-0 rounded-full bg-rose-100 px-2.5 py-1 text-[10px] font-semibold leading-none text-rose-600"><%= t("entries.source.healthkit_short") %></span>
        <% else %>
          <span class="inline-flex shrink-0 rounded-full bg-amber-100 px-2.5 py-1 text-[10px] font-semibold leading-none text-amber-700"><%= t("entries.source.manual") %></span>
        <% end %>
      </div>
      <% if entry.fact_items.present? %>
        <p class="mt-1 line-clamp-1 break-words text-[11px] text-slate-500 [overflow-wrap:anywhere]"><%= entry.input %></p>
      <% end %>
      <div class="mt-2">
        <%= render "entries/documents", entry: entry %>
      </div>
      <% if entry.pending_parse? %>
        <p class="mt-1 text-[11px] text-amber-700"><%= t("entries.parse_status.pending") %></p>
      <% elsif entry.failed_parse? %>
        <p class="mt-1 text-[11px] text-rose-600"><%= t("entries.parse_status.failed") %></p>
      <% elsif entry.skipped_parse? %>
        <p class="mt-1 text-[11px] text-slate-500"><%= t("entries.parse_status.skipped") %></p>
      <% end %>
    </div>

    <div class="flex h-7 w-7 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 shadow-sm transition group-open:rotate-180">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
      </svg>
    </div>
  </summary>

  <div class="px-3 pb-3 pt-1">
    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4 overflow-hidden break-all">
      <div class="grid gap-4 min-w-0">
        <section>
          <p class="mb-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("entries.raw_input.title") %></p>
          <p class="whitespace-pre-wrap break-words text-sm leading-relaxed text-slate-700 [overflow-wrap:anywhere]"><%= entry.input %></p>
        </section>

        <section>
          <p class="mb-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("entries.facts.title") %></p>
          <% if entry.fact_items.present? %>
            <ul class="space-y-1 text-sm leading-relaxed text-slate-700">
              <% entry.fact_items.each do |fact| %>
                <li class="break-words [overflow-wrap:anywhere]">• <%= fact %></li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-sm text-slate-500"><%= t("entries.parsed_data.empty") %></p>
          <% end %>
        </section>

        <section>
          <p class="mb-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("entries.parsed_data.title") %></p>
          <% if entry.parseable_data.present? %>
            <pre class="overflow-x-auto rounded-xl border border-slate-200 bg-white p-3 text-[11px] leading-5 text-slate-700 whitespace-pre-wrap break-words [overflow-wrap:anywhere]"><%= JSON.pretty_generate(entry.parseable_data) %></pre>
          <% else %>
            <p class="text-sm text-slate-500"><%= t("entries.parsed_data.empty") %></p>
          <% end %>

          <div class="mt-4">
            <%= render "entries/documents", entry: entry %>
          </div>
        </section>
      </div>
    </div>
  </div>
</details>
