<%= turbo_stream.replace "entries_list" do %>
  <%= render(@person.baby_mode? ? "entries/baby_list" : "entries/protocol_list", entries: @person.entries.recent_first) %>
<% end %>

<%= turbo_stream.replace "overview_recent_activity" do %>
  <%= render "shared/overview_recent_activity", person: @person, entries: @person.entries.recent_first %>
<% end %>

<%= turbo_stream.replace "overview_planning" do %>
  <%= render "shared/planning_widget", person: @person, card_classes: "xl:col-span-4 xl:row-span-3 h-full" %>
<% end %>

<% if @person.baby_mode? %>
  <%= turbo_stream.replace "overview_baby_activity_feeding" do %>
    <%= render "shared/baby_activity_widget", person: @person, type: :feeding %>
  <% end %>
  <%= turbo_stream.replace "overview_baby_activity_sleep" do %>
    <%= render "shared/baby_activity_widget", person: @person, type: :sleep %>
  <% end %>
  <%= turbo_stream.replace "overview_baby_activity_diaper" do %>
    <%= render "shared/baby_activity_widget", person: @person, type: :diaper %>
  <% end %>
<% end %>

<%= turbo_stream.replace "overview_person_meta" do %>
  <%= render "shared/overview_person_meta", person: @person, entries: @person.entries.recent_first %>
<% end %>

<%= turbo_stream.replace "overview_weight_activity" do %>
  <%= render "shared/weight_activity_widget", person: @person %>
<% end %>

<%= turbo_stream.replace "overview_height_activity" do %>
  <%= render "shared/height_activity_widget", person: @person %>
<% end %>

<%= turbo_stream.replace "overview_temperature_activity" do %>
  <%= render "shared/vital_activity_widget", person: @person, type: :temperature %>
<% end %>

<%= turbo_stream.replace "overview_pulse_activity" do %>
  <%= render "shared/vital_activity_widget", person: @person, type: :pulse %>
<% end %>

<%= turbo_stream.replace "overview_blood_pressure_activity" do %>
  <%= render "shared/vital_activity_widget", person: @person, type: :blood_pressure %>
<% end %>
