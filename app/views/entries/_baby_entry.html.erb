<div id="<%= dom_id(entry) %>" class="flex gap-4 rounded-2xl border border-white/10 bg-white/5 p-4">
  <div class="flex-shrink-0">
    <% if entry.baby_feeding? %>
      <div class="flex h-12 w-12 flex-col items-center justify-center rounded-xl bg-emerald-500/20 text-emerald-300">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
      </div>
    <% elsif entry.baby_diaper? %>
      <div class="flex h-12 w-12 flex-col items-center justify-center rounded-xl bg-blue-500/20 text-blue-300">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
      </div>
    <% else %>
      <div class="flex h-12 w-12 flex-col items-center justify-center rounded-xl bg-amber-500/20 text-amber-300">
        <span class="text-xs font-semibold uppercase"><%= entry.date.strftime("%b") %></span>
        <span class="text-lg font-bold leading-none"><%= entry.date.strftime("%d") %></span>
      </div>
    <% end %>
  </div>
  
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2 mb-1 flex-wrap">
      <% if entry.baby_feeding? %>
        <span class="text-xs font-semibold text-emerald-400 uppercase tracking-wider"><%= t("baby.types.feeding") %></span>
      <% elsif entry.baby_diaper? %>
        <span class="text-xs font-semibold text-blue-400 uppercase tracking-wider"><%= t("baby.types.diaper") %></span>
        
        <%# Diaper Consistency Badge %>
        <% if entry.diaper_consistency.present? %>
          <% consistency_colors = {
            "solid" => "bg-amber-500/30 text-amber-300",
            "fluid" => "bg-blue-500/30 text-blue-300", 
            "none" => "bg-cyan-500/30 text-cyan-300",
            "both" => "bg-purple-500/30 text-purple-300"
          } %>
          <span class="text-xs px-2 py-0.5 rounded-full <%= consistency_colors[entry.diaper_consistency] || 'bg-slate-500/30 text-slate-300' %>">
            <%= t("baby.diaper.consistency_options.#{entry.diaper_consistency}") %>
          </span>
        <% end %>
        
        <%# Rash Indicator %>
        <% if entry.diaper_rash? %>
          <span class="text-xs px-2 py-0.5 rounded-full bg-red-500/30 text-red-300">
            <%= t("baby.diaper.rash") %>
          </span>
        <% end %>
      <% end %>
      <span class="text-xs text-slate-500">• <%= time_ago_in_words(entry.created_at) %></span>
    </div>
    <p class="text-sm leading-relaxed text-white"><%= entry.note %></p>
    <p class="mt-1 text-xs text-slate-400"><%= entry.date.strftime("%B %d, %Y") %></p>
  </div>
  
  <%= button_to person_entry_path(entry.person, entry), method: :delete, class: "flex-shrink-0 self-start rounded-lg p-1.5 text-slate-400 hover:text-red-400 hover:bg-red-500/10 transition", data: { turbo_confirm: t("entries.destroy_confirm") } do %>
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12.562 3.011a17.933 17.933 0 0 1 3.167-.421m1.291-2.29 1.118-3.292A1.25 1.25 0 0 1 8.25 2.25h7.5a1.25 1.25 0 0 1 1.205.893l1.118 3.291m-9.772 3.01 12.331 0" />
    </svg>
  <% end %>
</div>
