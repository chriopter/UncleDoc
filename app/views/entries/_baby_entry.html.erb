<div id="<%= dom_id(entry) %>" class="flex gap-3 rounded-xl border border-white/10 bg-white/5 p-3">
  <div class="flex-shrink-0">
    <% if entry.feeding? %>
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-500/20 text-emerald-300">🤱</div>
    <% elsif entry.diaper? %>
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-500/20 text-blue-300">🧷</div>
    <% else %>
      <div class="flex h-10 w-10 flex-col items-center justify-center rounded-lg bg-amber-500/20 text-amber-300">
        <span class="text-xs font-semibold uppercase"><%= l(entry.display_time, format: "%b") %></span>
        <span class="text-base font-bold leading-none"><%= l(entry.display_time, format: "%d") %></span>
      </div>
    <% end %>
  </div>

  <div class="min-w-0 flex-1">
    <div class="mb-1 flex flex-wrap items-center gap-2">
      <% if entry.feeding? %>
        <span class="text-xs font-semibold uppercase tracking-wider text-emerald-400"><%= t("baby.types.feeding") %></span>
        <% if entry.feeding_duration_minutes.present? %>
          <span class="rounded-full bg-emerald-500/20 px-2 py-0.5 text-xs text-emerald-200"><%= t("baby.feeding.timer.duration", duration: entry.feeding_duration_minutes) %></span>
        <% end %>
        <% if entry.bottle_amount_ml.present? %>
          <span class="rounded-full bg-emerald-500/20 px-2 py-0.5 text-xs text-emerald-200"><%= t("baby.bottle.badge", amount: entry.bottle_amount_ml) %></span>
        <% end %>
      <% elsif entry.diaper? %>
        <span class="text-xs font-semibold uppercase tracking-wider text-blue-400"><%= t("baby.types.diaper") %></span>
        <% if entry.diaper_wet? || entry.diaper_solid? %>
          <span class="rounded-full bg-blue-500/20 px-2 py-0.5 text-xs text-blue-200">
            <% values = []
               values << t("entries.data_values.wet") if entry.diaper_wet?
               values << t("entries.data_values.solid") if entry.diaper_solid? %>
            <%= values.join(" + ") %>
          </span>
        <% end %>
        <% if entry.diaper_rash? %>
          <span class="rounded-full bg-red-500/20 px-2 py-0.5 text-xs text-red-200"><%= t("entries.data_values.rash") %></span>
        <% end %>
      <% end %>
      <span class="text-xs text-slate-500">• <%= time_ago_in_words(entry.display_time) %></span>
    </div>

    <p class="text-sm leading-snug text-white"><%= entry.note %></p>
    <%= render "entries/data_details", entry: entry %>
    <p class="mt-2 text-[11px] text-slate-400"><%= l(entry.display_time, format: :long) %></p>
  </div>

  <%= button_to person_entry_path(entry.person, entry), method: :delete, class: "flex-shrink-0 self-start rounded-lg p-1 text-slate-400 transition hover:bg-red-500/10 hover:text-red-400", data: { turbo_confirm: t("entries.destroy_confirm") } do %>
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12.562 3.011a17.933 17.933 0 0 1 3.167-.421m1.291-2.29 1.118-3.292A1.25 1.25 0 0 1 8.25 2.25h7.5a1.25 1.25 0 0 1 1.205.893l1.118 3.291m-9.772 3.01 12.331 0" />
    </svg>
  <% end %>
</div>
