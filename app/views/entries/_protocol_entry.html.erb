<div class="group flex gap-4 rounded-xl border-b border-white/10 py-4 last:border-0 hover:bg-white/5 transition px-2 -mx-2">
  <%# Date Column %>
  <% display_time = entry.occurred_at || entry.created_at %>
  <div class="flex-shrink-0 w-24">
    <div class="text-amber-300 text-sm font-semibold">
      <%= current_date_format == "compact" ? display_time.strftime("%m/%d/%Y") : display_time.strftime("%B %d, %Y") %>
    </div>
    <div class="text-xs text-slate-400 mt-0.5">
      <%= display_time.strftime("%H:%M") %>
    </div>
  </div>
  
  <%# Content Column %>
  <div class="flex-1 min-w-0">
    <p class="text-sm leading-relaxed text-white whitespace-pre-wrap"><%= entry.note %></p>
    <%= render "entries/data_details", entry: entry %>
  </div>
  
  <%# Actions Column - Hidden until hover %>
  <div class="flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
    <%= button_to person_entry_path(entry.person, entry), method: :delete, 
        class: "rounded-lg p-1.5 text-slate-400 hover:text-red-400 hover:bg-red-500/10 transition", 
        data: { turbo_confirm: t("entries.destroy_confirm") } do %>
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12.562 3.011a17.933 17.933 0 0 1 3.167-.421m1.291-2.29 1.118-3.292A1.25 1.25 0 0 1 8.25 2.25h7.5a1.25 1.25 0 0 1 1.205.893l1.118 3.291m-9.772 3.01 12.331 0" />
      </svg>
    <% end %>
  </div>
</div>
