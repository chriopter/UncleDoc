<article class="group rounded-[1.5rem] border border-white/10 bg-white/[0.03] px-4 py-4 transition hover:border-white/15 hover:bg-white/[0.05] sm:px-5">
  <% display_time = entry.occurred_at || entry.created_at %>
  <div class="grid gap-3 sm:grid-cols-[5.5rem_minmax(0,1fr)] sm:gap-4 sm:items-start">
    <div class="shrink-0 self-start px-1 py-1">
      <div class="text-lg font-semibold leading-none text-amber-300 sm:text-base">
        <%= display_time.strftime("%H:%M") %>
      </div>
      <%= render "entries/parse_status", entry: entry %>
    </div>

    <div class="min-w-0 flex-1">
      <div class="relative grid gap-3 lg:grid-cols-[minmax(0,1.7fr)_minmax(16rem,0.95fr)] lg:items-start lg:gap-0">
        <div class="hidden lg:block absolute bottom-1 top-1 right-[calc(18rem+1.25rem)] w-px bg-gradient-to-b from-transparent via-white/20 to-transparent"></div>

        <div class="min-w-0 rounded-2xl border border-transparent px-1 py-1 lg:px-0 lg:py-0 lg:pr-5">
          <div class="flex justify-end lg:hidden">
            <%= render "entries/entry_actions", entry: entry %>
          </div>

          <p class="text-base leading-relaxed text-white whitespace-pre-wrap break-words"><%= entry.note %></p>
        </div>

        <div class="p-3 lg:ml-5 lg:pl-5">
          <div class="mb-3 flex items-center justify-between gap-3">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-300"><%= t("entries.parsed_data.title") %></p>
            <div class="hidden lg:flex">
              <%= render "entries/entry_actions", entry: entry %>
            </div>
          </div>

          <% if entry.data.present? %>
            <%= render "entries/data_details", entry: entry %>
          <% else %>
            <p class="text-sm text-slate-400"><%= t("entries.parsed_data.empty") %></p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</article>
