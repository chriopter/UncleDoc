<% display_time = entry.occurred_at || entry.created_at %>
<% raw_text = entry.input.presence || (entry.documents_attached? ? t("entries.documents.document_only") : nil) %>
<% fact_preview = entry.fact_summary.presence %>
<% show_date = local_assigns[:show_date] %>
<% date = local_assigns[:date] %>

<details class="group" data-entry-collapsible="true">
  <summary class="grid cursor-pointer list-none grid-cols-[5.5rem_minmax(0,1fr)_5.5rem_6rem_1rem] items-center gap-2 px-4 py-3.5 transition hover:bg-amber-50/40 [&::-webkit-details-marker]:hidden">
    <div class="shrink-0 text-right">
      <% if show_date %>
        <p class="text-[10px] font-semibold uppercase tracking-[0.14em] text-amber-700"><%= log_day_label(date) %></p>
      <% end %>
    </div>

    <p class="min-w-0 truncate text-sm">
      <% if fact_preview.present? %>
        <span class="text-slate-800"><%= fact_preview %></span>
      <% elsif raw_text.present? %>
        <span class="text-slate-400"><%= raw_text.truncate(80) %></span>
      <% else %>
        <span class="text-slate-300">-</span>
      <% end %>
    </p>

    <div class="flex justify-end">
      <% if entry.source_ref.to_s.start_with?("healthkit:month:") %>
        <span class="rounded-full bg-rose-100 px-2.5 py-1 text-[10px] font-semibold leading-none text-rose-600"><%= t("entries.source.healthkit_month") %></span>
      <% elsif entry.source_ref.to_s.start_with?("healthkit:day:") %>
        <span class="rounded-full bg-rose-100 px-2.5 py-1 text-[10px] font-semibold leading-none text-rose-600"><%= t("entries.source.healthkit_day") %></span>
      <% elsif entry.healthkit_generated? %>
        <span class="rounded-full bg-rose-100 px-2.5 py-1 text-[10px] font-semibold leading-none text-rose-600"><%= t("entries.source.healthkit_short") %></span>
      <% elsif entry.babywidget_generated? %>
        <span class="rounded-full bg-sky-100 px-2.5 py-1 text-[10px] font-semibold leading-none text-sky-700"><%= t("entries.source.babywidget") %></span>
      <% else %>
        <span class="rounded-full bg-amber-100 px-2.5 py-1 text-[10px] font-semibold leading-none text-amber-700"><%= t("entries.source.manual") %></span>
      <% end %>
    </div>

    <div class="flex justify-end">
      <% if entry.appointment? %>
        <span class="rounded-full bg-violet-100 px-2.5 py-1 text-[10px] font-semibold leading-none text-violet-700"><%= t("entries.tags.appointment") %></span>
      <% elsif entry.todo? %>
        <span class="rounded-full bg-sky-100 px-2.5 py-1 text-[10px] font-semibold leading-none text-sky-700"><%= t("entries.tags.todo") %></span>
      <% elsif entry.documents_attached? %>
        <span class="rounded-full bg-emerald-100 px-2.5 py-1 text-[10px] font-semibold leading-none text-emerald-700"><%= t("entries.tags.document") %></span>
      <% elsif entry.failed_parse? %>
        <span class="rounded-full bg-red-100 px-2.5 py-1 text-[10px] font-semibold leading-none text-red-600"><%= t("entries.tags.parse_error") %></span>
      <% elsif entry.pending_parse? %>
        <span class="rounded-full bg-orange-100 px-2.5 py-1 text-[10px] font-semibold leading-none text-orange-600"><%= t("entries.tags.pending") %></span>
      <% elsif entry.skipped_parse? %>
        <span class="rounded-full bg-slate-100 px-2.5 py-1 text-[10px] font-semibold leading-none text-slate-500"><%= t("entries.tags.skipped") %></span>
      <% end %>
    </div>

    <svg class="h-3.5 w-3.5 shrink-0 text-slate-300 transition group-open:rotate-180 group-open:text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
    </svg>
  </summary>

  <div class="border-t border-slate-100 px-4 py-3 sm:ml-[6.5rem]">
    <div class="flex items-start justify-between gap-3">
      <p class="text-xs text-slate-400"><%= l(display_time, format: :long) %></p>
      <%= render "entries/entry_actions", entry: entry %>
    </div>

    <% if entry.healthkit_generated? && entry.source_ref.present? %>
      <div class="mt-2">
        <span class="inline-flex rounded-full border border-rose-200 bg-rose-50 px-2 py-0.5 text-[10px] font-semibold text-rose-700"><%= entry.source_ref %></span>
      </div>
    <% end %>

    <div class="mt-3 grid gap-4 lg:grid-cols-3">
      <div class="min-w-0">
        <p class="mb-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400"><%= t("entries.raw_input.title") %></p>
        <p class="text-sm leading-relaxed text-slate-700 whitespace-pre-wrap break-words"><%= raw_text %></p>
        <%= render "entries/documents", entry: entry, compact: false %>
      </div>

      <div class="min-w-0 border-t border-slate-100 pt-3 lg:border-t-0 lg:border-l lg:border-slate-100 lg:pl-4 lg:pt-0">
        <p class="mb-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400"><%= t("entries.facts.title") %></p>
        <% if entry.fact_items.present? %>
          <ul class="space-y-1 text-sm leading-relaxed text-slate-700">
            <% entry.fact_items.each do |fact| %>
              <li class="break-words">- <%= fact %></li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-slate-400"><%= t("entries.parsed_data.empty") %></p>
        <% end %>
      </div>

      <div class="min-w-0 border-t border-slate-100 pt-3 lg:border-t-0 lg:border-l lg:border-slate-100 lg:pl-4 lg:pt-0">
        <p class="mb-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400"><%= t("entries.parsed_data.title") %></p>
        <% if entry.parseable_data.present? %>
          <%= render "entries/data_details", entry: entry %>
        <% else %>
          <p class="text-sm text-slate-400"><%= t("entries.parsed_data.empty") %></p>
        <% end %>
      </div>
    </div>
  </div>
</details>
