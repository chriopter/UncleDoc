<article class="group px-4 py-4 transition hover:bg-white/[0.02] sm:px-5 <%= local_assigns[:grouped] ? '' : 'rounded-[1.5rem] border border-white/10 bg-white/[0.03] hover:border-white/15 hover:bg-white/[0.05]' %>">
  <% display_time = entry.occurred_at || entry.created_at %>
  <% raw_text = entry.input.presence || (entry.documents_attached? ? t("entries.documents.document_only") : nil) %>
  <div class="grid gap-3 sm:grid-cols-[5.5rem_minmax(0,1fr)] sm:gap-4 sm:items-start">
    <div class="shrink-0 self-start px-1 py-1">
      <div class="text-lg font-semibold leading-none text-amber-300 sm:text-base">
        <%= display_time.strftime("%H:%M") %>
      </div>
      <%= render "entries/parse_status", entry: entry %>

      <div class="mt-4 hidden lg:flex">
        <%= render "entries/entry_actions", entry: entry %>
      </div>
    </div>

    <div class="min-w-0 flex-1">
      <div class="grid gap-3 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_minmax(16rem,0.95fr)] lg:items-start">
        <div class="min-w-0 px-1 py-1 lg:pr-5">
          <div class="flex justify-end lg:hidden">
            <%= render "entries/entry_actions", entry: entry %>
          </div>

          <p class="mb-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400"><%= t("entries.raw_input.title") %></p>
          <p class="text-sm leading-relaxed text-slate-300 whitespace-pre-wrap break-words"><%= raw_text %></p>
          <div class="mt-4">
            <%= render "entries/documents", entry: entry, compact: false %>
          </div>
        </div>

        <div class="min-w-0 border-t border-white/10 pt-3 lg:border-t-0 lg:border-l lg:border-white/10 lg:px-5 lg:pt-1">
          <p class="mb-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-300"><%= t("entries.facts.title") %></p>

          <% if entry.fact_items.present? %>
            <ul class="space-y-1.5 text-base leading-relaxed text-white">
              <% entry.fact_items.each do |fact| %>
                <li class="break-words">• <%= fact %></li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-sm text-slate-400"><%= t("entries.parsed_data.empty") %></p>
          <% end %>
        </div>

        <div class="border-t border-white/10 pt-3 lg:border-t-0 lg:border-l lg:border-white/10 lg:pl-5 lg:pt-3">
          <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-300"><%= t("entries.parsed_data.title") %></p>

          <% if entry.parseable_data.present? %>
            <%= render "entries/data_details", entry: entry %>
          <% else %>
            <p class="text-sm text-slate-400"><%= t("entries.parsed_data.empty") %></p>
          <% end %>

        </div>
      </div>
    </div>
  </div>
</article>
