<%= turbo_stream.replace "entry_form" do %>
  <%= render(@person.baby_mode? ? "entries/form" : "entries/inline_form", entry: Entry.new, person: @person) %>
<% end %>

<%= turbo_stream.replace "entries_list" do %>
  <%= render(@person.baby_mode? ? "entries/baby_list" : "entries/protocol_list", entries: @person.entries.recent_first) %>
<% end %>

<%= turbo_stream.replace "overview_recent_activity" do %>
  <%= render "shared/overview_recent_activity", person: @person, entries: @person.entries.recent_first %>
<% end %>

<% if @person.baby_mode? %>
  <%= turbo_stream.replace "overview_baby_activity_feeding" do %>
    <%= render "shared/baby_activity_widget", person: @person, type: :feeding %>
  <% end %>
  <%= turbo_stream.replace "overview_baby_activity_diaper" do %>
    <%= render "shared/baby_activity_widget", person: @person, type: :diaper %>
  <% end %>
<% end %>

<%= turbo_stream.replace "overview_person_meta" do %>
  <%= render "shared/overview_person_meta", person: @person, entries: @person.entries.recent_first %>
<% end %>

<%= turbo_stream.replace "overview_weight_activity" do %>
  <%= render "shared/weight_activity_widget", person: @person %>
<% end %>
