<% if entry.fact_objects.present? %>
  <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
    <% entry.fact_objects.each_with_index do |fact, index| %>
      <% text = fact["text"].to_s.strip %>
      <% next if text.blank? %>
      <% fields = entry_fact_display_fields(fact) %>

      <div class="<%= index.positive? ? 'border-t border-slate-100' : '' %> px-4 py-3">
        <p class="text-sm font-semibold leading-6 text-slate-900"><%= text %></p>

        <% if fields.present? %>
          <dl class="mt-2 grid gap-2">
            <% fields.each do |key, value| %>
              <div class="text-sm leading-5 text-slate-700">
                <dt class="inline font-semibold text-slate-500"><%= entry_fact_field_label(key) %>:</dt>
                <dd class="inline break-words"><%= entry_fact_field_value(key, value) %></dd>
              </div>
            <% end %>
          </dl>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
