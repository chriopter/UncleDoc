<%= turbo_frame_tag "entry_form" do %>
  <%= form_with model: [person, entry], class: "space-y-4" do |f| %>
    <% if entry.errors.any? %>
      <div class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
        <% entry.errors.full_messages.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :occurred_at, t("activerecord.attributes.entry.occurred_at"), class: "block text-sm font-semibold text-slate-700" %>
      <%= f.datetime_local_field :occurred_at, value: (entry.occurred_at || Time.current).strftime("%Y-%m-%dT%H:%M"), class: "mt-1 block w-full rounded-xl border-slate-200 bg-white px-4 py-2 text-sm focus:border-amber-500 focus:ring-amber-500" %>
    </div>

    <div>
      <%= f.label :note, t("activerecord.attributes.entry.note"), class: "block text-sm font-semibold text-slate-700" %>
      <%= f.text_area :note, rows: 3, placeholder: t("entries.form.placeholder"), class: "mt-1 block w-full rounded-xl border-slate-200 bg-white px-4 py-2 text-sm focus:border-amber-500 focus:ring-amber-500" %>
    </div>

    <%= f.submit t("entries.form.submit"), class: "w-full rounded-xl bg-slate-950 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
  <% end %>
<% end %>
