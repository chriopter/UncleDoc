<%= turbo_frame_tag "entry_form" do %>
  <%= form_with model: [person, entry], class: "space-y-4" do |f| %>
    <% if entry.errors.any? %>
      <div class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
        <% entry.errors.full_messages.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :input, t("activerecord.attributes.entry.input"), class: "block text-sm font-semibold text-slate-700" %>
      <%= f.text_area :input, rows: 3, placeholder: t("entries.form.placeholder"), class: "mt-1 block w-full rounded-xl border border-slate-300 bg-slate-50 px-4 py-2 text-sm focus:border-amber-500 focus:ring-amber-500" %>
    </div>

    <div class="flex items-center gap-3">
      <details class="group rounded-full border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-600">
        <summary class="flex cursor-pointer list-none items-center gap-2 font-medium">
          <span class="flex h-8 w-8 items-center justify-center rounded-full bg-white text-slate-700 shadow-sm transition group-open:rotate-12" aria-label="<%= t("entries.form.change_time") %>">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </span>
          <span><%= t("entries.form.use_current_time") %></span>
        </summary>

        <div class="mt-3">
          <%= f.label :occurred_at, t("activerecord.attributes.entry.occurred_at"), class: "block text-sm font-semibold text-slate-700" %>
          <%= f.datetime_local_field :occurred_at, value: (entry.occurred_at || Time.current).strftime("%Y-%m-%dT%H:%M"), class: "mt-1 block w-full rounded-xl border-slate-200 bg-white px-4 py-2 text-sm focus:border-amber-500 focus:ring-amber-500" %>
        </div>
      </details>

      <%= f.submit t("entries.form.submit"), class: "rounded-xl bg-slate-950 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
    </div>
  <% end %>
<% end %>
