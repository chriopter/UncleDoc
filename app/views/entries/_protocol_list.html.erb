<%= turbo_frame_tag "entries_list" do %>
  <% if entries.any? %>
    <%= render "entries/grouped_list", entries: entries %>
  <% else %>
    <div class="rounded-3xl border border-dashed border-amber-200 bg-amber-50/50 px-6 py-16 text-center text-slate-600">
      <p class="text-lg font-medium text-slate-800"><%= t("dashboard.protocol.empty") %></p>
      <p class="mt-2 text-sm text-slate-500"><%= t("dashboard.protocol.empty_subtitle") %></p>
    </div>
  <% end %>
<% end %>
