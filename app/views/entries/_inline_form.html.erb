<%= turbo_frame_tag "entry_form" do %>
  <%= form_with model: [person, entry], class: "flex flex-col sm:flex-row gap-3 items-start" do |f| %>
    <% if entry.errors.any? %>
      <div class="w-full rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
        <% entry.errors.full_messages.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <%= f.datetime_local_field :occurred_at, value: (entry.occurred_at || Time.current).strftime("%Y-%m-%dT%H:%M"), 
        class: "w-full sm:w-56 rounded-xl border-slate-200 bg-slate-50 px-4 py-3 text-sm focus:border-amber-500 focus:ring-amber-500" %>

    <%= f.text_area :note, rows: 1, placeholder: t("entries.form.placeholder"), 
        class: "flex-1 min-h-[46px] rounded-xl border-slate-200 bg-slate-50 px-4 py-3 text-sm focus:border-amber-500 focus:ring-amber-500 resize-y" %>

    <%= f.submit t("entries.form.submit"), 
        class: "w-full sm:w-auto rounded-xl bg-slate-950 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800 whitespace-nowrap" %>
  <% end %>
<% end %>
