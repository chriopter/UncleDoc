<%= turbo_frame_tag dom_id(entry) do %>
  <section class="rounded-[1.5rem] border border-amber-400/20 bg-white/[0.05] p-4 shadow-sm ring-1 ring-white/10 sm:p-5">
    <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-amber-300"><%= t("entries.edit.label") %></p>
        <h3 class="mt-1 text-lg font-bold text-white"><%= t("entries.edit.title") %></h3>
        <p class="mt-1 text-sm text-slate-300"><%= t("entries.edit.subtitle") %></p>
      </div>

      <%= link_to t("actions.cancel"), person_entry_path(entry.person, entry),
          class: "inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-slate-200 transition hover:border-white/20 hover:bg-white/10 hover:text-white",
          data: { turbo_frame: dom_id(entry) } %>
    </div>

    <%= form_with model: [entry.person, entry], class: "space-y-4" do |f| %>
      <% if entry.errors.any? %>
        <div class="rounded-2xl border border-rose-400/20 bg-rose-500/10 px-4 py-3 text-sm text-rose-100">
          <% entry.errors.full_messages.each do |message| %>
            <p><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <%= f.label :note, t("activerecord.attributes.entry.note"), class: "mb-2 block text-sm font-semibold text-slate-200" %>
        <%= f.text_area :note, rows: 4, placeholder: t("entries.form.placeholder"), class: "block w-full rounded-[1.25rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-white placeholder:text-slate-500 focus:border-amber-400 focus:ring-amber-400" %>
      </div>

      <div>
        <%= f.label :occurred_at, t("activerecord.attributes.entry.occurred_at"), class: "mb-2 block text-sm font-semibold text-slate-200" %>
        <%= f.datetime_local_field :occurred_at, value: entry.occurred_at.strftime("%Y-%m-%dT%H:%M"), class: "block w-full rounded-[1.25rem] border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-white focus:border-amber-400 focus:ring-amber-400" %>
      </div>

      <div class="flex flex-col gap-3 border-t border-white/10 pt-4 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-xs text-slate-400"><%= t("entries.edit.reparse_hint") %></p>

        <div class="flex items-center gap-2">
          <%= link_to t("actions.cancel"), person_entry_path(entry.person, entry), class: "inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-slate-200 transition hover:border-white/20 hover:bg-white/10 hover:text-white", data: { turbo_frame: dom_id(entry) } %>
          <%= f.submit t("entries.edit.submit"), class: "inline-flex items-center justify-center rounded-full bg-amber-400 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-amber-300" %>
        </div>
      </div>
    <% end %>
  </section>
<% end %>
