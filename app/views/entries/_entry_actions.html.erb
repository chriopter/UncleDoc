<div class="flex items-center gap-2">
  <details class="relative">
    <summary class="flex cursor-pointer list-none items-center rounded-full border border-white/10 bg-white/5 p-2 text-slate-200 transition hover:border-white/20 hover:bg-white/10 hover:text-white">
      <span class="sr-only"><%= t("entries.db_row.toggle") %></span>
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <ellipse cx="12" cy="5" rx="7" ry="3" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 5v14c0 1.657 3.134 3 7 3s7-1.343 7-3V5" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 12c0 1.657 3.134 3 7 3s7-1.343 7-3" />
      </svg>
    </summary>

    <div class="absolute right-0 z-10 mt-2 w-[min(30rem,88vw)] overflow-hidden rounded-2xl border border-white/10 bg-slate-950 shadow-2xl ring-1 ring-black/30">
      <div class="border-b border-white/10 px-4 py-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-300">
        <%= t("entries.db_row.toggle") %>
      </div>
      <pre class="max-h-96 overflow-auto px-4 py-3 text-[11px] leading-5 text-slate-200 whitespace-pre-wrap break-words"><%= JSON.pretty_generate(entry.attributes) %></pre>
    </div>
  </details>

  <% if entry.parseable_data.present? %>
    <details class="relative">
      <summary class="flex cursor-pointer list-none items-center rounded-full border border-white/10 bg-white/5 p-2 text-slate-200 transition hover:border-white/20 hover:bg-white/10 hover:text-white">
        <span class="sr-only"><%= t("entries.raw_data.toggle") %></span>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5.25 12 5.25S20.268 7.943 21.542 12C20.268 16.057 16.477 18.75 12 18.75S3.732 16.057 2.458 12Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 15.75a3.75 3.75 0 1 0 0-7.5 3.75 3.75 0 0 0 0 7.5Z" />
        </svg>
      </summary>

      <div class="absolute right-0 z-10 mt-2 w-[min(24rem,80vw)] overflow-hidden rounded-2xl border border-white/10 bg-slate-950 shadow-2xl ring-1 ring-black/30">
        <div class="border-b border-white/10 px-4 py-3 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-300">
          <%= t("entries.raw_data.toggle") %>
        </div>
        <pre class="max-h-80 overflow-auto px-4 py-3 text-[11px] leading-5 text-slate-200 whitespace-pre-wrap break-words"><%= JSON.pretty_generate(entry.parseable_data) %></pre>
      </div>
    </details>
  <% end %>

  <%= link_to edit_person_entry_path(entry.person, entry),
      class: "inline-flex items-center rounded-full border border-white/10 bg-white/5 p-2 text-slate-200 transition hover:border-white/20 hover:bg-white/10 hover:text-white",
      data: { turbo_frame: dom_id(entry) },
      aria: { label: t("actions.edit") } do %>
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 3.487a2.25 2.25 0 1 1 3.182 3.182L8.25 18.463 3.75 19.5l1.037-4.5L16.862 3.487Z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 5.25 18.75 9" />
    </svg>
  <% end %>

  <%= button_to person_entry_path(entry.person, entry), method: :delete,
      class: "inline-flex items-center rounded-full border border-white/10 bg-white/5 p-2 text-slate-400 transition hover:border-red-400/30 hover:bg-red-500/10 hover:text-red-300",
      data: { turbo_confirm: t("entries.destroy_confirm") },
      aria: { label: t("actions.delete") } do %>
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12.562 3.011a17.933 17.933 0 0 1 3.167-.421m1.291-2.29 1.118-3.292A1.25 1.25 0 0 1 8.25 2.25h7.5a1.25 1.25 0 0 1 1.205.893l1.118 3.291m-9.772 3.01 12.331 0" />
    </svg>
  <% end %>
</div>
