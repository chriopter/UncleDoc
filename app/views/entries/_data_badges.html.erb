<% Array(entry.data).each do |item| %>
  <% next unless item.is_a?(Hash) && item["type"].present? %>
  <% label_key = item["type"].to_s.downcase %>
  <% label = t("entries.data_labels.#{label_key}", default: item["type"].to_s.humanize) %>
  <% badge_text = nil %>
  <% case item["type"] %>
  <% when "temperature" %>
    <% badge_text = ["TEMP", item["value"], item["unit"]].compact.join %>
  <% when "pulse" %>
    <% badge_text = ["PULSE", item["value"], item["unit"]].compact.join(" ") %>
  <% when "weight" %>
    <% badge_text = ["WT", item["value"], item["unit"]].compact.join(" ") %>
  <% when "bottle_feeding" %>
    <% badge_text = ["BOTTLE", item["value"], item["unit"]].compact.join %>
  <% when "breast_feeding" %>
    <% side_label = item["side"].present? ? t("entries.data_values.side_#{item['side']}", default: item["side"].to_s.humanize) : nil %>
    <% badge_text = ["BREAST", side_label, item["value"], item["unit"]].compact.join(" ") %>
  <% when "diaper" %>
    <% states = [] %>
    <% states << t("entries.data_values.wet") if item["wet"] == true %>
    <% states << t("entries.data_values.solid") if item["solid"] == true %>
    <% states << t("entries.data_values.rash") if item["rash"] == true %>
    <% badge_text = ["DIAPER", states.join(" + ")].compact.join(" ") %>
  <% when "sleep" %>
    <% badge_text = ["SLEEP", item["value"], item["unit"]].compact.join(" ") %>
  <% when "medication" %>
    <% badge_text = ["MED", item["value"], item["dose"]].compact.join(" ") %>
  <% else %>
    <% badge_text = [label, item["value"], item["unit"], item["dose"], item["flag"]].compact.join(" ") %>
  <% end %>
  <% next if badge_text.blank? %>
  <span class="rounded-full bg-white/10 px-2.5 py-1 text-xs font-medium text-slate-200"><%= badge_text %></span>
<% end %>
