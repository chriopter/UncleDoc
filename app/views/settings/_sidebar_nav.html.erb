<div class="space-y-2">
  <div class="space-y-2">
    <div class="rounded-2xl border border-slate-200 bg-slate-50/80 px-3 py-2">
      <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-500"><%= t("settings.user_group.label") %></p>
    </div>

    <div class="ml-4 space-y-1 border-l-2 border-slate-200 pl-3">
      <%= link_to settings_path_for(:profile), class: settings_subnav_item_class(@section == "profile") do %>
        <span><%= t("settings.profile.nav") %></span>
      <% end %>

      <%= link_to settings_path_for(:users), class: settings_subnav_item_class(@section == "users") do %>
        <span><%= t("settings.users.nav") %></span>
      <% end %>
    </div>
  </div>

  <%= link_to settings_path_for(:llm), class: settings_sidebar_item_class(@section == "llm") do %>
    <span><%= t("settings.llm.title") %></span>
    <span class="text-xs uppercase tracking-[0.2em] opacity-70"><%= t("settings.llm.subtitle") %></span>
  <% end %>

  <div class="ml-4 space-y-1 border-l-2 border-slate-200 pl-3">
    <%= link_to settings_path(section: "llm_prompt"), class: settings_subnav_item_class(@section == "llm_prompt") do %>
      <span><%= t("settings.llm_prompt.nav") %></span>
    <% end %>

    <%= link_to settings_path(section: "llm_logs"), class: settings_subnav_item_class(@section == "llm_logs") do %>
      <span><%= t("settings.llm_logs.nav") %></span>
    <% end %>
  </div>

  <%= link_to settings_path_for(:db), class: settings_sidebar_item_class(@section == "db") do %>
    <span><%= t("settings.db.title") %></span>
    <span class="text-xs uppercase tracking-[0.2em] opacity-70"><%= t("settings.db.subtitle") %></span>
  <% end %>
</div>
