<section class="rounded-[2rem] border border-white/70 bg-white/90 p-5 ring-1 ring-black/5 backdrop-blur">
  <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("settings.users.title") %></p>
    <h2 class="text-2xl font-black tracking-tight text-slate-950"><%= t("people.list.title") %></h2>
  </div>
</section>

<section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5">
  <div class="mb-4 border-b border-slate-200 pb-3">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("people.new.label") %></p>
    <h3 class="mt-0.5 text-lg font-bold text-slate-950"><%= t("people.new.title") %></h3>
  </div>
  <%= render "people/form", person: person %>
</section>

<section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5">
  <div class="mb-4 flex items-center justify-between border-b border-slate-200 pb-3">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("people.list.label") %></p>
      <h3 class="mt-0.5 text-lg font-bold text-slate-950"><%= t("people.list.title") %></h3>
    </div>
    <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2.5 py-0.5 text-xs font-semibold text-slate-700"><%= t("people.list.count", count: people.count) %></span>
  </div>
  <%= render "settings/users_list", people: people %>
</section>
