<section class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
  <div class="mb-6">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("settings.users.title") %></p>
    <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950"><%= t("people.list.title") %></h2>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600">
      <%= t("settings.subtitle") %>
    </p>
  </div>

  <div class="grid gap-6 xl:grid-cols-[minmax(0,420px)_minmax(0,1fr)]">
    <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-black/5">
      <div class="mb-5 space-y-2">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("people.new.label") %></p>
        <h3 class="text-xl font-bold text-slate-950"><%= t("people.new.title") %></h3>
        <p class="text-sm leading-6 text-slate-600"><%= t("people.new.subtitle") %></p>
      </div>

      <%= render "people/form", person: person %>
    </div>

    <div class="rounded-[2rem] border border-slate-200 bg-slate-50 p-6 shadow-sm ring-1 ring-black/5">
      <div class="mb-5 flex items-end justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("people.list.label") %></p>
          <h3 class="text-xl font-bold text-slate-950"><%= t("people.list.title") %></h3>
        </div>
        <span class="rounded-full border border-slate-300 bg-white px-3 py-1 text-xs font-semibold text-slate-600"><%= t("people.list.count", count: people.count) %></span>
      </div>

      <% if people.any? %>
        <div class="space-y-3">
          <% people.each do |p| %>
            <div class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white p-4">
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-amber-100 text-amber-800 font-semibold text-sm">
                  <%= p.name.first.upcase %>
                </div>
                <div>
                  <p class="font-semibold text-slate-950"><%= p.name %></p>
                  <p class="text-xs text-slate-500"><%= formatted_date(p.birth_date) %></p>
                  <% if p.baby_mode? %>
                    <span class="inline-flex items-center rounded-full bg-pink-100 px-2 py-0.5 text-xs font-medium text-pink-800 mt-1">
                      <%= t("baby.badge") %>
                    </span>
                  <% end %>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <%= button_to person_path(p, person: { baby_mode: !p.baby_mode }), method: :patch, class: "rounded-xl p-2 text-slate-400 hover:bg-pink-50 hover:text-pink-600 transition", title: t("baby.toggle") do %>
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.592-2.296 6.375 6.375 0 0 1 1.998 3.18M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106c0 .771-.146 1.508-.408 2.19M12 14a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" />
                  </svg>
                <% end %>
                <%= button_to person_path(p), method: :delete, class: "rounded-xl p-2 text-slate-400 hover:bg-red-50 hover:text-red-600 transition", data: { turbo_confirm: t("people.person.remove_confirm", name: p.name) } do %>
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12.562 3.011a17.933 17.933 0 0 1 3.167-.421m1.291-2.29 1.118-3.292A1.25 1.25 0 0 1 8.25 2.25h7.5a1.25 1.25 0 0 1 1.205.893l1.118 3.291m-9.772 3.01 12.331 0" />
                  </svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="rounded-3xl border border-dashed border-slate-300 bg-white px-6 py-10 text-center text-slate-500">
          <%= t("people.list.empty") %>
        </div>
      <% end %>
    </div>
  </div>
</section>
