<section class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
  <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("settings.llm_logs.label") %></p>
  <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950"><%= t("settings.llm_logs.title") %></h2>
  <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600"><%= t("settings.llm_logs.description") %></p>
</section>

<section class="space-y-4">
  <% if @llm_logs.any? %>
    <% @llm_logs.each do |log| %>
      <article class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm ring-1 ring-black/5">
        <div class="flex flex-col gap-3 border-b border-slate-200 bg-slate-950 px-5 py-4 text-white md:flex-row md:items-center md:justify-between">
          <div>
            <h3 class="text-lg font-bold"><%= log.request_kind %></h3>
            <p class="text-sm text-slate-300"><%= l(log.created_at, format: :long) %></p>
          </div>
          <div class="flex flex-wrap gap-2 text-xs">
            <span class="rounded-full border border-white/15 px-3 py-1 text-slate-300"><%= log.provider %></span>
            <% if log.model.present? %>
              <span class="rounded-full border border-white/15 px-3 py-1 text-slate-300"><%= log.model %></span>
            <% end %>
            <% if log.status_code.present? %>
              <span class="rounded-full border border-white/15 px-3 py-1 text-slate-300"><%= t("settings.llm_logs.http_status", status: log.status_code) %></span>
            <% end %>
          </div>
        </div>

        <div class="grid gap-4 p-5 lg:grid-cols-2">
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("settings.llm_logs.request") %></p>
            <p class="truncate font-mono text-xs leading-6 text-slate-700"><%= log.request_payload.to_s.strip.presence || "-" %></p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
            <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("settings.llm_logs.response") %></p>
            <p class="truncate font-mono text-xs leading-6 text-slate-700"><%= (log.response_body.presence || log.error_message.presence || "-").to_s.strip %></p>
          </div>
        </div>

        <details class="mx-5 mb-5 rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
          <summary class="cursor-pointer list-none text-sm font-semibold text-slate-900">
            <span class="inline-flex items-center rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.16em] text-slate-700"><%= t("settings.llm_logs.raw_data.toggle") %></span>
          </summary>

          <div class="mt-4 grid gap-4 lg:grid-cols-2">
            <div>
              <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("settings.llm_logs.request") %></p>
              <pre class="overflow-x-auto rounded-2xl bg-slate-950 p-4 text-xs leading-6 text-slate-100 whitespace-pre-wrap"><%= log.request_payload %></pre>
            </div>
            <div>
              <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("settings.llm_logs.response") %></p>
              <pre class="overflow-x-auto rounded-2xl bg-slate-950 p-4 text-xs leading-6 text-slate-100 whitespace-pre-wrap"><%= log.response_body.presence || log.error_message.presence || "-" %></pre>
            </div>
          </div>
        </details>

        <div class="border-t border-slate-100 px-5 py-4 text-xs text-slate-500">
          <span><%= log.endpoint %></span>
          <% if log.entry_id.present? %>
            <span class="ml-3"><%= t("settings.llm_logs.entry_id", id: log.entry_id) %></span>
          <% end %>
          <% if log.person_id.present? %>
            <span class="ml-3"><%= t("settings.llm_logs.person_id", id: log.person_id) %></span>
          <% end %>
        </div>
      </article>
    <% end %>
  <% else %>
    <section class="rounded-[2rem] border border-dashed border-slate-300 bg-white/80 p-8 text-center text-sm text-slate-500 shadow-sm ring-1 ring-black/5">
      <%= t("settings.llm_logs.empty") %>
    </section>
  <% end %>
</section>
