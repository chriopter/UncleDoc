<section class="grid gap-6 lg:grid-cols-[260px_minmax(0,1fr)]">
  <aside class="rounded-[2rem] border border-white/70 bg-white/90 p-5 shadow-sm ring-1 ring-black/5 backdrop-blur">
    <p class="text-sm font-semibold uppercase tracking-[0.25em] text-amber-700"><%= t("nav.settings") %></p>
    <h1 class="mt-2 text-2xl font-black tracking-tight text-slate-950"><%= t("settings.title") %></h1>
    <p class="mt-2 text-sm leading-6 text-slate-600"><%= t("settings.subtitle") %></p>

    <nav class="mt-6 space-y-2">
      <%= link_to settings_path_for(:profile), class: settings_sidebar_item_class(@section == "profile") do %>
        <span><%= t("settings.profile.title") %></span>
        <span class="text-xs uppercase tracking-[0.2em] opacity-70"><%= t("settings.profile.subtitle") %></span>
      <% end %>

      <%= link_to settings_path_for(:users), class: settings_sidebar_item_class(@section == "users") do %>
        <span><%= t("settings.users.title") %></span>
        <span class="text-xs uppercase tracking-[0.2em] opacity-70"><%= t("settings.users.subtitle") %></span>
      <% end %>

      <%= link_to settings_path_for(:llm), class: settings_sidebar_item_class(@section == "llm") do %>
        <span><%= t("settings.llm.title") %></span>
        <span class="text-xs uppercase tracking-[0.2em] opacity-70"><%= t("settings.llm.subtitle") %></span>
      <% end %>

      <div class="ml-4 space-y-1 border-l-2 border-slate-200 pl-3">
        <%= link_to settings_path(section: "llm_logs"), class: settings_subnav_item_class(@section == "llm_logs") do %>
          <span><%= t("settings.llm_logs.nav") %></span>
        <% end %>
      </div>

      <%= link_to settings_path_for(:db), class: settings_sidebar_item_class(@section == "db") do %>
        <span><%= t("settings.db.title") %></span>
        <span class="text-xs uppercase tracking-[0.2em] opacity-70"><%= t("settings.db.subtitle") %></span>
      <% end %>
      
      <% if @section == "db" && @database_snapshot.present? %>
        <div class="mt-2 ml-4 space-y-1 border-l-2 border-slate-200 pl-3">
          <%# Data Tables Group %>
          <div class="mb-2">
            <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1">Data</p>
            <% @database_snapshot[:data].each do |table| %>
              <%= link_to "##{table[:name]}", class: "block py-1 text-xs text-slate-600 hover:text-slate-900 transition" do %>
                <%= table[:name] %>
                <span class="text-[10px] text-slate-400">(<%= table[:count] %>)</span>
              <% end %>
            <% end %>
          </div>
          
          <%# System Tables Group %>
          <div>
            <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-400 mb-1">System</p>
            <% @database_snapshot[:system].each do |table| %>
              <%= link_to "##{table[:name]}", class: "block py-1 text-xs text-slate-600 hover:text-slate-900 transition" do %>
                <%= table[:name] %>
                <span class="text-[10px] text-slate-400">(<%= table[:count] %>)</span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </nav>
  </aside>

  <div class="space-y-6">
    <% if @section == "db" %>
      <%= render "dashboard/db", database_snapshot: @database_snapshot %>
    <% elsif @section == "users" %>
      <%= render "settings/users", people: @people, person: @person %>
    <% elsif @section == "llm_logs" %>
      <%= render "settings/llm_logs" %>
    <% elsif @section == "llm" %>
      <%= render "settings/llm" %>
    <% else %>
      <section class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("settings.profile.title") %></p>
        <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950"><%= t("settings.display.title") %></h2>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600">
          <%= t("settings.display.subtitle") %>
        </p>
      </section>

      <section class="grid gap-6 xl:grid-cols-2">
        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-black/5">
          <div class="mb-4">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("settings.language.label") %></p>
            <h3 class="mt-1 text-xl font-bold text-slate-950"><%= t("settings.language.title") %></h3>
          </div>

          <div class="grid gap-3">
            <%= link_to settings_path_for(:profile) + "?locale=en", class: settings_option_class(current_locale == "en") do %>
              <span><%= t("settings.language.english") %></span>
              <span class="text-xs uppercase tracking-[0.2em] text-slate-500">EN</span>
            <% end %>

            <%= link_to settings_path_for(:profile) + "?locale=de", class: settings_option_class(current_locale == "de") do %>
              <span><%= t("settings.language.german") %></span>
              <span class="text-xs uppercase tracking-[0.2em] text-slate-500">DE</span>
            <% end %>
          </div>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-black/5">
          <div class="mb-4">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("settings.date_format.label") %></p>
            <h3 class="mt-1 text-xl font-bold text-slate-950"><%= t("settings.date_format.title") %></h3>
          </div>

          <%= form_with url: settings_path(section: "profile"), method: :patch, class: "grid gap-3" do |f| %>
            <%= f.hidden_field :date_format, value: "long" %>
            <%= f.button type: :submit, class: settings_option_class(current_date_format == "long") do %>
              <span><%= t("settings.date_format.long") %></span>
              <span class="text-xs text-slate-500"><%= current_locale == "de" ? "28. März 2026" : "March 28, 2026" %></span>
            <% end %>
          <% end %>

          <%= form_with url: settings_path(section: "profile"), method: :patch, class: "grid gap-3 mt-3" do |f| %>
            <%= f.hidden_field :date_format, value: "compact" %>
            <%= f.button type: :submit, class: settings_option_class(current_date_format == "compact") do %>
              <span><%= t("settings.date_format.compact") %></span>
              <span class="text-xs text-slate-500"><%= current_locale == "de" ? "28.03.2026" : "03/28/2026" %></span>
            <% end %>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</section>
