<section class="grid gap-6 lg:grid-cols-[260px_minmax(0,1fr)]">
  <aside class="rounded-[2rem] border border-white/70 bg-white/90 p-5 shadow-sm ring-1 ring-black/5 backdrop-blur">
    <p class="text-sm font-semibold uppercase tracking-[0.25em] text-amber-700">Settings</p>
    <h1 class="mt-2 text-2xl font-black tracking-tight text-slate-950">Workspace settings</h1>
    <p class="mt-2 text-sm leading-6 text-slate-600">A simple admin area for display options and the raw database browser.</p>

    <nav class="mt-6 space-y-2">
      <%= link_to settings_path(:profile), class: settings_sidebar_item_class(@section == "profile") do %>
        <span>Profile settings</span>
        <span class="text-xs uppercase tracking-[0.2em] opacity-70">UI</span>
      <% end %>

      <%= link_to settings_path(:db), class: settings_sidebar_item_class(@section == "db") do %>
        <span>Full DB view</span>
        <span class="text-xs uppercase tracking-[0.2em] opacity-70">SQL</span>
      <% end %>
    </nav>
  </aside>

  <div class="space-y-6">
    <% if @section == "db" %>
      <%= render "dashboard/db", database_snapshot: @database_snapshot %>
    <% else %>
      <section class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700">Profile settings</p>
        <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950">Display preferences</h2>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600">
          Keep the first admin area simple: choose language and date format for your current view.
        </p>
      </section>

      <section class="grid gap-6 xl:grid-cols-2">
        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-black/5">
          <div class="mb-4">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Language</p>
            <h3 class="mt-1 text-xl font-bold text-slate-950">Choose app language</h3>
          </div>

          <div class="grid gap-3">
            <%= link_to settings_path(:profile, locale: "en", date_format: current_date_format), class: settings_option_class(current_locale == "en") do %>
              <span>English</span>
              <span class="text-xs uppercase tracking-[0.2em] text-slate-500">EN</span>
            <% end %>

            <%= link_to settings_path(:profile, locale: "de", date_format: current_date_format), class: settings_option_class(current_locale == "de") do %>
              <span>Deutsch</span>
              <span class="text-xs uppercase tracking-[0.2em] text-slate-500">DE</span>
            <% end %>
          </div>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-black/5">
          <div class="mb-4">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Date format</p>
            <h3 class="mt-1 text-xl font-bold text-slate-950">Choose date display</h3>
          </div>

          <div class="grid gap-3">
            <%= link_to settings_path(:profile, locale: current_locale, date_format: "long"), class: settings_option_class(current_date_format == "long") do %>
              <span>Long</span>
              <span class="text-xs text-slate-500"><%= current_locale == "de" ? "28. Marz 2026" : "March 28, 2026" %></span>
            <% end %>

            <%= link_to settings_path(:profile, locale: current_locale, date_format: "compact"), class: settings_option_class(current_date_format == "compact") do %>
              <span>Compact</span>
              <span class="text-xs text-slate-500"><%= current_locale == "de" ? "28.03.2026" : "03/28/2026" %></span>
            <% end %>
          </div>
        </div>
      </section>
    <% end %>
  </div>
</section>
