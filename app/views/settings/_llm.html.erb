<% llm_ready = app_setting.llm_model.present? && (app_setting.llm_api_key_configured? || app_setting.llm_provider == "ollama") %>
<section class="rounded-[2rem] border border-white/70 bg-white/90 p-5 ring-1 ring-black/5 backdrop-blur">
  <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("settings.llm.title") %></p>
    <h2 class="text-2xl font-black tracking-tight text-slate-950"><%= t("settings.llm.heading") %></h2>
  </div>
</section>

<section class="grid gap-5 xl:grid-cols-[minmax(0,1.4fr)_minmax(18rem,0.8fr)] xl:items-start">
  <section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5">
    <div class="mb-4 flex items-center justify-between border-b border-slate-200 pb-3">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("settings.llm.configuration_label") %></p>
        <h3 class="mt-0.5 text-lg font-bold text-slate-950"><%= t("settings.llm.configuration_title") %></h3>
      </div>
      <% if llm_ready %>
        <span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-2.5 py-0.5 text-xs font-semibold text-emerald-800"><%= t("settings.llm.ready") %></span>
      <% else %>
        <span class="inline-flex items-center rounded-full border border-amber-200 bg-amber-50 px-2.5 py-0.5 text-xs font-semibold text-amber-800"><%= t("settings.llm.needs_setup") %></span>
      <% end %>
    </div>

    <%= form_with url: settings_path(section: :llm), method: :patch, class: "space-y-3", data: { controller: "llm-settings", llm_settings_path_value: settings_llm_models_path, llm_settings_initial_model_value: app_setting.llm_model.to_s } do |form| %>
      <div class="grid gap-3 sm:grid-cols-[1fr_2fr]">
        <div class="space-y-1.5">
          <%= form.label :llm_provider, t("settings.llm.provider_label"), class: "text-sm font-semibold text-slate-700" %>
          <%= form.select :llm_provider, AppSetting::LLM_PROVIDERS.keys.map { |provider| [t("settings.llm.providers.#{provider}.name"), provider] }, { selected: current_llm_provider }, class: "w-full rounded-xl border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-500 focus:ring-2 focus:ring-amber-200", data: { llm_settings_target: "provider", action: "change->llm-settings#lookup" } %>
        </div>

        <div class="space-y-1.5">
          <div class="flex items-center justify-between gap-3">
            <%= form.label :llm_api_key, t("settings.llm.api_key_title"), class: "text-sm font-semibold text-slate-700" %>
            <span class="text-xs text-slate-500"><%= app_setting.llm_api_key_configured? ? t("settings.llm.api_key_saved") : t("settings.llm.api_key_missing") %></span>
          </div>
        <%= form.password_field :llm_api_key, autocomplete: "off", placeholder: app_setting.llm_api_key_configured? ? "••••••••••••••••" : t("settings.llm.api_key_placeholder"), class: "w-full rounded-xl border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-amber-500 focus:ring-2 focus:ring-amber-200", data: { llm_settings_target: "apiKey", action: "blur->llm-settings#lookup input->llm-settings#queueLookup" } %>
        </div>
      </div>

      <div class="space-y-1.5">
        <%= form.label :llm_model, t("settings.llm.model_title"), class: "text-sm font-semibold text-slate-700" %>
        <%= form.select :llm_model, [], { prompt: t("settings.llm.model_placeholder") }, class: "w-full rounded-xl border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-500 focus:ring-2 focus:ring-amber-200", data: { llm_settings_target: "model" } %>
        <p class="text-xs leading-5 text-slate-400" data-llm-settings-target="status" data-loading-text="<%= t("settings.llm.model_status.loading") %>" data-failed-text="<%= t("settings.llm.model_status.request_failed") %>"><%= t("settings.llm.model_status.idle") %></p>
      </div>

      <p class="hidden" data-llm-settings-target="credentialsHint" data-template="<%= t("settings.llm.credentials_hint", env_key: "%{env_key}") %>"></p>
      <p class="hidden" data-llm-settings-target="endpointHint" data-template="<%= t("settings.llm.endpoint_hint", endpoint: "%{endpoint}") %>"></p>

      <div class="flex items-center justify-end gap-2 border-t border-slate-100 pt-3">
        <button type="button" data-action="click->llm-settings#testConnection" class="inline-flex items-center rounded-full border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" data-llm-settings-target="testButton" data-test-url="<%= settings_llm_test_path %>">
          <%= t("settings.llm.test") %>
        </button>
        <span class="text-xs text-slate-500" data-llm-settings-target="testResult"></span>
        <%= form.submit(llm_ready ? t("settings.llm.edit") : t("settings.llm.save"), class: "inline-flex items-center rounded-full bg-slate-950 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800") %>
      </div>
    <% end %>
  </section>

  <aside class="xl:sticky xl:top-6">
    <section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5">
      <div class="mb-4 border-b border-slate-200 pb-3">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("settings.llm.usage_label") %></p>
        <h3 class="mt-0.5 text-lg font-bold text-slate-950"><%= t("settings.llm.usage_title") %></h3>
      </div>

      <div class="space-y-2">
        <div class="flex items-center justify-between rounded-xl border border-slate-200 bg-slate-50/80 px-3.5 py-2.5">
          <p class="text-xs font-semibold text-slate-500"><%= t("settings.llm.usage_chats") %></p>
          <p class="text-xl font-black text-slate-950"><%= @llm_stats[:chat_count] %></p>
        </div>
        <div class="flex items-center justify-between rounded-xl border border-slate-200 bg-slate-50/80 px-3.5 py-2.5">
          <p class="text-xs font-semibold text-slate-500"><%= t("settings.llm.usage_prompts") %></p>
          <p class="text-xl font-bold text-slate-950"><%= @llm_stats[:prompt_count] %></p>
        </div>
        <div class="flex items-center justify-between rounded-xl border border-slate-200 bg-slate-50/80 px-3.5 py-2.5">
          <p class="text-xs font-semibold text-slate-500"><%= t("settings.llm.usage_responses") %></p>
          <p class="text-xl font-bold text-slate-950"><%= @llm_stats[:response_count] %></p>
        </div>
        <div class="grid grid-cols-2 gap-2">
          <div class="rounded-xl border border-slate-200 bg-slate-50/80 px-3.5 py-2.5">
            <p class="text-xs font-semibold text-slate-500"><%= t("settings.llm.input_tokens") %></p>
            <p class="text-lg font-bold text-slate-950"><%= number_with_delimiter(@llm_stats[:input_tokens]) %></p>
          </div>
          <div class="rounded-xl border border-slate-200 bg-slate-50/80 px-3.5 py-2.5">
            <p class="text-xs font-semibold text-slate-500"><%= t("settings.llm.output_tokens") %></p>
            <p class="text-lg font-bold text-slate-950"><%= number_with_delimiter(@llm_stats[:output_tokens]) %></p>
          </div>
          <div class="rounded-xl border border-slate-200 bg-slate-50/80 px-3.5 py-2.5">
            <p class="text-xs font-semibold text-slate-500"><%= t("settings.llm.cached_tokens") %></p>
            <p class="text-lg font-bold text-slate-950"><%= number_with_delimiter(@llm_stats[:cached_tokens]) %></p>
          </div>
          <div class="rounded-xl border border-slate-200 bg-slate-50/80 px-3.5 py-2.5">
            <p class="text-xs font-semibold text-slate-500"><%= t("settings.llm.thinking_tokens") %></p>
            <p class="text-lg font-bold text-slate-950"><%= number_with_delimiter(@llm_stats[:thinking_tokens]) %></p>
          </div>
        </div>
      </div>

      <p class="mt-3 text-xs text-slate-400">
        <% if @llm_stats[:latest_request_at].present? %>
          <%= t("settings.llm.latest_request", time: l(@llm_stats[:latest_request_at], format: :long)) %>
        <% else %>
          <%= t("settings.llm.no_requests") %>
        <% end %>
      </p>
    </section>

    <section class="mt-5 rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5">
      <div class="mb-4 border-b border-slate-200 pb-3">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("settings.llm.cost_label") %></p>
        <h3 class="mt-0.5 text-lg font-bold text-slate-950"><%= t("settings.llm.cost_label") %></h3>
      </div>

      <div class="space-y-2">
        <div class="flex items-center justify-between rounded-xl border border-slate-200 bg-slate-50/80 px-3.5 py-2.5">
          <p class="text-xs font-semibold text-slate-500"><%= t("settings.llm.cost_estimate") %></p>
          <p class="text-xl font-black text-slate-950"><%= number_to_currency(@llm_stats[:estimated_cost_usd], unit: "$") %></p>
        </div>
        <p class="text-sm leading-6 text-slate-600"><%= t("settings.llm.cost_description", priced: @llm_stats[:priced_responses], total: @llm_stats[:response_count]) %></p>
      </div>
    </section>
  </aside>
</section>

<section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5">
  <div class="mb-4 border-b border-slate-200 pb-3">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("settings.llm_prompt_preview.label") %></p>
    <h3 class="mt-0.5 text-lg font-bold text-slate-950"><%= t("settings.llm.prompt_workspace_title") %></h3>
  </div>

  <div class="space-y-3">
    <div class="flex items-center justify-between rounded-xl border border-slate-200 px-3.5 py-2.5">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500"><%= t("settings.llm_prompt.label") %></p>
        <span class="text-sm font-bold text-slate-950"><%= t("settings.llm_prompt.title") %></span>
      </div>
      <%= link_to t("settings.llm.view_full_prompt"), settings_prompt_preview_path(kind: "parser", person_id: @preview_person&.id || 0), target: "_blank", class: "inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100" %>
    </div>

    <div class="rounded-xl border border-slate-200 px-3.5 py-2.5">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500"><%= t("settings.llm.preview_person_label") %></p>
          <span class="text-sm font-bold text-slate-950"><%= t("settings.llm_prompt_preview.sections.summary") %></span>
        </div>

        <div class="flex items-center gap-2">
          <%= form_with url: settings_path, method: :get, class: "flex items-center gap-2" do |form| %>
            <%= form.hidden_field :section, value: :llm %>
            <%= form.select :preview_person_id, @preview_people.map { |person| [person.name, person.id] }, { selected: @preview_person&.id, prompt: t("settings.llm.preview_person_placeholder") }, class: "rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs text-slate-900 outline-none transition focus:border-amber-500 focus:ring-2 focus:ring-amber-200", data: { action: "change->this.form.requestSubmit()" }, onchange: "this.form.requestSubmit()" %>
          <% end %>
          <% if @preview_person.present? %>
            <%= link_to t("settings.llm.view_full_prompt"), settings_prompt_preview_path(kind: "summary", person_id: @preview_person.id), target: "_blank", class: "inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100" %>
          <% end %>
        </div>
      </div>

      <p class="mt-3 text-sm text-slate-600">
        <% if @preview_person.present? %>
          <%= t("settings.llm.preview_context_selected", name: @preview_person.name) %>
        <% else %>
          <%= t("settings.llm.prompt_preview_empty") %>
        <% end %>
      </p>
    </div>
  </div>
</section>

<section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5">
  <div class="mb-4 flex flex-wrap items-start justify-between gap-3 border-b border-slate-200 pb-3">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("settings.llm.reparse.label") %></p>
      <h3 class="mt-0.5 text-lg font-bold text-slate-950"><%= t("settings.llm.reparse.title") %></h3>
      <p class="mt-1 text-sm text-slate-600"><%= t("settings.llm.reparse.description") %></p>
    </div>

    <div class="text-right">
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500"><%= t("settings.llm.reparse.unparsed_count") %></p>
      <p class="text-3xl font-black text-slate-950"><%= @unparsed_entry_count %></p>
    </div>
  </div>

  <div class="flex flex-wrap items-center justify-between gap-3">
    <details class="group min-w-[18rem] flex-1 rounded-2xl border border-slate-200 bg-slate-50/80 px-4 py-3">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-3 [&::-webkit-details-marker]:hidden">
        <div>
          <p class="text-sm font-semibold text-slate-900"><%= t("settings.llm.reparse.unparsed_entries") %></p>
          <p class="text-xs text-slate-500"><%= t("settings.llm.reparse.expand_hint") %></p>
        </div>
        <svg class="h-4 w-4 text-slate-400 transition group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
        </svg>
      </summary>

      <div class="mt-3 space-y-2">
        <% if @unparsed_entries.any? %>
          <% @unparsed_entries.each do |entry| %>
            <% status_label = case entry.parse_status
            when "pending" then t("entries.tags.pending")
            when "failed" then t("entries.tags.parse_error")
            when "skipped" then t("entries.tags.skipped")
            else entry.parse_status
            end %>
            <div class="rounded-xl border border-slate-200 bg-white px-3 py-2">
              <div class="flex flex-wrap items-center justify-between gap-2">
                <p class="text-sm font-semibold text-slate-900"><%= entry.person.name %></p>
                <span class="rounded-full bg-amber-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.14em] text-amber-800"><%= status_label %></span>
              </div>
              <p class="mt-1 text-xs text-slate-500"><%= l(entry.display_time, format: :long) %> · <%= entry.source %></p>
              <p class="mt-1 text-sm text-slate-700"><%= entry.document_title.presence || entry.input.presence || entry.fact_summary.presence || t("entries.documents.document_only") %></p>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm text-slate-500"><%= t("settings.llm.reparse.none") %></p>
        <% end %>
      </div>
    </details>

    <%= button_to settings_llm_reparse_all_path, method: :post,
        class: "inline-flex items-center rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800",
        data: { turbo_confirm: t("settings.llm.reparse.confirm") } do %>
      <%= t("settings.llm.reparse.trigger") %>
    <% end %>
  </div>
</section>

<% if @section.in?(["llm_prompt", "llm_prompt_preview"]) %>
  <% @prompt_previews.each do |key, messages| %>
    <section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5">
      <div class="mb-4 border-b border-slate-200 pb-3">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("settings.llm_prompt_preview.label") %></p>
        <h3 class="mt-0.5 text-lg font-bold text-slate-950"><%= t("settings.llm_prompt_preview.sections.#{key}") %></h3>
      </div>

      <div class="space-y-4">
        <div>
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("settings.llm_prompt_preview.system_label") %></p>
          <pre class="overflow-x-auto rounded-[1.5rem] border border-slate-200 bg-slate-950 p-4 text-xs leading-6 text-slate-100 whitespace-pre-wrap"><%= messages[:system] %></pre>
        </div>

        <div>
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("settings.llm_prompt_preview.user_label") %></p>
          <pre class="overflow-x-auto rounded-[1.5rem] border border-slate-200 bg-amber-50 p-4 text-xs leading-6 text-slate-800 whitespace-pre-wrap"><%= messages[:user] %></pre>
        </div>
      </div>
    </section>
  <% end %>
<% end %>
