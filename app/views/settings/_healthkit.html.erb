<section class="space-y-6">
  <section class="rounded-[2rem] border border-emerald-200 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700"><%= t("settings.healthkit.label") %></p>
    <h2 class="mt-2 text-2xl font-bold text-slate-950"><%= t("settings.healthkit.title") %></h2>
    <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600"><%= t("settings.healthkit.subtitle") %></p>
  </section>

  <section class="grid gap-6 xl:grid-cols-2">
    <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-black/5">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("settings.healthkit.syncs_label") %></p>
      <h3 class="mt-1 text-xl font-bold text-slate-950"><%= t("settings.healthkit.last_sync_title") %></h3>

      <div class="mt-4 space-y-3">
        <% if healthkit_syncs.any? %>
          <% healthkit_syncs.each do |sync| %>
            <div class="rounded-2xl border border-slate-200 bg-slate-50/70 p-4 text-sm text-slate-700">
              <div class="flex items-center justify-between gap-3">
                <p class="font-semibold text-slate-950"><%= sync.person.name %></p>
                <span class="rounded-full bg-slate-950 px-3 py-1 text-xs font-semibold uppercase tracking-[0.15em] text-white"><%= sync.status %></span>
              </div>
              <dl class="mt-3 grid gap-2 text-xs text-slate-500">
                <div><span class="font-semibold text-slate-700"><%= t("settings.healthkit.device_id") %>:</span> <%= sync.device_id %></div>
                <div><span class="font-semibold text-slate-700"><%= t("settings.healthkit.last_sync_at") %>:</span> <%= sync.last_synced_at || "-" %></div>
                <div><span class="font-semibold text-slate-700"><%= t("settings.healthkit.last_successful_sync_at") %>:</span> <%= sync.last_successful_sync_at || "-" %></div>
                <div><span class="font-semibold text-slate-700"><%= t("settings.healthkit.synced_record_count") %>:</span> <%= sync.synced_record_count %></div>
                <div><span class="font-semibold text-slate-700"><%= t("settings.healthkit.last_error") %>:</span> <%= sync.last_error.presence || "-" %></div>
              </dl>

              <%= button_to t("settings.healthkit.reset_button"), ios_healthkit_reset_path(person_uuid: sync.person.uuid), method: :delete, class: "mt-4 inline-flex rounded-xl bg-rose-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-rose-500", form: { data: { turbo_confirm: t("settings.healthkit.reset_confirm") } } %>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm text-slate-500"><%= t("settings.healthkit.empty_syncs") %></p>
        <% end %>
      </div>
    </div>

    <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-black/5">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("settings.healthkit.records_label") %></p>
      <h3 class="mt-1 text-xl font-bold text-slate-950"><%= t("settings.healthkit.records_title") %></h3>

      <div class="mt-4 space-y-3 max-h-[40rem] overflow-y-auto pr-2">
        <% if healthkit_records.any? %>
          <% healthkit_records.each do |record| %>
            <div class="rounded-2xl border border-slate-200 bg-slate-50/70 p-4 text-sm text-slate-700">
              <div class="flex items-center justify-between gap-3">
                <p class="font-semibold text-slate-950"><%= record.record_type %></p>
                <span class="text-xs text-slate-500"><%= record.person.name %></span>
              </div>
              <p class="mt-2 text-xs text-slate-500"><%= record.source_name.presence || "-" %> · <%= record.start_at %></p>
              <pre class="mt-3 overflow-x-auto rounded-xl bg-slate-950 p-3 text-[11px] leading-5 text-slate-100 whitespace-pre-wrap"><%= JSON.pretty_generate(record.payload) %></pre>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm text-slate-500"><%= t("settings.healthkit.empty_records") %></p>
        <% end %>
      </div>
    </div>
  </section>
</section>
