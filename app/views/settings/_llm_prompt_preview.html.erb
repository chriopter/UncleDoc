<section class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
  <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("settings.llm_prompt_preview.label") %></p>
  <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950"><%= t("settings.llm_prompt_preview.title") %></h2>
  <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600"><%= t("settings.llm_prompt_preview.description") %></p>
</section>

<% @prompt_previews.each do |key, messages| %>
  <section class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm ring-1 ring-black/5">
    <h3 class="mb-4 text-lg font-bold text-slate-950"><%= t("settings.llm_prompt_preview.sections.#{key}") %></h3>

    <div class="space-y-4">
      <div>
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("settings.llm_prompt_preview.system_label") %></p>
        <pre class="overflow-x-auto rounded-[1.5rem] border border-slate-200 bg-slate-950 p-4 text-xs leading-6 text-slate-100 whitespace-pre-wrap"><%= messages[:system] %></pre>
      </div>

      <div>
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("settings.llm_prompt_preview.user_label") %></p>
        <pre class="overflow-x-auto rounded-[1.5rem] border border-slate-200 bg-amber-50 p-4 text-xs leading-6 text-slate-800 whitespace-pre-wrap"><%= messages[:user] %></pre>
      </div>
    </div>
  </section>
<% end %>
