<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "UncleDoc" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="UncleDoc">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <style>
      :root {
        --uncledoc-safe-top: env(safe-area-inset-top, 0px);
      }
    </style>
    <%= javascript_importmap_tags %>
  </head>

  <% nav_items = shell_nav_items(current_person, request.path) %>
  <% on_settings = request.path.start_with?("/settings") %>
  <% on_db = request.path.include?("/settings/db") %>

  <body class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(251,191,36,0.20),_transparent_22%),radial-gradient(circle_at_bottom_right,_rgba(244,114,182,0.12),_transparent_24%),linear-gradient(180deg,_#fffaf1_0%,_#f4efe4_100%)] text-slate-900 antialiased">
    <%# Skip to content link for accessibility %>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[9999] focus:rounded-xl focus:bg-amber-500 focus:px-4 focus:py-3 focus:text-white focus:text-sm focus:font-semibold focus:shadow-lg">
      <%= t("accessibility.skip_to_content") %>
    </a>

    <main id="main-content" class="mx-auto min-h-screen w-full max-w-[96rem] px-4 pt-[max(1rem,calc(var(--uncledoc-safe-top)+0.75rem))] pb-4 md:px-6 md:pt-6 md:pb-6">
      <div class="flex min-h-[calc(100vh-2rem)] flex-col gap-6 xl:flex-row">

        <%# ── Mobile / tablet top bar (below xl) ── %>
        <header class="sticky z-40 rounded-[2rem] border border-amber-100/80 bg-white/95 p-4 shadow-sm ring-1 ring-amber-100/80 backdrop-blur xl:hidden" style="top: calc(var(--uncledoc-safe-top) + 0.5rem);">
          <div class="flex items-center justify-between gap-3">
            <div class="relative min-w-0 flex-1" <%= family_members.size > 1 ? 'data-controller="dropdown"'.html_safe : '' %>>
              <% if family_members.size > 1 %>
                <button type="button" data-action="dropdown#toggle" class="flex min-w-0 items-center gap-3 rounded-xl px-1 py-1 text-left transition hover:bg-amber-50" aria-label="<%= t("family.default_name") %>">
                  <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-amber-100 text-base font-black text-amber-800 shadow-inner">
                    <%= current_person&.name&.first&.upcase || "U" %>
                  </div>
                  <span class="truncate text-lg font-black tracking-tight text-slate-950"><%= current_person&.name || t("family.default_name") %></span>
                  <svg class="h-4 w-4 flex-shrink-0 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                  </svg>
                </button>

                <div data-dropdown-target="menu" class="absolute left-0 top-full z-[9999] mt-3 hidden min-w-full rounded-[1.75rem] border border-amber-200 bg-white p-3 shadow-xl ring-1 ring-black/5">
                  <div class="space-y-0.5">
                    <% family_members.each do |person| %>
                      <%= link_to person_overview_path(person_slug: person.name), class: "flex items-center justify-between rounded-xl px-3 py-2.5 text-sm font-medium #{current_person == person ? 'bg-amber-100 text-amber-900' : 'text-slate-700 hover:bg-amber-50'}" do %>
                        <span class="truncate"><%= person.name %></span>
                        <% if current_person == person %>
                          <span class="ml-2 text-xs text-amber-600">●</span>
                        <% end %>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              <% else %>
                <div class="flex min-w-0 items-center gap-3 px-1 py-1">
                  <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-amber-100 text-base font-black text-amber-800 shadow-inner">
                    <%= current_person&.name&.first&.upcase || "U" %>
                  </div>
                  <span class="truncate text-lg font-black tracking-tight text-slate-950"><%= current_person&.name || t("family.default_name") %></span>
                </div>
              <% end %>
            </div>

            <div class="relative" data-controller="dropdown">
              <button type="button" data-action="dropdown#toggle" class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-600 shadow-sm transition hover:border-amber-200 hover:text-slate-950" aria-label="Menu">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
              </button>

              <div data-dropdown-target="menu" class="absolute right-0 top-full z-[9999] mt-3 w-[min(24rem,calc(100vw-2rem))] hidden rounded-[1.75rem] border border-amber-200 bg-white p-3 shadow-xl ring-1 ring-black/5">
            <%# Navigation %>
            <div class="space-y-1">
              <% shell_mobile_nav_groups(current_person, request.path).each do |group| %>
                <div class="rounded-2xl <%= group[:children].any? ? 'bg-amber-50/70 px-2 py-2' : '' %>">
                  <%= link_to group[:path], class: "flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-semibold #{group[:active] ? 'bg-slate-950 text-white' : 'text-slate-700 hover:bg-amber-50'}" do %>
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <path stroke-linecap="round" stroke-linejoin="round" d="<%= shell_nav_icon(group[:label]) %>" />
                    </svg>
                    <span><%= group[:label] %></span>
                  <% end %>

                  <% if group[:children].any? %>
                    <div class="mt-1 border-l border-amber-200/80 pl-7">
                      <% group[:children].each do |item| %>
                        <%= link_to item[:path], class: "block rounded-lg px-3 py-1.5 text-sm font-medium #{item[:active] ? 'bg-white text-amber-800 shadow-sm' : 'text-slate-500 hover:bg-white/80 hover:text-slate-900'}" do %>
                          <%= item[:label] %>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>

            <%# Server-side settings %>
            <div class="mt-2 border-t border-slate-100 pt-3 space-y-0.5">
              <% if on_settings %>
                <% shell_settings_items(request.path).each do |item| %>
                  <% if item[:child] %>
                    <%= link_to item[:path], class: "ml-7 block rounded-lg px-3 py-1.5 text-sm font-medium #{item[:active] ? 'text-amber-800 bg-amber-50' : 'text-slate-500 hover:text-slate-900 hover:bg-amber-50'}" do %>
                      <%= item[:label] %>
                    <% end %>
                  <% else %>
                    <%= link_to item[:path], class: "flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-semibold #{item[:active] ? 'bg-slate-950 text-white' : 'text-slate-700 hover:bg-amber-50'}" do %>
                      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="<%= shell_nav_icon(item[:label]) %>" />
                      </svg>
                      <span><%= item[:label] %></span>
                    <% end %>
                  <% end %>
                <% end %>
              <% else %>
                <%= link_to settings_path_for, class: "flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-semibold text-slate-700 hover:bg-amber-50" do %>
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="<%= shell_nav_icon(t('nav.settings')) %>" />
                  </svg>
                  <span><%= t("nav.settings") %></span>
                <% end %>
              <% end %>
            </div>

            <% if native_app_request? %>
              <%# Native app actions %>
              <div class="mt-2 border-t border-slate-100 pt-3">
                <div class="rounded-2xl bg-slate-50/80 px-2 py-2">
                  <div class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm font-semibold text-slate-800">
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <path stroke-linecap="round" stroke-linejoin="round" d="<%= shell_nav_icon(t('nav.app_settings')) %>" />
                    </svg>
                    <span><%= t("nav.app_settings") %></span>
                  </div>

                  <div class="mt-1 border-l border-slate-200/80 pl-7 space-y-0.5">
                    <div data-native-menu-slot="mobile" class="hidden"></div>
                  </div>
                </div>
              </div>
            <% end %>
              </div>
            </div>
          </div>
        </header>

        <%# ── Desktop sidebar (xl+) ── %>
        <aside class="hidden xl:sticky xl:top-6 xl:block xl:h-[calc(100vh-3rem)] xl:w-[18rem] xl:flex-shrink-0">
          <div class="flex h-full flex-col rounded-[2rem] border border-amber-100/80 bg-[linear-gradient(180deg,_rgba(255,255,255,0.96)_0%,_rgba(255,248,235,0.92)_100%)] p-5 shadow-[0_24px_70px_-32px_rgba(120,53,15,0.28)] ring-1 ring-amber-100/80">

            <%# ── Main panel ── %>
            <div class="flex flex-1 flex-col <%= 'hidden' if on_settings %>">
              <%# Person picker %>
              <div class="relative mb-6" data-controller="dropdown">
                <button type="button" data-action="dropdown#toggle" class="group mx-auto flex items-center gap-3 text-left">
                  <h1 class="max-w-[13rem] break-words text-xl font-black tracking-tight text-slate-950 transition-colors group-hover:text-amber-700"><%= current_person&.name || t("family.default_name") %></h1>
                  <svg class="h-5 w-5 text-slate-400 group-hover:text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                  </svg>
                </button>

                <div data-dropdown-target="menu" class="absolute left-1/2 top-full z-[9999] mt-3 hidden w-48 -translate-x-1/2 rounded-2xl border border-amber-200 bg-white p-2 shadow-xl ring-1 ring-black/5">
                  <% if family_members.any? %>
                    <div class="space-y-0.5">
                      <% family_members.each do |person| %>
                        <%= link_to person_overview_path(person_slug: person.name), class: "flex items-center justify-between rounded-xl px-3 py-2.5 text-sm font-medium #{current_person == person ? 'bg-amber-100 text-amber-900' : 'text-slate-700 hover:bg-amber-50'}" do %>
                          <span class="truncate"><%= person.name %></span>
                          <% if current_person == person %>
                            <span class="ml-2 text-xs text-amber-600">●</span>
                          <% end %>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>

              <%# Nav links %>
              <nav class="flex-1 space-y-0.5 overflow-y-auto">
                <% nav_items.each do |item| %>
                  <% if item[:child] %>
                    <%= link_to item[:path], class: "ml-11 block rounded-lg px-3 py-1.5 text-sm font-medium transition #{item[:active] ? 'text-amber-800 bg-amber-50' : 'text-slate-500 hover:text-slate-900 hover:bg-white'}" do %>
                      <%= item[:label] %>
                    <% end %>
                  <% else %>
                    <%= link_to item[:path], class: shell_menu_item_class(item[:active]) do %>
                      <span class="flex items-center gap-3">
                        <span class="flex h-8 w-8 items-center justify-center rounded-xl <%= item[:active] ? 'bg-white/[.12]' : 'bg-amber-50 text-amber-700' %>">
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="<%= shell_nav_icon(item[:label]) %>" />
                          </svg>
                        </span>
                        <span><%= item[:label] %></span>
                      </span>
                    <% end %>
                  <% end %>
                <% end %>
              </nav>

              <%# Settings link — navigates to settings %>
              <div class="mt-auto border-t border-amber-100/80 pt-3">
                <%= link_to settings_path_for, class: shell_menu_item_class(false) do %>
                  <span class="flex items-center gap-3">
                    <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-amber-50 text-amber-700">
                      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="<%= shell_nav_icon(t('nav.settings')) %>" />
                      </svg>
                    </span>
                    <span><%= t("nav.settings") %></span>
                  </span>
                <% end %>

                <div data-native-menu-slot="desktop" class="hidden mt-3 border-t border-amber-100/80 pt-3"></div>
              </div>
            </div>

            <%# ── Settings panel ── %>
            <div class="flex flex-1 flex-col <%= 'hidden' unless on_settings && !on_db %>">
              <div class="mb-6">
                <%= link_to (current_person ? person_overview_path(person_slug: current_person.name) : root_path), class: "group flex items-center gap-2 text-sm font-semibold text-slate-600 transition hover:text-slate-950" do %>
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                  </svg>
                  <span><%= t("nav.back") %></span>
                <% end %>
                <h2 class="mt-3 text-xl font-black tracking-tight text-slate-950"><%= t("nav.settings") %></h2>
              </div>

              <nav class="flex-1 space-y-0.5 overflow-y-auto">
                <% shell_settings_items(request.path).each do |item| %>
                  <% if item[:child] %>
                    <%= link_to item[:path], class: "ml-11 block rounded-lg px-3 py-1.5 text-sm font-medium transition #{item[:active] ? 'text-amber-800 bg-amber-50' : 'text-slate-500 hover:text-slate-900 hover:bg-white'}" do %>
                      <%= item[:label] %>
                    <% end %>
                  <% else %>
                    <%= link_to item[:path], class: shell_menu_item_class(item[:active]) do %>
                      <span class="flex items-center gap-3">
                        <span class="flex h-8 w-8 items-center justify-center rounded-xl <%= item[:active] ? 'bg-white/[.12]' : 'bg-amber-50 text-amber-700' %>">
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="<%= shell_nav_icon(item[:label]) %>" />
                          </svg>
                        </span>
                        <span><%= item[:label] %></span>
                      </span>
                    <% end %>
                  <% end %>
                <% end %>
              </nav>
            </div>

            <%# ── DB browser panel ── %>
            <div class="flex flex-1 flex-col <%= 'hidden' unless on_db %>">
              <div class="mb-6">
                <%= link_to settings_path_for(:profile), class: "group flex items-center gap-2 text-sm font-semibold text-slate-600 transition hover:text-slate-950" do %>
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                  </svg>
                  <span><%= t("nav.settings") %></span>
                <% end %>
                <h2 class="mt-3 text-xl font-black tracking-tight text-slate-950"><%= t("settings.db.title") %></h2>
              </div>

              <nav class="flex-1 space-y-4 overflow-y-auto">
                <% shell_db_tables.each do |group| %>
                  <div>
                    <p class="mb-1 px-3 text-[10px] font-semibold uppercase tracking-[0.2em] text-slate-400"><%= group[:label] %></p>
                    <div class="space-y-0.5">
                      <% group[:tables].each do |table| %>
                        <% active = params[:table] == table[:name] %>
                        <%= link_to settings_path(section: "db_table", table: table[:name]), class: "flex items-center justify-between rounded-lg px-3 py-1.5 text-sm font-medium transition #{active ? 'text-amber-800 bg-amber-50' : 'text-slate-600 hover:text-slate-900 hover:bg-white'}" do %>
                          <span><%= table[:name] %></span>
                          <span class="text-[10px] tabular-nums text-slate-400"><%= table[:count] %></span>
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </nav>
            </div>
          </div>
        </aside>

        <div class="min-w-0 flex-1">
          <% if notice.present? || alert.present? %>
            <div class="mb-4 flex flex-col gap-2">
              <% if notice.present? %>
                <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800"><%= notice %></div>
              <% end %>
              <% if alert.present? %>
                <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-800"><%= alert %></div>
              <% end %>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </div>
    </main>
  </body>
</html>
