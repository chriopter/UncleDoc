<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "UncleDoc" %></title>
    <meta name="viewport" content="<%= viewport_meta_content %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="UncleDoc">
    <meta name="mobile-web-app-capable" content="yes">
    <% if current_native_app_token.present? %>
      <meta name="uncledoc-native-app-token" content="<%= current_native_app_token %>">
      <meta name="uncledoc-native-app-email" content="<%= current_user.email_address %>">
    <% end %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192">
    <link rel="icon" href="/icon-512.png" type="image/png" sizes="512x512">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <style>
      :root {
        --uncledoc-safe-top: env(safe-area-inset-top, 0px);
      }
    </style>
    <%= javascript_importmap_tags %>
  </head>

  <% nav_items = shell_nav_items(current_person, request.path) %>
  <% on_settings = controller_name == "settings" %>
  <% current_settings_section = params[:section].presence || "users" %>
  <% on_db = on_settings && current_settings_section.in?(["db", "db_table"]) %>
  <% on_cockpit = current_person.present? && !on_settings && ((controller_name == "people" && action_name == "show") || (controller_name == "dashboard" && action_name == "show")) %>

  <body class="<%= on_cockpit ? 'h-[100dvh] overflow-hidden overscroll-none' : 'min-h-screen' %> bg-[radial-gradient(circle_at_top_left,_rgba(251,191,36,0.20),_transparent_22%),radial-gradient(circle_at_bottom_right,_rgba(244,114,182,0.12),_transparent_24%),linear-gradient(180deg,_#fffaf1_0%,_#f4efe4_100%)] text-slate-900 antialiased <%= 'overflow-x-hidden' if native_app_request? %>">
    <%# Skip to content link for accessibility %>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[9999] focus:rounded-xl focus:bg-amber-500 focus:px-4 focus:py-3 focus:text-white focus:text-sm focus:font-semibold focus:shadow-lg">
      <%= t("accessibility.skip_to_content") %>
    </a>

    <main id="main-content" class="mx-auto <%= on_cockpit ? 'h-[100dvh] overflow-hidden' : 'min-h-screen' %> w-full <%= on_db ? 'max-w-none px-4 md:px-6 xl:px-8' : 'max-w-[96rem] px-4 md:px-6' %> pt-[max(1rem,calc(var(--uncledoc-safe-top)+0.75rem))] pb-4 md:pt-6 md:pb-6">
      <div class="flex <%= on_cockpit ? 'h-full min-h-0' : 'min-h-[calc(100vh-2rem)]' %> flex-col gap-6 xl:flex-row">

        <%# ── Mobile / tablet top bar (below xl) ── %>
        <header class="sticky z-40 pb-3 xl:hidden" style="top: calc(var(--uncledoc-safe-top) + 0.5rem);">
          <div class="relative flex items-start justify-between gap-3">
            <div class="flex min-w-0 items-center gap-3">
              <div class="relative" data-controller="dropdown">
                <button type="button" data-action="dropdown#toggle" class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full border border-white/80 bg-white/90 text-slate-700 shadow-[0_14px_40px_-24px_rgba(15,23,42,0.42)] ring-1 ring-black/5 backdrop-blur transition hover:bg-white hover:text-slate-950" aria-label="<%= t("nav.menu") %>">
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                  </svg>
                </button>

                <div data-dropdown-target="menu" class="absolute left-0 top-full z-[9999] mt-3 hidden max-h-[calc(100dvh-var(--uncledoc-safe-top)-5.5rem)] w-[min(25rem,calc(100vw-1.5rem))] overflow-x-hidden overflow-y-auto overscroll-contain rounded-[2rem] border border-white/80 bg-[linear-gradient(180deg,_rgba(255,255,255,0.98)_0%,_rgba(255,248,235,0.94)_100%)] p-3 shadow-[0_28px_80px_-34px_rgba(15,23,42,0.42)] ring-1 ring-black/5 backdrop-blur">
                  <div class="space-y-1">
                    <% shell_mobile_nav_groups(current_person, request.path).each do |group| %>
                      <div class="rounded-[1.5rem] <%= group[:children].any? ? 'bg-amber-50/70 px-2 py-2' : '' %>">
                        <%= link_to group[:path], class: "flex items-center gap-3 rounded-[1.15rem] px-3 py-3 text-sm font-semibold #{group[:active] ? 'bg-amber-100 text-amber-900 shadow-sm ring-1 ring-amber-200/80' : 'text-slate-700 hover:bg-white/80'}" do %>
                          <span class="flex h-9 w-9 items-center justify-center rounded-2xl <%= group[:active] ? 'bg-white text-amber-700 shadow-sm ring-1 ring-amber-200/80' : 'bg-white text-amber-700 shadow-sm ring-1 ring-black/5' %>">
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                              <path stroke-linecap="round" stroke-linejoin="round" d="<%= shell_nav_icon(group[:label]) %>" />
                            </svg>
                          </span>
                          <span><%= group[:label] %></span>
                        <% end %>

                        <% if group[:children].any? %>
                          <div class="mt-1 border-l border-amber-200/80 pl-7">
                            <% group[:children].each do |item| %>
                              <%= link_to item[:path], class: "block rounded-xl px-3 py-2 text-sm font-medium #{item[:active] ? 'bg-white text-amber-800 shadow-sm ring-1 ring-black/5' : 'text-slate-500 hover:bg-white/80 hover:text-slate-900'}" do %>
                                <%= item[:label] %>
                              <% end %>
                            <% end %>
                            <% if native_app_request? && group[:label] == t("nav.data") %>
                              <div data-native-menu-slot="data-mobile" class="hidden mt-1 space-y-0.5"></div>
                            <% end %>
                          </div>
                        <% elsif native_app_request? && group[:label] == t("nav.data") %>
                          <div class="mt-1 border-l border-amber-200/80 pl-7">
                            <div data-native-menu-slot="data-mobile" class="hidden space-y-0.5"></div>
                          </div>
                        <% end %>
                      </div>
                    <% end %>
                  </div>

                  <div class="mt-2 border-t border-amber-100/80 pt-3 space-y-0.5">
                    <% if on_settings %>
                      <p class="px-3 pb-1 pt-0.5 text-[11px] font-black uppercase tracking-[0.18em] text-amber-700"><%= t("nav.settings") %></p>
                      <% shell_settings_items(request.path).each do |item| %>
                        <% if item[:child] %>
                          <%= link_to item[:path], class: "ml-7 block rounded-xl px-3 py-2 text-sm font-medium #{item[:active] ? 'bg-amber-50 text-amber-800' : 'text-slate-500 hover:bg-white/80 hover:text-slate-900'}" do %>
                            <%= item[:label] %>
                          <% end %>
                        <% else %>
                          <%= link_to item[:path], class: "flex items-center gap-3 rounded-[1.15rem] px-3 py-3 text-sm font-semibold #{item[:active] ? 'bg-amber-100 text-amber-900 shadow-sm ring-1 ring-amber-200/80' : 'text-slate-700 hover:bg-white/80'}" do %>
                            <span class="flex h-9 w-9 items-center justify-center rounded-2xl <%= item[:active] ? 'bg-white text-amber-700 shadow-sm ring-1 ring-amber-200/80' : 'bg-white text-amber-700 shadow-sm ring-1 ring-black/5' %>">
                              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path stroke-linecap="round" stroke-linejoin="round" d="<%= shell_nav_icon(item[:label]) %>" />
                              </svg>
                            </span>
                            <span><%= item[:label] %></span>
                          <% end %>
                        <% end %>
                      <% end %>
                    <% elsif current_user&.can_administer? %>
                      <%= link_to settings_path_for, class: "flex items-center gap-3 rounded-[1.15rem] px-3 py-3 text-sm font-semibold text-slate-700 hover:bg-white/80", aria: { label: t("nav.settings") } do %>
                        <span class="flex h-9 w-9 items-center justify-center rounded-2xl bg-white text-amber-700 shadow-sm ring-1 ring-black/5">
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="<%= shell_nav_icon(t('nav.settings')) %>" />
                          </svg>
                        </span>
                        <span><%= t("nav.settings") %></span>
                      <% end %>
                    <% end %>

                    <% if current_user.present? %>
                      <div class="mt-2 border-t border-amber-100/80 pt-3">
                        <div class="flex items-center gap-2.5 px-3 py-2">
                          <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-amber-100 text-xs font-black text-amber-800"><%= current_user.person&.name&.first&.upcase || "?" %></span>
                          <div class="min-w-0">
                            <p class="truncate text-sm font-semibold text-slate-900"><%= current_user.person&.name || current_user.email_address %></p>
                            <p class="truncate text-[11px] text-slate-400"><%= current_user.email_address %></p>
                          </div>
                        </div>
                        <%= button_to session_path, method: :delete, class: "flex w-full items-center gap-3 rounded-[1.15rem] px-3 py-3 text-sm font-semibold text-slate-700 hover:bg-white/80" do %>
                          <span class="flex h-9 w-9 items-center justify-center rounded-2xl bg-white text-amber-700 shadow-sm ring-1 ring-black/5">
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m-3-3h9m0 0-3-3m3 3-3 3" /></svg>
                          </span>
                          <span><%= t("auth.logout.button") %></span>
                        <% end %>
                      </div>
                    <% end %>

                  </div>

                  <% if native_app_request? %>
                    <div class="mt-2 border-t border-amber-100/80 pt-3">
                      <div data-native-menu-slot="mobile" class="hidden space-y-0.5"></div>
                    </div>
                  <% end %>
                </div>
              </div>

              <div class="relative min-w-0 flex-1" <%= family_members.size > 1 ? 'data-controller="dropdown"'.html_safe : '' %>>
                <% if family_members.size > 1 %>
                  <button type="button" data-action="dropdown#toggle" class="flex min-w-0 max-w-full items-center gap-3 rounded-full border border-white/80 bg-white/90 px-2.5 py-2 pr-4 text-left shadow-[0_14px_40px_-24px_rgba(15,23,42,0.42)] ring-1 ring-black/5 backdrop-blur transition hover:bg-white" aria-label="<%= t("family.default_name") %>">
                    <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-amber-100 text-sm font-black text-amber-800 ring-1 ring-amber-200/80">
                      <%= current_person&.name&.first&.upcase || "U" %>
                    </div>
                    <span class="truncate text-[1.05rem] font-semibold tracking-tight text-slate-950"><%= current_person&.name || t("family.default_name") %></span>
                    <svg class="h-4 w-4 flex-shrink-0 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                    </svg>
                  </button>

                  <div data-dropdown-target="menu" class="absolute left-0 top-full z-[9999] mt-3 hidden min-w-full overflow-hidden rounded-[1.75rem] border border-white/80 bg-white/95 p-2.5 shadow-[0_28px_80px_-34px_rgba(15,23,42,0.42)] ring-1 ring-black/5 backdrop-blur">
                    <div class="space-y-1">
                      <% family_members.each do |person| %>
                        <%= link_to person_root_path(person_slug: person.name), class: "flex items-center justify-between rounded-[1.15rem] px-3 py-3 text-sm font-medium #{current_person == person ? 'bg-amber-100 text-amber-900 shadow-sm ring-1 ring-amber-200/80' : 'text-slate-700 hover:bg-amber-50/70'}" do %>
                          <span class="truncate"><%= person.name %></span>
                          <% if current_person == person %>
                            <span class="ml-2 text-xs text-amber-600">●</span>
                          <% end %>
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                <% else %>
                  <div class="flex min-w-0 max-w-full items-center gap-3 rounded-full border border-white/80 bg-white/90 px-2.5 py-2 pr-4 shadow-[0_14px_40px_-24px_rgba(15,23,42,0.42)] ring-1 ring-black/5 backdrop-blur">
                    <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-amber-100 text-sm font-black text-amber-800 ring-1 ring-amber-200/80">
                      <%= current_person&.name&.first&.upcase || "U" %>
                    </div>
                    <span class="truncate text-[1.05rem] font-semibold tracking-tight text-slate-950"><%= current_person&.name || t("family.default_name") %></span>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </header>

        <%# ── Desktop sidebar (xl+) ── %>
        <aside class="hidden xl:sticky xl:top-6 xl:block xl:h-[calc(100vh-3rem)] xl:w-[18rem] xl:flex-shrink-0">
          <div class="flex h-full flex-col rounded-[2rem] border border-amber-100/80 bg-[linear-gradient(180deg,_rgba(255,255,255,0.96)_0%,_rgba(255,248,235,0.92)_100%)] p-5 shadow-[0_24px_70px_-32px_rgba(120,53,15,0.28)] ring-1 ring-amber-100/80">

            <%# ── Main panel ── %>
            <div class="flex flex-1 flex-col <%= 'hidden' if on_settings %>">
              <%# Person picker %>
              <div class="relative mb-6" data-controller="dropdown">
                <button type="button" data-action="dropdown#toggle" class="group mx-auto flex items-center gap-3 text-left">
                  <h1 class="max-w-[13rem] break-words text-xl font-black tracking-tight text-slate-950 transition-colors group-hover:text-amber-700"><%= current_person&.name || t("family.default_name") %></h1>
                  <svg class="h-5 w-5 text-slate-400 group-hover:text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                  </svg>
                </button>

                <div data-dropdown-target="menu" class="absolute left-1/2 top-full z-[9999] mt-3 hidden w-48 -translate-x-1/2 rounded-2xl border border-amber-200 bg-white p-2 shadow-xl ring-1 ring-black/5">
                  <% if family_members.any? %>
                    <div class="space-y-0.5">
                      <% family_members.each do |person| %>
                        <%= link_to person_root_path(person_slug: person.name), class: "flex items-center justify-between rounded-xl px-3 py-2.5 text-sm font-medium #{current_person == person ? 'bg-amber-100 text-amber-900' : 'text-slate-700 hover:bg-amber-50'}" do %>
                          <span class="truncate"><%= person.name %></span>
                          <% if current_person == person %>
                            <span class="ml-2 text-xs text-amber-600">●</span>
                          <% end %>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>

              <%# Nav links %>
              <nav class="flex-1 space-y-0.5 overflow-y-auto">
                <% nav_items.each do |item| %>
                  <% if item[:child] %>
                    <%= link_to item[:path], class: "ml-11 block rounded-lg px-3 py-1.5 text-sm font-medium transition #{item[:active] ? 'text-amber-800 bg-amber-50' : 'text-slate-500 hover:text-slate-900 hover:bg-white'}" do %>
                      <%= item[:label] %>
                    <% end %>
                  <% else %>
                    <%= link_to item[:path], class: shell_menu_item_class(item[:active]) do %>
                      <span class="flex items-center gap-3">
                        <span class="flex h-8 w-8 items-center justify-center rounded-xl <%= item[:active] ? 'bg-white text-amber-700 shadow-sm ring-1 ring-amber-200/80' : 'bg-amber-50 text-amber-700' %>">
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="<%= shell_nav_icon(item[:label]) %>" />
                          </svg>
                        </span>
                        <span><%= item[:label] %></span>
                      </span>
                    <% end %>

                    <% if native_app_request? && item[:label] == t("nav.data") %>
                      <div class="ml-11 mt-1">
                        <div data-native-menu-slot="data-desktop" class="hidden space-y-0.5"></div>
                      </div>
                    <% end %>
                  <% end %>
                <% end %>
              </nav>

              <%# Settings & user menu %>
              <div class="mt-auto border-t border-amber-100/80 pt-3">
                <% if current_user&.can_administer? %>
                  <%= link_to settings_path_for, class: shell_menu_item_class(false) do %>
                    <span class="flex items-center gap-3">
                      <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-amber-50 text-amber-700">
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="<%= shell_nav_icon(t('nav.settings')) %>" /></svg>
                      </span>
                      <span><%= t("nav.settings") %></span>
                    </span>
                  <% end %>
                <% end %>

                <% if current_user.present? %>
                  <details class="group mt-2">
                    <summary class="flex cursor-pointer items-center gap-3 rounded-[1.15rem] px-3 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-white/80 [&::-webkit-details-marker]:hidden">
                      <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-amber-100 text-xs font-black text-amber-800"><%= current_user.person&.name&.first&.upcase || "?" %></span>
                      <span class="min-w-0 truncate"><%= current_user.person&.name || current_user.email_address %></span>
                      <svg class="ml-auto h-4 w-4 shrink-0 text-slate-400 transition group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" /></svg>
                    </summary>
                    <div class="mt-1 rounded-2xl border border-amber-100/80 bg-white/90 p-2 shadow-sm">
                      <p class="truncate px-3 py-1.5 text-[11px] text-slate-400"><%= current_user.email_address %></p>
                      <%= button_to session_path, method: :delete, class: "flex w-full items-center gap-2.5 rounded-xl px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-amber-50" do %>
                        <svg class="h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m-3-3h9m0 0-3-3m3 3-3 3" /></svg>
                        <span><%= t("auth.logout.button") %></span>
                      <% end %>
                    </div>
                  </details>
                <% end %>

                <div data-native-menu-slot="desktop" class="hidden mt-3 border-t border-amber-100/80 pt-3"></div>
              </div>
            </div>

            <%# ── Settings panel ── %>
            <div class="flex flex-1 flex-col <%= 'hidden' unless on_settings && !on_db %>">
              <div class="mb-6">
                <%= link_to (current_person ? person_root_path(person_slug: current_person.name) : root_path), class: "group flex items-center gap-2 text-sm font-semibold text-slate-600 transition hover:text-slate-950" do %>
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                  </svg>
                  <span><%= t("nav.back") %></span>
                <% end %>
                <h2 class="mt-3 text-xl font-black tracking-tight text-slate-950"><%= t("nav.settings") %></h2>
              </div>

              <nav class="flex-1 space-y-0.5 overflow-y-auto">
                <% shell_settings_items(request.path).each do |item| %>
                  <% if item[:child] %>
                    <%= link_to item[:path], class: "ml-11 block rounded-lg px-3 py-1.5 text-sm font-medium transition #{item[:active] ? 'text-amber-800 bg-amber-50' : 'text-slate-500 hover:text-slate-900 hover:bg-white'}" do %>
                      <%= item[:label] %>
                    <% end %>
                  <% else %>
                    <%= link_to item[:path], class: shell_menu_item_class(item[:active]) do %>
                      <span class="flex items-center gap-3">
                        <span class="flex h-8 w-8 items-center justify-center rounded-xl <%= item[:active] ? 'bg-white text-amber-700 shadow-sm ring-1 ring-amber-200/80' : 'bg-amber-50 text-amber-700' %>">
                          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="<%= shell_nav_icon(item[:label]) %>" />
                          </svg>
                        </span>
                        <span><%= item[:label] %></span>
                      </span>
                    <% end %>
                  <% end %>
                <% end %>
              </nav>
            </div>

            <%# ── DB browser panel ── %>
            <div class="flex flex-1 flex-col <%= 'hidden' unless on_db %>">
              <div class="mb-6">
                  <%= link_to settings_path_for(:users), class: "group flex items-center gap-2 text-sm font-semibold text-slate-600 transition hover:text-slate-950" do %>
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                  </svg>
                  <span><%= t("nav.settings") %></span>
                <% end %>
                <h2 class="mt-3 text-xl font-black tracking-tight text-slate-950"><%= t("settings.db.title") %></h2>
              </div>

              <nav class="flex-1 space-y-4 overflow-y-auto">
                <% shell_db_tables.each do |group| %>
                  <div>
                    <p class="mb-1 px-3 text-[10px] font-semibold uppercase tracking-[0.2em] text-slate-400"><%= group[:label] %></p>
                    <div class="space-y-0.5">
                      <% group[:tables].each do |table| %>
                        <% active = params[:table] == table[:name] %>
                        <%= link_to settings_path(section: "db_table", table: table[:name]), class: "flex items-center justify-between rounded-lg px-3 py-1.5 text-sm font-medium transition #{active ? 'text-amber-800 bg-amber-50' : 'text-slate-600 hover:text-slate-900 hover:bg-white'}" do %>
                          <span><%= table[:name] %></span>
                          <span class="text-[10px] tabular-nums text-slate-400"><%= table[:count] %></span>
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </nav>
            </div>
          </div>
        </aside>

        <div class="min-w-0 flex-1 <%= on_cockpit ? 'min-h-0' : '' %> <%= on_db ? 'overflow-x-auto pb-2' : '' %>">
          <% if notice.present? || alert.present? %>
            <div class="mb-4 flex flex-col gap-2">
              <% if notice.present? %>
                <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800"><%= notice %></div>
              <% end %>
              <% if alert.present? %>
                <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-800"><%= alert %></div>
              <% end %>
            </div>
          <% end %>

          <div class="<%= on_db ? 'min-w-max' : '' %> <%= on_cockpit ? 'h-full min-h-0' : '' %>">
            <%= yield %>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
