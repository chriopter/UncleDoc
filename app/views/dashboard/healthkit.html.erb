<%= turbo_stream_from [@person, :entries] %>

<section class="space-y-5">
  <section class="rounded-[2rem] border border-white/70 bg-white/90 p-5 ring-1 ring-black/5 backdrop-blur">
    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-700"><%= t("dashboard.healthkit.label") %></p>
      <h1 class="text-2xl font-black tracking-tight text-slate-950"><%= t("dashboard.healthkit.title", name: @person.name) %></h1>
    </div>

    <div class="mt-4 flex flex-wrap items-center gap-2">
      <%= link_to person_log_path(person_slug: @person.name, source: "healthkit"), class: "inline-flex items-center gap-1.5 rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800" do %>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
        <%= t("dashboard.healthkit.view_all_entries") %>
      <% end %>
    </div>
  </section>

  <div class="grid grid-cols-1 gap-5 xl:grid-cols-3">
    <% latest_status = @healthkit_latest_sync&.effective_status || 'not_synced' %>
    <section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5 xl:col-span-1">
      <p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400"><%= t("dashboard.healthkit.stats_label") %></p>
      <div class="space-y-2.5 text-sm text-slate-600">
        <div class="flex items-center gap-2">
          <span class="inline-flex rounded-full border px-2.5 py-0.5 text-xs font-semibold <%= healthkit_sync_badge_class(latest_status) %>"><%= t("dashboard.healthkit.sync_states.#{latest_status}") %></span>
        </div>
        <div class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 shrink-0 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
          <span><%= @healthkit_latest_sync&.last_synced_at ? l(@healthkit_latest_sync.last_synced_at, format: :long) : t("dashboard.healthkit.empty_value") %></span>
        </div>
        <div class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 shrink-0 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 0 0-1.883 2.542l.857 6a2.25 2.25 0 0 0 2.227 1.932H19.05a2.25 2.25 0 0 0 2.227-1.932l.857-6a2.25 2.25 0 0 0-1.883-2.542m-16.5 0V6A2.25 2.25 0 0 1 6 3.75h3.879a1.5 1.5 0 0 1 1.06.44l2.122 2.12a1.5 1.5 0 0 0 1.06.44H18A2.25 2.25 0 0 1 20.25 9v.776" /></svg>
          <span><%= number_with_delimiter(@healthkit_record_count) %> <%= t("dashboard.healthkit.stats.raw_records").downcase %></span>
        </div>
        <div class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 shrink-0 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z" /></svg>
          <span><%= number_with_delimiter(@healthkit_summary_count) %> (<%= @healthkit_daily_summary_count %> <%= t("dashboard.healthkit.stats.daily_short") %> · <%= @healthkit_monthly_summary_count %> <%= t("dashboard.healthkit.stats.monthly_short") %>)</span>
        </div>
        <div class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 shrink-0 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3" /></svg>
          <span><%= t("dashboard.healthkit.stats.devices_value", count: @healthkit_syncs.size) %></span>
        </div>
      </div>
    </section>

    <% if @healthkit_syncs.any? %>
      <section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5 xl:col-span-1">
        <p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400"><%= t("dashboard.healthkit.syncs_label") %></p>
        <div class="space-y-3">
          <% @healthkit_syncs.each do |sync| %>
            <div class="rounded-xl border border-slate-200 bg-slate-50/80 p-4">
              <div class="flex items-center justify-between gap-3">
                <p class="min-w-0 truncate text-sm font-bold text-slate-950"><%= sync.device_id %></p>
                <% sync_status = sync.effective_status %>
                <span class="inline-flex shrink-0 rounded-full border px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-[0.15em] <%= healthkit_sync_badge_class(sync_status) %>"><%= t("dashboard.healthkit.sync_states.#{sync_status}") %></span>
              </div>
              <dl class="mt-3 space-y-1 text-xs text-slate-500">
                <div><span class="font-semibold text-slate-700"><%= t("dashboard.healthkit.sync_meta.last_sync") %>:</span> <%= sync.last_synced_at ? l(sync.last_synced_at, format: :long) : t("dashboard.healthkit.empty_value") %></div>
                <div><span class="font-semibold text-slate-700"><%= t("dashboard.healthkit.sync_meta.synced_records") %>:</span> <%= number_with_delimiter(sync.synced_record_count) %></div>
                <% if sync.last_error.present? %>
                  <div><span class="font-semibold text-rose-700"><%= t("dashboard.healthkit.sync_meta.last_error") %>:</span> <%= sync.last_error %></div>
                <% end %>
              </dl>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>

    <section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5 xl:col-span-1">
      <p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400"><%= t("dashboard.healthkit.admin_label") %></p>
      <div class="space-y-2">
        <%= button_to person_healthkit_sync_summaries_path(person_slug: @person.name), method: :post, class: "inline-flex items-center gap-1.5 rounded-full border border-orange-200 bg-orange-50 px-3.5 py-2 text-xs font-semibold text-orange-700 transition hover:bg-orange-100", form: { class: "inline-block", data: { turbo_confirm: t("dashboard.healthkit.rebuild_confirm") } } do %>
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182" /></svg>
          <%= t("dashboard.healthkit.rebuild_button") %>
        <% end %>
        <%= button_to person_healthkit_reparse_path(person_slug: @person.name), method: :post, class: "inline-flex items-center gap-1.5 rounded-full border border-orange-200 bg-orange-50 px-3.5 py-2 text-xs font-semibold text-orange-700 transition hover:bg-orange-100", form: { class: "inline-block", data: { turbo_confirm: t("dashboard.healthkit.reparse_confirm") } } do %>
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.678 48.678 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 0 0 3.7 3.7 48.656 48.656 0 0 0 7.324 0 4.006 4.006 0 0 0 3.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3-3 3" /></svg>
          <%= t("dashboard.healthkit.reparse_button") %>
        <% end %>
        <% if @healthkit_syncs.any? || @healthkit_record_count.positive? || @healthkit_summary_count.positive? %>
          <%= button_to ios_healthkit_reset_path(person_uuid: @person.uuid), method: :delete, class: "inline-flex items-center gap-1.5 rounded-full border border-rose-200 bg-rose-50 px-3.5 py-2 text-xs font-semibold text-rose-700 transition hover:bg-rose-100", form: { class: "inline-block", data: { turbo_confirm: t("dashboard.healthkit.reset_confirm") } } do %>
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" /></svg>
            <%= t("dashboard.healthkit.reset_button") %>
          <% end %>
        <% end %>
      </div>
    </section>
  </div>

  <%= turbo_frame_tag "healthkit_records_table_frame", src: person_healthkit_records_path(person_slug: @person.name, page: 1) do %>
    <section class="rounded-[2rem] border border-slate-200 bg-white p-8 text-center text-sm text-slate-500 shadow-sm ring-1 ring-black/5">
      <%= t("db.table.loading_more") %>
    </section>
  <% end %>
</section>
