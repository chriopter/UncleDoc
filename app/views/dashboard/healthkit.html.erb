<%= turbo_stream_from [@person, :entries] %>

<section class="space-y-6">
  <section class="rounded-[2rem] border border-cyan-200/80 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
    <div class="space-y-6">
      <div class="flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
        <div class="space-y-4">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-700"><%= t("dashboard.healthkit.label") %></p>
            <h1 class="mt-1 text-3xl font-black tracking-tight text-slate-950"><%= t("dashboard.healthkit.title", name: @person.name) %></h1>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600"><%= t("dashboard.healthkit.subtitle") %></p>
          </div>

          <div class="inline-flex rounded-full border border-slate-200 bg-slate-50 p-1 text-sm font-semibold text-slate-600">
            <%= link_to t("dashboard.healthkit.views.summaries"), healthkit_pagination_path(@person, view: "summaries", page: 1), class: healthkit_view_tab_class(@healthkit_view == "summaries") %>
            <%= link_to t("dashboard.healthkit.views.raw"), healthkit_pagination_path(@person, view: "raw", page: 1), class: healthkit_view_tab_class(@healthkit_view == "raw") %>
          </div>
        </div>

        <div class="grid w-full gap-3 sm:grid-cols-2 xl:w-[32rem]">
          <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50/70 p-4">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("dashboard.healthkit.stats.sync_state") %></p>
            <div class="mt-2 flex items-center gap-3">
              <span class="inline-flex rounded-full border px-3 py-1 text-xs font-semibold <%= healthkit_sync_badge_class(@healthkit_latest_sync&.status || 'not_synced') %>"><%= t("dashboard.healthkit.sync_states.#{@healthkit_latest_sync&.status || 'not_synced'}") %></span>
              <span class="text-sm text-slate-600"><%= t("dashboard.healthkit.stats.devices_value", count: @healthkit_syncs.size) %></span>
            </div>
          </div>

          <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50/70 p-4">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("dashboard.healthkit.stats.last_sync") %></p>
            <p class="mt-2 text-sm font-semibold text-slate-950"><%= @healthkit_latest_sync&.last_synced_at ? l(@healthkit_latest_sync.last_synced_at, format: :long) : t("dashboard.healthkit.empty_value") %></p>
            <p class="mt-1 text-xs text-slate-500"><%= t("dashboard.healthkit.stats.last_success") %>: <%= @healthkit_last_successful_sync_at ? l(@healthkit_last_successful_sync_at, format: :long) : t("dashboard.healthkit.empty_value") %></p>
          </div>

          <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50/70 p-4">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("dashboard.healthkit.stats.raw_records") %></p>
            <p class="mt-2 text-2xl font-black tracking-tight text-slate-950"><%= number_with_delimiter(@healthkit_record_count) %></p>
            <p class="mt-1 text-xs text-slate-500"><%= t("dashboard.healthkit.stats.record_types_value", count: @healthkit_record_type_count) %></p>
          </div>

          <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50/70 p-4">
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("dashboard.healthkit.stats.summaries") %></p>
            <p class="mt-2 text-2xl font-black tracking-tight text-slate-950"><%= number_with_delimiter(@healthkit_summary_count) %></p>
            <p class="mt-1 text-xs text-slate-500"><%= t("dashboard.healthkit.stats.summary_split", daily: @healthkit_daily_summary_count, monthly: @healthkit_monthly_summary_count) %></p>
          </div>
        </div>
      </div>

      <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50/80 p-4">
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("dashboard.healthkit.syncs_label") %></p>
            <h2 class="mt-1 text-lg font-bold text-slate-950"><%= t("dashboard.healthkit.syncs_title") %></h2>
          </div>
          <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-semibold text-slate-600"><%= t("dashboard.healthkit.stats.devices_value", count: @healthkit_syncs.size) %></span>
        </div>

        <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
          <% if @healthkit_syncs.any? %>
            <% @healthkit_syncs.each do |sync| %>
              <div class="rounded-[1.35rem] border border-slate-200 bg-white p-4 shadow-sm">
                <div class="flex items-center justify-between gap-3">
                  <p class="font-semibold text-slate-950"><%= sync.device_id %></p>
                  <span class="inline-flex rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.15em] <%= healthkit_sync_badge_class(sync.status) %>"><%= t("dashboard.healthkit.sync_states.#{sync.status}") %></span>
                </div>
                <dl class="mt-3 space-y-2 text-xs text-slate-500">
                  <div><span class="font-semibold text-slate-700"><%= t("dashboard.healthkit.sync_meta.last_sync") %>:</span> <%= sync.last_synced_at ? l(sync.last_synced_at, format: :long) : t("dashboard.healthkit.empty_value") %></div>
                  <div><span class="font-semibold text-slate-700"><%= t("dashboard.healthkit.sync_meta.last_success") %>:</span> <%= sync.last_successful_sync_at ? l(sync.last_successful_sync_at, format: :long) : t("dashboard.healthkit.empty_value") %></div>
                  <div><span class="font-semibold text-slate-700"><%= t("dashboard.healthkit.sync_meta.synced_records") %>:</span> <%= number_with_delimiter(sync.synced_record_count) %></div>
                  <div><span class="font-semibold text-slate-700"><%= t("dashboard.healthkit.sync_meta.last_error") %>:</span> <%= sync.last_error.presence || t("dashboard.healthkit.empty_value") %></div>
                </dl>
              </div>
            <% end %>
          <% else %>
            <p class="text-sm text-slate-500"><%= t("dashboard.healthkit.empty_syncs") %></p>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <section class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-sm ring-1 ring-black/5">
    <div class="mb-5 flex flex-col gap-4 border-b border-white/10 pb-5 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-300"><%= @healthkit_view == "summaries" ? t("dashboard.healthkit.views.summaries") : t("dashboard.healthkit.views.raw") %></p>
        <h2 class="mt-1 text-3xl font-black tracking-tight"><%= @healthkit_view == "summaries" ? t("dashboard.healthkit.summary_title") : t("dashboard.healthkit.raw_title") %></h2>
      </div>
      <div class="flex items-center gap-3">
        <span class="inline-flex rounded-full border border-white/15 px-3 py-1 text-xs font-semibold text-slate-300"><%= @healthkit_view == "summaries" ? t("dashboard.healthkit.summary_count", count: @healthkit_summary_count) : t("dashboard.healthkit.raw_count", count: @healthkit_record_count) %></span>
        <span class="inline-flex rounded-full border border-white/15 px-3 py-1 text-xs font-semibold text-slate-300"><%= t("dashboard.healthkit.pagination.page", current: @healthkit_page, total: @healthkit_total_pages) %></span>
      </div>
    </div>

    <% if @healthkit_view == "summaries" %>
      <div class="space-y-3">
        <% if @healthkit_summary_entries.any? %>
          <% @healthkit_summary_entries.each do |entry| %>
            <% lines = healthkit_summary_lines(entry) %>
            <% header = lines.first %>
            <% body_lines = lines.drop(1) %>
            <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.04] p-4 backdrop-blur">
              <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="inline-flex rounded-full border border-cyan-400/20 bg-cyan-400/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-cyan-100"><%= entry.source_ref&.start_with?("healthkit:month:") ? t("dashboard.healthkit.preview_kind.month") : t("dashboard.healthkit.preview_kind.day") %></span>
                    <span class="inline-flex rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[11px] font-semibold text-slate-300"><%= entry.source_ref %></span>
                    <span class="inline-flex rounded-full border px-3 py-1 text-[11px] font-semibold <%= healthkit_parse_badge_class(entry) %>"><%= t("entries.parse_status.#{entry.parse_status == 'pending' ? 'pending_short' : entry.parse_status == 'failed' ? 'failed_short' : entry.parse_status == 'skipped' ? 'skipped_short' : 'parsed'}") %></span>
                  </div>

                  <h3 class="mt-3 text-lg font-bold text-white"><%= header %></h3>
                  <% if body_lines.any? %>
                    <ul class="mt-3 space-y-1.5 text-sm leading-6 text-slate-100">
                      <% body_lines.each do |line| %>
                        <li class="break-words"><%= line %></li>
                      <% end %>
                    </ul>
                  <% end %>
                </div>

                <div class="shrink-0 rounded-2xl border border-white/10 bg-slate-900/70 p-3 text-xs text-slate-300 lg:w-56">
                  <p><span class="font-semibold text-white"><%= t("dashboard.healthkit.preview_meta.range") %>:</span> <%= l(entry.occurred_at.to_date, format: :long_date) %></p>
                  <p class="mt-2"><span class="font-semibold text-white"><%= t("dashboard.healthkit.preview_meta.types") %>:</span> <%= Array(entry.parseable_data).map { |item| item["type"] }.compact.join(", ").presence || t("dashboard.healthkit.empty_value") %></p>
                  <p class="mt-2"><span class="font-semibold text-white"><%= t("dashboard.healthkit.preview_meta.records") %>:</span> <%= t("dashboard.healthkit.summary_entry_source") %></p>
                </div>
              </div>
            </article>
          <% end %>
        <% else %>
          <p class="rounded-[1.5rem] border border-white/10 bg-white/[0.04] p-5 text-sm text-slate-300"><%= t("dashboard.healthkit.empty_summaries") %></p>
        <% end %>
      </div>
    <% else %>
      <div class="space-y-3">
        <% if @healthkit_records.any? %>
          <% @healthkit_records.each do |record| %>
            <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.04] p-4 backdrop-blur">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <p class="font-semibold text-white break-all"><%= record.record_type %></p>
                <span class="text-xs text-slate-400"><%= l(record.start_at, format: :long) %></span>
              </div>
              <p class="mt-2 text-xs text-slate-400"><%= [record.source_name.presence || t("dashboard.healthkit.empty_value"), record.device_id].join(" · ") %></p>
              <pre class="mt-3 overflow-x-auto rounded-xl bg-slate-900 p-3 text-[11px] leading-5 text-slate-100 whitespace-pre-wrap"><%= JSON.pretty_generate(record.payload) %></pre>
            </article>
          <% end %>
        <% else %>
          <p class="rounded-[1.5rem] border border-white/10 bg-white/[0.04] p-5 text-sm text-slate-300"><%= t("dashboard.healthkit.empty_raw") %></p>
        <% end %>
      </div>
    <% end %>

    <div class="mt-6 flex items-center justify-between border-t border-white/10 pt-5 text-sm">
      <% prev_page = @healthkit_page - 1 %>
      <% next_page = @healthkit_page + 1 %>
      <% if @healthkit_page > 1 %>
        <%= link_to t("dashboard.healthkit.pagination.previous"), healthkit_pagination_path(@person, view: @healthkit_view, page: prev_page), class: "rounded-full border border-white/15 px-4 py-2 font-semibold text-slate-200 transition hover:bg-white/10 hover:text-white" %>
      <% else %>
        <span class="rounded-full border border-white/10 px-4 py-2 font-semibold text-slate-500"><%= t("dashboard.healthkit.pagination.previous") %></span>
      <% end %>

      <span class="text-slate-400"><%= t("dashboard.healthkit.pagination.page", current: @healthkit_page, total: @healthkit_total_pages) %></span>

      <% if @healthkit_page < @healthkit_total_pages %>
        <%= link_to t("dashboard.healthkit.pagination.next"), healthkit_pagination_path(@person, view: @healthkit_view, page: next_page), class: "rounded-full border border-white/15 px-4 py-2 font-semibold text-slate-200 transition hover:bg-white/10 hover:text-white" %>
      <% else %>
        <span class="rounded-full border border-white/10 px-4 py-2 font-semibold text-slate-500"><%= t("dashboard.healthkit.pagination.next") %></span>
      <% end %>
    </div>
  </section>
</section>
