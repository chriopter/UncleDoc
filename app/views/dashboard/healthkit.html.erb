<%= turbo_stream_from [@person, :entries] %>

<section class="space-y-5">
  <section class="rounded-[2rem] border border-white/70 bg-white/90 p-5 ring-1 ring-black/5 backdrop-blur">
    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-700"><%= t("dashboard.healthkit.label") %></p>
      <h1 class="text-2xl font-black tracking-tight text-slate-950"><%= t("dashboard.healthkit.title", name: @person.name) %></h1>
    </div>
  </section>

  <section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5">
    <div class="mb-4 border-b border-slate-200 pb-3">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("dashboard.healthkit.stats_label") %></p>
      <h2 class="mt-0.5 text-lg font-bold text-slate-950"><%= t("dashboard.healthkit.stats_title") %></h2>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
      <div class="rounded-xl border border-slate-200 bg-slate-50/80 p-4">
        <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("dashboard.healthkit.stats.sync_state") %></p>
        <div class="mt-2">
          <% latest_status = @healthkit_latest_sync&.effective_status || 'not_synced' %>
          <span class="inline-flex rounded-full border px-2.5 py-0.5 text-xs font-semibold <%= healthkit_sync_badge_class(latest_status) %>"><%= t("dashboard.healthkit.sync_states.#{latest_status}") %></span>
        </div>
        <p class="mt-2 text-xs text-slate-500"><%= t("dashboard.healthkit.stats.devices_value", count: @healthkit_syncs.size) %></p>
      </div>

      <div class="rounded-xl border border-slate-200 bg-slate-50/80 p-4">
        <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("dashboard.healthkit.stats.last_sync") %></p>
        <p class="mt-2 text-base font-bold text-slate-950"><%= @healthkit_latest_sync&.last_synced_at ? l(@healthkit_latest_sync.last_synced_at, format: :long) : t("dashboard.healthkit.empty_value") %></p>
        <p class="mt-1 text-xs text-slate-500"><%= t("dashboard.healthkit.stats.last_success") %>: <%= @healthkit_last_successful_sync_at ? l(@healthkit_last_successful_sync_at, format: :long) : t("dashboard.healthkit.empty_value") %></p>
      </div>

      <div class="rounded-xl border border-slate-200 bg-slate-50/80 p-4">
        <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("dashboard.healthkit.stats.raw_records") %></p>
        <p class="mt-2 text-2xl font-black tracking-tight text-slate-950"><%= number_with_delimiter(@healthkit_record_count) %></p>
        <p class="mt-1 text-xs text-slate-500"><%= t("dashboard.healthkit.stats.record_types_value", count: @healthkit_record_type_count) %></p>
      </div>

      <div class="rounded-xl border border-slate-200 bg-slate-50/80 p-4">
        <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("dashboard.healthkit.stats.summaries") %></p>
        <p class="mt-2 text-2xl font-black tracking-tight text-slate-950"><%= number_with_delimiter(@healthkit_summary_count) %></p>
        <p class="mt-1 text-xs text-slate-500"><%= t("dashboard.healthkit.stats.summary_split", daily: @healthkit_daily_summary_count, monthly: @healthkit_monthly_summary_count) %></p>
      </div>
    </div>
  </section>

  <section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5">
    <div class="mb-4 flex items-start justify-between gap-3 border-b border-slate-200 pb-3">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("dashboard.healthkit.syncs_label") %></p>
        <h2 class="mt-0.5 text-lg font-bold text-slate-950"><%= t("dashboard.healthkit.syncs_title") %></h2>
      </div>
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2.5 py-0.5 text-xs font-semibold text-slate-700"><%= t("dashboard.healthkit.stats.devices_value", count: @healthkit_syncs.size) %></span>
        <% if @healthkit_syncs.any? || @healthkit_record_count.positive? || @healthkit_summary_count.positive? %>
          <%= button_to t("dashboard.healthkit.reset_button"), ios_healthkit_reset_path(person_uuid: @person.uuid), method: :delete, class: "inline-flex rounded-full border border-rose-200 bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-700 transition hover:bg-rose-100", form: { class: "inline-block", data: { turbo_confirm: t("dashboard.healthkit.reset_confirm") } } %>
        <% end %>
      </div>
    </div>

    <% if @healthkit_syncs.any? %>
      <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-3">
        <% @healthkit_syncs.each do |sync| %>
          <div class="rounded-xl border border-slate-200 bg-slate-50/80 p-4">
            <div class="flex items-center justify-between gap-3">
              <p class="text-sm font-bold text-slate-950"><%= sync.device_id %></p>
              <% sync_status = sync.effective_status %>
              <span class="inline-flex rounded-full border px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-[0.15em] <%= healthkit_sync_badge_class(sync_status) %>"><%= t("dashboard.healthkit.sync_states.#{sync_status}") %></span>
            </div>
            <dl class="mt-3 space-y-1.5 text-xs text-slate-500">
              <div><span class="font-semibold text-slate-700"><%= t("dashboard.healthkit.sync_meta.last_sync") %>:</span> <%= sync.last_synced_at ? l(sync.last_synced_at, format: :long) : t("dashboard.healthkit.empty_value") %></div>
              <div><span class="font-semibold text-slate-700"><%= t("dashboard.healthkit.sync_meta.last_success") %>:</span> <%= sync.last_successful_sync_at ? l(sync.last_successful_sync_at, format: :long) : t("dashboard.healthkit.empty_value") %></div>
              <div><span class="font-semibold text-slate-700"><%= t("dashboard.healthkit.sync_meta.synced_records") %>:</span> <%= number_with_delimiter(sync.synced_record_count) %></div>
              <% if sync.last_error.present? %>
                <div><span class="font-semibold text-rose-700"><%= t("dashboard.healthkit.sync_meta.last_error") %>:</span> <%= sync.last_error %></div>
              <% end %>
            </dl>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="rounded-xl border border-dashed border-slate-300 bg-slate-50/70 p-6 text-center text-sm text-slate-500"><%= t("dashboard.healthkit.empty_syncs") %></p>
    <% end %>
  </section>

  <section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5">
    <div class="mb-4 border-b border-slate-200 pb-3">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("dashboard.healthkit.entries_label") %></p>
      <h2 class="mt-0.5 text-lg font-bold text-slate-950"><%= t("dashboard.healthkit.entries_title") %></h2>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <%= link_to person_log_path(person_slug: @person.name, source: "healthkit"), class: "inline-flex rounded-full bg-slate-950 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800" do %>
        <%= t("dashboard.healthkit.view_all_entries") %>
      <% end %>
      <%= link_to person_log_path(person_slug: @person.name, source: "healthkit_day"), class: "inline-flex rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-white hover:text-slate-950" do %>
        <%= t("dashboard.healthkit.view_daily") %>
      <% end %>
      <%= link_to person_log_path(person_slug: @person.name, source: "healthkit_month"), class: "inline-flex rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-white hover:text-slate-950" do %>
        <%= t("dashboard.healthkit.view_monthly") %>
      <% end %>
    </div>
  </section>
</section>
