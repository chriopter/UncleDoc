<div id="research_chat_form" class="border-t border-slate-200 px-4 py-3 sm:px-5">
  <% if error_message.present? %>
    <p class="mb-3 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700"><%= error_message %></p>
  <% end %>

  <%= form_with model: message, url: person_chat_path(person_slug: person.name), method: :post, class: "flex items-end gap-3", data: { controller: "chat-input", action: "submit->chat-input#clearOnSubmit turbo:submit-start->chat-input#startSubmitting turbo:submit-end->chat-input#finishSubmitting" } do |form| %>
    <%= form.text_area :content,
      rows: 1,
      placeholder: t("chat.placeholder"),
      class: "max-h-40 min-h-10 flex-1 resize-y rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 placeholder-slate-400 outline-none transition focus:border-amber-500 focus:ring-2 focus:ring-amber-200",
      data: { chat_input_target: "field", action: "keydown->chat-input#submitOnEnter" } %>
    <%= form.button type: :submit, class: "flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-slate-950 text-white transition hover:bg-slate-800 disabled:opacity-40", data: { chat_input_target: "submit" }, aria: { label: t("chat.send") } do %>
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" data-chat-input-target="icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
      </svg>
      <svg class="hidden h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none" data-chat-input-target="spinner">
        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-opacity="0.25" stroke-width="3" />
        <path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
      </svg>
    <% end %>
  <% end %>
</div>
