<%= turbo_frame_tag "files_stats" do %>
  <div class="grid gap-3 sm:grid-cols-2">
    <div class="rounded-[1.5rem] border border-amber-200 bg-amber-50/70 p-4">
      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700"><%= t("files.stats.documents") %></p>
      <p class="mt-2 text-3xl font-black text-slate-950"><%= document_count %></p>
    </div>

    <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-4">
      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("files.stats.entries") %></p>
      <p class="mt-2 text-3xl font-black text-slate-950"><%= document_entries.size %></p>
    </div>
  </div>
<% end %>
