<%= turbo_frame_tag "files_stats", class: local_assigns.fetch(:classes, "pointer-events-none absolute left-0 top-full z-20 mt-2 hidden w-max items-center gap-2 rounded-full border border-slate-200 bg-white/95 px-3 py-1.5 shadow-sm group-hover:flex") do %>
  <span class="text-xs font-semibold text-slate-400"><%= t("files.stats.documents_count", count: document_count) %></span>
  <span class="text-xs font-semibold text-slate-400"><%= t("files.stats.entries_count", count: document_entries.size) %></span>
<% end %>
