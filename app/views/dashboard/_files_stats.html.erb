<%= turbo_frame_tag "files_stats" do %>
  <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2.5 py-0.5 text-xs font-semibold text-slate-700"><%= t("files.stats.documents_count", count: document_count) %></span>
  <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2.5 py-0.5 text-xs font-semibold text-slate-700"><%= t("files.stats.entries_count", count: document_entries.size) %></span>
<% end %>
