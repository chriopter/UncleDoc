<section id="patient_record_panel" class="overflow-hidden rounded-[2rem] border border-amber-200 bg-white/95 shadow-sm ring-1 ring-black/5">
  <div class="border-b border-amber-100/80 px-5 py-5">
    <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
      <div class="min-w-0">
        <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("dashboard.record.label") %></p>
        <h1 class="mt-1 truncate text-xl font-black tracking-tight text-slate-950"><%= t("dashboard.record.title", name: person.name) %></h1>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-500"><%= t("dashboard.record.description") %></p>
      </div>
      <span class="inline-flex shrink-0 rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-800">
        <%= t("dashboard.record.entry_count", count: person.entries.count) %>
      </span>
    </div>
  </div>

  <div class="bg-white px-5 py-5">
    <pre class="max-h-[70vh] overflow-auto whitespace-pre-wrap rounded-2xl border border-slate-200 bg-slate-950 px-4 py-4 text-xs leading-6 text-slate-100 shadow-inner"><code><%= prompt %></code></pre>
  </div>
</section>
