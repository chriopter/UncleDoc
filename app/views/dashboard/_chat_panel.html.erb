<% system_prompt ||= nil %>

<section class="flex h-[calc(100vh-6rem)] min-h-[32rem] w-full flex-col rounded-[2rem] border border-slate-200 bg-white ring-1 ring-black/5" data-controller="chat" data-chat-url="<%= person_chat_path(person_slug: person.name) %>">
  <div class="flex items-center justify-between gap-3 border-b border-slate-200 px-5 py-3.5">
    <div class="flex items-center gap-3">
      <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-amber-100 text-sm font-black text-amber-800 ring-1 ring-amber-200/80">
        <%= person.name.first.upcase %>
      </div>
      <div>
        <h2 class="text-base font-bold text-slate-950"><%= t("chat.title", name: person.name) %></h2>
        <p class="text-xs text-slate-500"><%= t("chat.subtitle", count: person.entries.count) %></p>
      </div>
    </div>
  </div>

  <div class="flex-1 space-y-3 overflow-y-auto bg-slate-50/50 px-4 py-5 sm:px-5" data-chat-target="messages">
    <% if system_prompt.present? %>
      <div class="flex justify-start">
        <details class="group max-w-[85%]">
          <summary class="flex cursor-pointer list-none items-center gap-2 rounded-2xl rounded-tl-md border border-slate-200 bg-white px-4 py-2.5 text-xs font-semibold text-slate-500 shadow-sm transition hover:bg-slate-50">
            <svg class="h-3.5 w-3.5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456Z" />
            </svg>
            <span><%= t("chat.system_prompt_label") %></span>
            <span class="text-slate-400 transition group-open:rotate-180">▾</span>
          </summary>
          <pre class="mt-1 max-h-80 overflow-auto rounded-2xl rounded-tl-md border border-slate-200 bg-slate-950 px-4 py-3 text-xs leading-5 text-slate-300 whitespace-pre-wrap"><%= system_prompt %></pre>
        </details>
      </div>
    <% end %>

    <div class="flex justify-start">
      <div class="max-w-[85%] rounded-2xl rounded-tl-md border border-slate-200 bg-white px-4 py-3 text-sm leading-relaxed text-slate-700 shadow-sm">
        <div data-role="content" class="whitespace-pre-wrap"><%= t("chat.welcome", name: person.name) %></div>
      </div>
    </div>
  </div>

  <div class="border-t border-slate-200 px-4 py-3 sm:px-5">
    <form data-chat-target="form" data-action="submit->chat#send" class="flex items-end gap-3">
      <textarea
        data-chat-target="input"
        data-action="input->chat#autoResize keydown->chat#handleKeydown"
        rows="1"
        placeholder="<%= t("chat.placeholder") %>"
        class="flex-1 resize-none rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 placeholder-slate-400 outline-none transition focus:border-amber-500 focus:ring-2 focus:ring-amber-200"
      ></textarea>
      <button
        type="submit"
        data-chat-target="submit"
        class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-slate-950 text-white transition hover:bg-slate-800 disabled:opacity-40"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
        </svg>
      </button>
    </form>
  </div>
</section>
