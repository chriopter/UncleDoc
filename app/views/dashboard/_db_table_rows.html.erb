<% table[:rows].each do |row| %>
  <tr>
    <% table[:columns].each do |column| %>
      <% value = row[column].presence || "-" %>
      <% value_text = value.to_s %>
      <% expandable = value_text.length > 120 || value_text.include?("\n") %>
      <td class="<%= db_column_width_class(column) %> px-4 py-3 align-top text-xs leading-5 text-slate-700 whitespace-normal break-words [overflow-wrap:anywhere] <%= db_cell_text_class(column) %>">
        <% if expandable %>
          <details class="group">
            <summary class="list-none cursor-pointer">
              <div class="space-y-2">
                <div class="line-clamp-3 whitespace-pre-wrap break-words [overflow-wrap:anywhere]"><%= value_text %></div>
                <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-slate-500 transition group-open:hidden"><%= t("db.table.expand") %></span>
                <span class="hidden items-center rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-slate-500 group-open:inline-flex"><%= t("db.table.collapse") %></span>
              </div>
            </summary>
            <div class="mt-2 rounded-xl border border-slate-200 bg-slate-50/80 p-3 whitespace-pre-wrap break-words [overflow-wrap:anywhere]"><%= value_text %></div>
          </details>
        <% else %>
          <div class="whitespace-pre-wrap break-words [overflow-wrap:anywhere]"><%= value_text %></div>
        <% end %>
      </td>
    <% end %>
    <% if table[:deletable] %>
      <td class="min-w-[8rem] px-4 py-3 align-top text-xs">
        <% row_id = row[table[:primary_key]] %>
        <% if row_id.present? %>
          <%= button_to t("db.table.delete"), settings_db_row_path(table: table[:name], row_id: row_id, page: table[:page]), method: :delete, form_class: "inline", class: "rounded-full border border-rose-200 bg-rose-50 px-3 py-1 font-semibold text-rose-700 transition hover:bg-rose-100", data: { turbo_confirm: t("db.table.delete_confirm", table: table[:name], id: row_id) } %>
        <% else %>
          <span class="text-slate-400"><%= t("db.table.delete_unavailable_short") %></span>
        <% end %>
      </td>
    <% end %>
  </tr>
<% end %>
