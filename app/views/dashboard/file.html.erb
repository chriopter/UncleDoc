<%= turbo_stream_from [@person, :entries] %>

<section class="space-y-5">
  <div class="flex items-center justify-between gap-3 rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5">
    <div class="min-w-0">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("files.label") %></p>
      <h1 class="truncate text-xl font-black tracking-tight text-slate-950"><%= @selected_document_entry.document_title.presence || @selected_document_entry.documents.first&.filename&.to_s || t("files.list.document_only") %></h1>
      <p class="mt-1 text-sm text-slate-500"><%= @person.name %> · <%= l(@selected_document_entry.display_time, format: :long) %></p>
    </div>

    <%= link_to t("files.viewer.back_to_files"), person_files_path(person_slug: @person.name, year: params[:year], doc_type: params[:doc_type]), class: "inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-white hover:text-slate-950" %>
  </div>

  <%= render "dashboard/document_viewer", entry: @selected_document_entry %>
</section>
