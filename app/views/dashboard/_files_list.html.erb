<%= turbo_frame_tag "files_list" do %>
  <% if document_entries.any? %>
    <% grouped_document_entries = document_entries.group_by { |entry| entry.display_time&.year || Time.current.year }.transform_values do |entries|
         entries.group_by { |entry| entry.document_type.presence || "other" }
       end %>
    <div class="space-y-10">
      <% grouped_document_entries.each do |year, type_groups| %>
        <% year_entries = type_groups.values.flatten %>
        <% year_document_count = year_entries.sum(&:document_count) %>
        <div>
          <div class="mb-5 flex items-center gap-4">
            <div class="group relative">
              <h2 class="text-2xl font-black tracking-tight text-slate-950"><%= year %></h2>
              <div class="pointer-events-none absolute left-0 top-full z-10 mt-2 hidden w-max items-center gap-2 rounded-full border border-slate-200 bg-white/95 px-3 py-1.5 shadow-sm group-hover:flex">
                <span class="text-xs font-semibold text-slate-400"><%= t("files.stats.documents_count", count: year_document_count) %></span>
                <span class="text-xs font-semibold text-slate-400"><%= t("files.stats.entries_count", count: year_entries.size) %></span>
              </div>
            </div>
            <div class="h-px flex-1 bg-slate-200"></div>
          </div>

          <div class="space-y-6">
            <% type_groups.each do |doc_type, entries| %>
              <div>
                <h3 class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-amber-700"><%= t("files.document_types.#{doc_type}", default: doc_type.humanize) %></h3>
                <% parsed_entries = entries.select(&:parsed?) %>
                <% attention_entries = entries.reject(&:parsed?) %>

                <% attention_entries.each do |entry| %>
                  <% row_classes = if entry.failed_parse?
                    "border-red-200 bg-red-50/70"
                  elsif entry.pending_parse?
                    "border-amber-200 bg-amber-50/70"
                  else
                    "border-slate-300 bg-slate-100"
                  end %>
                  <div class="mb-2 rounded-lg border px-3 py-2 <%= row_classes %>">
                    <div class="flex items-center gap-2">
                      <% if entry.pending_parse? %>
                        <svg class="h-3.5 w-3.5 shrink-0 animate-spin text-amber-600" viewBox="0 0 24 24" fill="none">
                          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                      <% elsif entry.failed_parse? %>
                        <svg class="h-3.5 w-3.5 shrink-0 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM12 16.5h.008v.008H12V16.5Z" />
                        </svg>
                      <% else %>
                        <svg class="h-3.5 w-3.5 shrink-0 text-slate-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                      <% end %>
                      <%= link_to person_file_path(person_slug: entry.person.name, entry_id: entry.id, year: params[:year], doc_type: params[:doc_type]), class: "min-w-0 flex-1 truncate text-xs font-medium text-slate-700 hover:text-slate-950", data: { turbo_frame: "_top" } do %>
                        <%= entry.document_title.presence || entry.document_names.join(", ").presence || t("files.list.document_only") %>
                      <% end %>
                      <span class="shrink-0 rounded-full px-2 py-0.5 text-[10px] font-bold uppercase tracking-[0.12em] <%= entry.failed_parse? ? 'bg-red-600 text-white' : entry.pending_parse? ? 'bg-amber-500 text-white' : 'bg-slate-700 text-white' %>">
                        <%= entry.failed_parse? ? t("entries.tags.parse_error") : entry.pending_parse? ? t("entries.tags.pending") : t("entries.tags.skipped") %>
                      </span>
                      <% unless entry.babywidget_generated? %>
                        <%= button_to reparse_person_entry_path(entry.person, entry), method: :patch,
                            class: "inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 transition hover:border-amber-300 hover:bg-amber-50 hover:text-amber-700",
                            form_class: "contents", data: { turbo_frame: "_top" } do %>
                          <span class="sr-only"><%= t("files.reparse.document_button") %></span>
                          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992V4.356" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M20.49 9.023A8.25 8.25 0 1 0 21 12" />
                          </svg>
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                <% end %>

                <% if parsed_entries.any? %>
                  <div class="grid grid-cols-3 gap-3 sm:grid-cols-4 lg:grid-cols-5 xl:grid-cols-4 2xl:grid-cols-5">
                    <% parsed_entries.each do |entry| %>
                      <% first_doc = entry.documents.first %>
                      <% thumbnail_path = file_thumbnail_path_for(entry) %>
                      <div class="group relative flex cursor-pointer flex-col rounded-xl border <%= params[:entry_id].to_i == entry.id ? 'border-amber-400 ring-2 ring-amber-100' : 'border-slate-200' %> bg-white p-3 transition hover:border-amber-300 hover:shadow-sm">
                        <%= link_to person_file_path(person_slug: entry.person.name, entry_id: entry.id, year: params[:year], doc_type: params[:doc_type]),
                            class: "absolute inset-0 z-10 rounded-xl focus:outline-none focus:ring-2 focus:ring-amber-300 focus:ring-offset-2",
                            aria: { label: t("files.viewer.open_inline") },
                            data: { turbo_frame: "_top" } do %>
                          <span class="sr-only"><%= t("files.viewer.open_inline") %></span>
                        <% end %>

                        <% if first_doc %>
                          <div class="mb-2 flex aspect-[1/1.4142] items-center justify-center overflow-hidden rounded-lg border border-slate-200 bg-slate-50">
                            <% if thumbnail_path.present? %>
                              <%= image_tag thumbnail_path, class: "h-full w-full object-cover", loading: "lazy", alt: entry.document_title.presence || first_doc.filename.to_s %>
                            <% else %>
                              <div class="flex flex-col items-center gap-2 text-slate-400">
                                <svg class="h-10 w-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                                </svg>
                                <span class="px-3 text-center text-[10px] font-semibold uppercase tracking-[0.14em]"><%= first_doc.filename.extension_without_delimiter.to_s.presence || "doc" %></span>
                              </div>
                            <% end %>
                          </div>
                        <% end %>

                        <p class="text-[10px] text-slate-400"><%= l(entry.display_time, format: :short) %></p>
                        <p class="line-clamp-2 text-xs font-semibold text-slate-800 transition group-hover:text-amber-800">
                          <%= entry.document_title.presence || first_doc&.filename&.to_s || t("files.list.document_only") %>
                        </p>
                        <% if document_type_labels(entry).present? %>
                          <p class="mt-1 text-[10px] font-medium text-slate-500"><%= document_type_labels(entry).join(" + ") %></p>
                        <% end %>
                        <% if entry.invoice_total_label.present? %>
                          <p class="mt-1 text-[10px] font-semibold text-emerald-700"><%= entry.invoice_total_label %></p>
                        <% end %>
                        <% if first_doc.present? %>
                          <p class="mt-1 truncate text-[10px] text-slate-400"><%= first_doc.filename.to_s %></p>
                        <% end %>

                        <div class="mt-2 flex items-center justify-end">
                          <% unless entry.babywidget_generated? %>
                            <%= button_to reparse_person_entry_path(entry.person, entry), method: :patch,
                                class: "relative z-20 inline-flex h-8 w-8 items-center justify-center rounded-lg border border-slate-200 bg-white text-slate-500 transition hover:border-amber-300 hover:bg-amber-50 hover:text-amber-700",
                                form_class: "contents", data: { turbo_frame: "_top" } do %>
                              <span class="sr-only"><%= t("files.reparse.document_button") %></span>
                              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992V4.356" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20.49 9.023A8.25 8.25 0 1 0 21 12" />
                              </svg>
                            <% end %>
                          <% end %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50/70 p-6 text-center text-sm text-slate-500">
      <p class="font-medium text-slate-700"><%= t("files.empty") %></p>
      <p class="mt-1 text-slate-500"><%= t("files.empty_subtitle") %></p>
    </div>
  <% end %>
<% end %>
