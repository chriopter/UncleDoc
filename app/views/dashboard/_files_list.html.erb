<%= turbo_frame_tag "files_list" do %>
  <% if document_entries.any? %>
    <% grouped_document_entries = document_entries.group_by { |entry| entry.display_time&.year || Time.current.year }.transform_values do |entries|
         entries.group_by { |entry| entry.document_type.presence || "other" }
       end %>
    <div class="space-y-10">
      <% grouped_document_entries.each do |year, type_groups| %>
        <div>
          <%# Year header %>
          <div class="mb-5 flex items-center gap-4">
            <h2 class="text-2xl font-black tracking-tight text-slate-950"><%= year %></h2>
            <div class="h-px flex-1 bg-slate-200"></div>
          </div>

          <%# Categories within year %>
          <div class="space-y-6">
            <% type_groups.each do |doc_type, entries| %>
              <div>
                <h3 class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-amber-700"><%= t("files.document_types.#{doc_type}", default: doc_type.humanize) %></h3>
                <% parsed_entries, pending_entries = entries.partition { |e| !e.pending_parse? } %>

                <%# Pending entries — compact lines with spinner %>
                <% pending_entries.each do |entry| %>
                  <div class="flex items-center gap-2 rounded-lg border border-amber-200 bg-amber-50/50 px-3 py-2 mb-2">
                    <svg class="h-3.5 w-3.5 shrink-0 animate-spin text-amber-600" viewBox="0 0 24 24" fill="none">
                      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <span class="min-w-0 truncate text-xs font-medium text-slate-700"><%= entry.document_names.join(", ").presence || t("files.list.document_only") %></span>
                    <span class="ml-auto shrink-0 text-[10px] text-amber-600"><%= t("entries.parse_status.pending") %></span>
                  </div>
                <% end %>

                <%# Parsed entries — full cards %>
                <% if parsed_entries.any? %>
                  <div class="grid grid-cols-3 gap-3 sm:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6">
                    <% parsed_entries.each do |entry| %>
                      <div class="group relative flex flex-col rounded-xl border border-slate-200 bg-white p-3 transition hover:border-amber-300 hover:shadow-sm">
                        <%# Thumbnail area — links to document %>
                        <% first_doc = entry.documents.first %>
                        <% if first_doc %>
                          <%= link_to rails_blob_path(first_doc, disposition: "inline"), target: "_blank", class: "block mb-2" do %>
                            <div class="overflow-hidden rounded-lg bg-slate-50 <%= entry.document_count > 1 ? 'grid grid-cols-2 gap-px' : '' %>">
                              <% entry.documents.limit(4).each do |doc| %>
                                <% single = entry.document_count == 1 %>
                                <div class="<%= single ? 'aspect-[1/1.4142] w-full' : 'aspect-[1/1.4142]' %> flex items-center justify-center overflow-hidden bg-slate-50">
                                  <% if doc.representable? %>
                                    <%= image_tag doc.representation(resize_to_fill: single ? [280, 396] : [140, 198]), class: "h-full w-full object-cover", loading: "lazy" %>
                                  <% else %>
                                    <svg class="h-6 w-6 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                                    </svg>
                                  <% end %>
                                </div>
                              <% end %>
                            </div>
                          <% end %>
                        <% end %>

                        <%# Date then title %>
                        <p class="text-[10px] text-slate-400"><%= l(entry.display_time, format: :short) %></p>
                        <p class="line-clamp-2 text-xs font-semibold text-slate-800"><%= entry.document_title.presence || entry.documents.first&.filename&.to_s || t("files.list.document_only") %></p>

                        <%# File count badge %>
                        <% if entry.document_count > 4 %>
                          <span class="absolute right-2 top-2 inline-flex items-center rounded-full bg-white/80 px-1.5 py-0.5 text-[10px] font-medium text-slate-600 backdrop-blur">+<%= entry.document_count - 4 %></span>
                        <% end %>

                        <%# Details popup button %>
                        <% if entry.fact_objects.present? || entry.input.present? %>
                          <details class="relative mt-2" onclick="event.stopPropagation()">
                            <summary class="flex cursor-pointer items-center justify-center rounded-lg border border-slate-200 px-2 py-1 text-[10px] font-medium text-slate-500 transition hover:border-amber-300 hover:text-amber-700 list-none [&::-webkit-details-marker]:hidden">
                              <svg class="mr-1 h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m5.25 12h-1.5m-3 0h-.008v.008H9v-.008Zm3 0h.008v.008H15v-.008Zm-6-3h.008v.008H9v-.008Zm3 0h.008v.008H12v-.008Zm3 0h.008v.008H15v-.008Z" />
                              </svg>
                              <%= t("files.details") %>
                            </summary>
                            <div class="absolute bottom-full left-0 z-50 mb-1 w-72 max-h-80 overflow-y-auto rounded-xl border border-slate-200 bg-white p-3 shadow-lg sm:w-80">
                              <div class="mb-2 flex items-start justify-between">
                                <div>
                                  <p class="text-xs font-semibold text-slate-800"><%= entry.document_title.presence || t("files.list.document_only") %></p>
                                  <p class="text-[10px] text-slate-400"><%= l(entry.display_time, format: :long) %></p>
                                </div>
                                <% if entry.document_type.present? %>
                                  <span class="ml-2 shrink-0 inline-flex items-center rounded-full bg-amber-50 px-2 py-0.5 text-[10px] font-medium text-amber-700"><%= t("files.document_types.#{entry.document_type}", default: entry.document_type.humanize) %></span>
                                <% end %>
                              </div>

                              <% if entry.input.present? %>
                                <p class="mb-2 text-xs leading-relaxed text-slate-600 whitespace-pre-wrap break-words"><%= entry.input %></p>
                              <% end %>

                              <%= render "entries/data_details", entry: entry %>

                              <div class="mt-2 flex flex-wrap gap-1.5">
                                <% entry.documents.each do |doc| %>
                                  <%= link_to rails_blob_path(doc, disposition: "inline"), target: "_blank", class: "inline-flex items-center gap-1 rounded-full border border-slate-200 bg-slate-50 px-2 py-1 text-[10px] font-medium text-slate-600 hover:border-amber-300 hover:text-amber-700" do %>
                                    <span class="max-w-[10rem] truncate"><%= doc.filename.to_s %></span>
                                    <svg class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                    </svg>
                                  <% end %>
                                <% end %>
                              </div>
                            </div>
                          </details>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50/70 p-6 text-center text-sm text-slate-500">
      <p class="font-medium text-slate-700"><%= t("files.empty") %></p>
      <p class="mt-1 text-slate-500"><%= t("files.empty_subtitle") %></p>
    </div>
  <% end %>
<% end %>
