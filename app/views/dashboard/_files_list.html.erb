<%= turbo_frame_tag "files_list" do %>
  <% if document_entries.any? %>
    <% grouped_document_entries = document_entries.group_by { |entry| entry.display_time&.year || Time.current.year }.transform_values do |entries|
         entries.group_by { |entry| entry.document_type.presence || "other" }
       end %>
    <div class="space-y-10">
      <% grouped_document_entries.each do |year, type_groups| %>
        <div>
          <div class="mb-5 flex items-center gap-4">
            <h2 class="text-2xl font-black tracking-tight text-slate-950"><%= year %></h2>
            <div class="h-px flex-1 bg-slate-200"></div>
          </div>

          <div class="space-y-6">
            <% type_groups.each do |doc_type, entries| %>
              <div>
                <h3 class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-amber-700"><%= t("files.document_types.#{doc_type}", default: doc_type.humanize) %></h3>
                <% parsed_entries = entries.select(&:parsed?) %>
                <% attention_entries = entries.reject(&:parsed?) %>

                <% attention_entries.each do |entry| %>
                  <% row_classes = if entry.failed_parse?
                    "border-red-200 bg-red-50/70"
                  elsif entry.pending_parse?
                    "border-amber-200 bg-amber-50/70"
                  else
                    "border-slate-300 bg-slate-100"
                  end %>
                  <div class="mb-2 rounded-lg border px-3 py-2 <%= row_classes %>">
                    <div class="flex items-center gap-2">
                      <% if entry.pending_parse? %>
                        <svg class="h-3.5 w-3.5 shrink-0 animate-spin text-amber-600" viewBox="0 0 24 24" fill="none">
                          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                      <% elsif entry.failed_parse? %>
                        <svg class="h-3.5 w-3.5 shrink-0 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM12 16.5h.008v.008H12V16.5Z" />
                        </svg>
                      <% else %>
                        <svg class="h-3.5 w-3.5 shrink-0 text-slate-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                      <% end %>
                      <%= link_to person_files_path(person_slug: entry.person.name, year: params[:year], doc_type: params[:doc_type], entry_id: entry.id), class: "min-w-0 flex-1 truncate text-xs font-medium text-slate-700 hover:text-slate-950" do %>
                        <%= entry.document_title.presence || entry.document_names.join(", ").presence || t("files.list.document_only") %>
                      <% end %>
                      <% unless entry.babywidget_generated? %>
                        <%= button_to reparse_person_entry_path(entry.person, entry), method: :patch,
                            class: "shrink-0 rounded-full border border-slate-200 bg-white px-2 py-1 text-[10px] font-semibold text-slate-700 transition hover:border-amber-300 hover:bg-amber-50 hover:text-amber-800",
                            form_class: "contents" do %>
                          <%= t("entries.reparse.trigger") %>
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                <% end %>

                <% if parsed_entries.any? %>
                  <div class="grid grid-cols-3 gap-3 sm:grid-cols-4 lg:grid-cols-5 xl:grid-cols-4 2xl:grid-cols-5">
                    <% parsed_entries.each do |entry| %>
                      <% first_doc = entry.documents.first %>
                      <div class="group relative flex flex-col rounded-xl border <%= params[:entry_id].to_i == entry.id ? 'border-amber-400 ring-2 ring-amber-100' : 'border-slate-200' %> bg-white p-3 transition hover:border-amber-300 hover:shadow-sm">
                        <% if first_doc %>
                          <%= link_to person_files_path(person_slug: entry.person.name, year: params[:year], doc_type: params[:doc_type], entry_id: entry.id), class: "mb-2 block" do %>
                            <div class="flex aspect-[1/1.4142] items-center justify-center overflow-hidden rounded-lg border border-slate-200 bg-slate-50">
                              <% if first_doc.image? %>
                                <%= image_tag rails_storage_proxy_path(first_doc, disposition: "inline"), class: "h-full w-full object-cover", loading: "lazy" %>
                              <% else %>
                                <div class="flex flex-col items-center gap-2 text-slate-400">
                                  <svg class="h-10 w-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                                  </svg>
                                  <span class="px-3 text-center text-[10px] font-semibold uppercase tracking-[0.14em]"><%= first_doc.filename.extension_without_delimiter.to_s.presence || "doc" %></span>
                                </div>
                              <% end %>
                            </div>
                          <% end %>
                        <% end %>

                        <p class="text-[10px] text-slate-400"><%= l(entry.display_time, format: :short) %></p>
                        <%= link_to person_files_path(person_slug: entry.person.name, year: params[:year], doc_type: params[:doc_type], entry_id: entry.id), class: "line-clamp-2 text-xs font-semibold text-slate-800 hover:text-amber-800" do %>
                          <%= entry.document_title.presence || first_doc&.filename&.to_s || t("files.list.document_only") %>
                        <% end %>

                        <div class="mt-2 flex items-center gap-2">
                          <%= link_to t("files.viewer.open_inline"), person_files_path(person_slug: entry.person.name, year: params[:year], doc_type: params[:doc_type], entry_id: entry.id), class: "inline-flex flex-1 items-center justify-center rounded-lg border border-slate-200 px-2 py-1 text-[10px] font-medium text-slate-500 transition hover:border-amber-300 hover:text-amber-700" %>
                          <% unless entry.babywidget_generated? %>
                            <%= button_to reparse_person_entry_path(entry.person, entry), method: :patch,
                                class: "inline-flex items-center justify-center rounded-lg border border-slate-200 px-2 py-1 text-[10px] font-medium text-slate-500 transition hover:border-amber-300 hover:text-amber-700",
                                form_class: "contents" do %>
                              <%= t("entries.reparse.trigger") %>
                            <% end %>
                          <% end %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50/70 p-6 text-center text-sm text-slate-500">
      <p class="font-medium text-slate-700"><%= t("files.empty") %></p>
      <p class="mt-1 text-slate-500"><%= t("files.empty_subtitle") %></p>
    </div>
  <% end %>
<% end %>
