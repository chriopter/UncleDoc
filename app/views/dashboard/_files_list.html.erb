<%= turbo_frame_tag "files_list" do %>
  <% grouped_document_entries = local_assigns[:grouped_document_entries] || group_document_entries(document_entries) %>
  <% if document_entries.any? %>
    <div class="space-y-8">
      <% grouped_document_entries.each do |doc_type, years| %>
        <div>
          <h3 class="mb-3 text-sm font-semibold uppercase tracking-[0.15em] text-amber-700"><%= t("files.document_types.#{doc_type}", default: doc_type.humanize) %></h3>

          <% years.sort_by { |year, _| -year }.each do |year, entries| %>
            <div class="mb-4">
              <p class="mb-2 text-xs font-medium text-slate-400"><%= year %></p>
              <div class="grid grid-cols-3 gap-3 sm:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6">
                <% entries.each do |entry| %>
                  <div class="group relative flex flex-col rounded-xl border border-slate-200 bg-white p-3 transition hover:border-amber-300 hover:shadow-sm">
                    <%# Thumbnail area %>
                    <% first_doc = entry.documents.first %>
                    <div class="mb-2 overflow-hidden rounded-lg bg-slate-50 <%= entry.document_count > 1 ? 'grid grid-cols-2 gap-px' : '' %>">
                      <% entry.documents.limit(4).each_with_index do |doc, i| %>
                        <% single = entry.document_count == 1 %>
                        <div class="<%= single ? 'aspect-[1/1.4142] w-full' : 'aspect-[1/1.4142]' %> flex items-center justify-center overflow-hidden bg-slate-50">
                          <% if doc.representable? %>
                            <%= image_tag doc.representation(resize_to_fill: single ? [280, 396] : [140, 198]), class: "h-full w-full object-cover", loading: "lazy" %>
                          <% else %>
                            <svg class="h-6 w-6 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                            </svg>
                          <% end %>
                        </div>
                      <% end %>
                    </div>

                    <%# Title %>
                    <p class="line-clamp-2 text-xs font-semibold text-slate-800"><%= entry.document_title.presence || entry.documents.first&.filename&.to_s || t("files.list.document_only") %></p>

                    <%# Type badge %>
                    <% if entry.document_type.present? %>
                      <span class="mt-1 inline-flex w-fit items-center rounded-full bg-amber-50 px-2 py-0.5 text-[10px] font-medium text-amber-700"><%= t("files.document_types.#{entry.document_type}", default: entry.document_type.humanize) %></span>
                    <% end %>

                    <%# Date %>
                    <p class="mt-auto pt-1 text-[10px] text-slate-400"><%= l(entry.display_time, format: :short) %></p>

                    <%# File count badge (when more than shown) %>
                    <% if entry.document_count > 4 %>
                      <span class="absolute right-2 top-2 inline-flex items-center rounded-full bg-white/80 px-1.5 py-0.5 text-[10px] font-medium text-slate-600 backdrop-blur">+<%= entry.document_count - 4 %></span>
                    <% end %>

                    <%# Click to open first document %>
                    <% if first_doc %>
                      <%= link_to rails_blob_path(first_doc, disposition: "inline"), class: "absolute inset-0 rounded-xl", target: "_blank" do %><% end %>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50/70 p-6 text-center text-sm text-slate-500">
      <p class="font-medium text-slate-700"><%= t("files.empty") %></p>
      <p class="mt-1 text-slate-500"><%= t("files.empty_subtitle") %></p>
    </div>
  <% end %>
<% end %>
