<%= turbo_frame_tag "files_list" do %>
  <% if document_entries.any? %>
    <div class="space-y-4">
      <% document_entries.each do |entry| %>
        <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.04] p-4 backdrop-blur">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="space-y-3">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-amber-300"><%= l(entry.display_time, format: :long) %></p>
                <p class="mt-2 text-base font-semibold text-white"><%= entry.fact_summary.presence || entry.input.presence || t("files.list.document_only") %></p>
              </div>

              <% if entry.input.present? %>
                <p class="max-w-3xl text-sm leading-6 text-slate-300"><%= truncate(entry.input, length: 240) %></p>
              <% end %>
            </div>

            <%= render "entries/documents", entry: entry, compact: false %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-3xl border border-dashed border-white/20 bg-white/[0.04] px-6 py-16 text-center text-slate-300">
      <p class="text-lg font-medium"><%= t("files.empty") %></p>
      <p class="mt-2 text-sm text-slate-400"><%= t("files.empty_subtitle") %></p>
    </div>
  <% end %>
<% end %>
