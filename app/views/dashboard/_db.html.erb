<section class="space-y-6">
  <div class="rounded-[2rem] border border-amber-200 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700">Admin</p>
    <h2 class="mt-2 text-2xl font-bold text-slate-950">Raw database view</h2>
    <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600">
      This tab shows the current SQLite tables and up to 50 rows per table for fast v1 inspection.
    </p>
  </div>

  <% database_snapshot.each do |table| %>
    <section class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm ring-1 ring-black/5">
      <div class="flex flex-col gap-3 border-b border-slate-200 bg-slate-950 px-5 py-4 text-white md:flex-row md:items-center md:justify-between">
        <div>
          <h3 class="text-lg font-bold"><%= table[:name] %></h3>
          <p class="text-sm text-slate-300"><%= pluralize(table[:count], "row") %> total</p>
        </div>
        <div class="rounded-full border border-white/15 px-3 py-1 text-xs font-semibold text-slate-300">
          <%= table[:columns].join(", ") %>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
          <thead class="bg-slate-50 text-slate-600">
            <tr>
              <% table[:columns].each do |column| %>
                <th class="px-4 py-3 font-semibold"><%= column %></th>
              <% end %>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 bg-white text-slate-800">
            <% if table[:rows].any? %>
              <% table[:rows].each do |row| %>
                <tr>
                  <% table[:columns].each do |column| %>
                    <td class="max-w-xs px-4 py-3 align-top text-xs leading-5 text-slate-700"><%= row[column].presence || "-" %></td>
                  <% end %>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="<%= table[:columns].size %>" class="px-4 py-8 text-center text-sm text-slate-500">No rows yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>
</section>
