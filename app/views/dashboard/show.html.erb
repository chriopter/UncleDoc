<section class="w-full space-y-6">
  <% if current_person %>
    <% if current_person.baby_mode? %>
      <%= render "dashboard/baby_dashboard", person: current_person, entry: @entry, entries: @entries %>
    <% else %>
      <div class="grid gap-6 xl:grid-cols-[minmax(0,420px)_minmax(0,1fr)]">
        <div class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
          <div class="mb-5 space-y-2">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("dashboard.new_entry.label") %></p>
            <h2 class="text-2xl font-bold text-slate-950"><%= t("dashboard.new_entry.title", name: current_person.name) %></h2>
            <p class="text-sm leading-6 text-slate-600"><%= t("dashboard.new_entry.subtitle") %></p>
          </div>

          <%= render "entries/form", entry: @entry, person: current_person %>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-sm ring-1 ring-black/5">
          <div class="mb-5 flex items-end justify-between gap-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-300"><%= t("dashboard.entries.label") %></p>
              <h2 class="text-2xl font-bold"><%= t("dashboard.entries.title", name: current_person.name) %></h2>
            </div>
            <span class="rounded-full border border-white/15 px-3 py-1 text-xs font-semibold text-slate-300"><%= t("dashboard.entries.count", count: @entries.count) %></span>
          </div>

          <%= render "entries/list", entries: @entries %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur text-center py-12">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("dashboard.welcome.title") %></p>
      <h2 class="mt-2 text-2xl font-bold text-slate-950"><%= t("dashboard.welcome.subtitle") %></h2>
      <p class="mt-4 text-slate-600"><%= t("dashboard.welcome.description") %></p>
      <%= link_to t("dashboard.welcome.cta"), settings_path_for(:users), class: "mt-6 inline-flex items-center rounded-xl bg-slate-950 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
    </div>
  <% end %>
</section>
