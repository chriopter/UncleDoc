<%= turbo_stream_from [person, :entries] %>

<% feeding_timer_started_at = baby_feeding_timer_started_at_for(person) %>
<% feeding_timer_side = baby_feeding_timer_side_for(person) %>
<% feeding_timer_elapsed = baby_feeding_timer_elapsed_label(feeding_timer_started_at) %>

<div class="space-y-6">
  <section class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
    <div class="flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
      <div class="flex items-center gap-4">
        <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-pink-100 text-2xl font-black text-pink-700 shadow-inner">
          <%= person.name.first.upcase %>
        </div>
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-pink-600"><%= t("baby.badge") %></p>
          <h1 class="mt-1 text-3xl font-black tracking-tight text-slate-950"><%= person.name %></h1>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600"><%= t("baby.quick_actions.subtitle") %></p>
        </div>
      </div>

      <div class="w-full max-w-xl xl:w-[28rem]">
        <div class="rounded-[1.75rem] border border-pink-200 bg-pink-50/50 p-5">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-pink-600"><%= t("dashboard.new_entry.label") %></p>
          <h2 class="mt-1 text-2xl font-bold text-slate-950"><%= t("dashboard.new_entry.title", name: person.name) %></h2>
          <p class="mt-2 text-sm leading-6 text-slate-600"><%= t("baby.notes.subtitle") %></p>

          <div class="mt-5">
            <%= render "entries/form", entry: entry, person: person %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="rounded-[2rem] border-2 border-pink-300 bg-pink-50/30 p-4 shadow-sm">
    <div class="grid gap-6 xl:grid-cols-2 xl:items-start">
      <div class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
        <div class="mb-5 space-y-2">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-pink-600"><%= t("baby.quick_actions.title") %></p>
          <h2 class="text-2xl font-bold text-slate-950"><%= t("baby.feeding.title") %> + <%= t("baby.diaper.title") %></h2>

          <% if feeding_timer_started_at %>
            <div class="mt-3 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3">
              <p class="text-xs font-semibold uppercase tracking-wider text-emerald-700"><%= t("baby.feeding.timer.running") %></p>
              <p class="text-base font-bold text-emerald-900"><%= t("baby.feeding.sides.#{feeding_timer_side}") %> · <%= feeding_timer_elapsed %></p>
              <p class="mt-1 text-xs text-emerald-700"><%= l(feeding_timer_started_at, format: :short) %></p>
            </div>
          <% end %>
        </div>

        <div class="space-y-4">
          <div class="border-t border-slate-200 pt-4" data-controller="feeding-mode" data-feeding-mode-default-value="breast">
            <label class="mb-3 block text-sm font-semibold text-slate-700"><%= t("baby.feeding.combined_title") %></label>
            <div class="mb-3 flex flex-wrap gap-2 text-xs">
              <% if person.time_since_last_feeding %>
                <span class="rounded-full border border-amber-200 bg-amber-50 px-3 py-1 font-semibold text-amber-800"><%= t("baby.last_feeding") %>: <%= capped_time_ago_in_words(person.time_since_last_feeding) %></span>
              <% end %>
            </div>

            <div data-feeding-mode-target="panel" data-panel="breast" class="space-y-3">
              <div class="grid grid-cols-3 gap-3">
                <% if feeding_timer_started_at && feeding_timer_side == "left" %>
                  <%= button_to person_baby_feeding_timer_path(person), method: :delete, class: "rounded-2xl border border-emerald-300 bg-emerald-100 px-4 py-4 text-left text-sm font-semibold text-emerald-900 transition hover:bg-emerald-200" do %>
                    <span class="block">🤱 <%= t("baby.feeding.sides.left") %></span>
                    <span class="mt-1 block text-xs font-medium text-emerald-700"><%= feeding_timer_elapsed %> · <%= t("baby.feeding.timer.tap_to_stop") %></span>
                  <% end %>
                <% elsif feeding_timer_started_at %>
                  <button type="button" disabled class="rounded-2xl border border-slate-200 bg-slate-100 px-4 py-4 text-left text-sm font-semibold text-slate-400">
                    <span class="block">🤱 <%= t("baby.feeding.sides.left") %></span>
                    <span class="mt-1 block text-xs font-medium"><%= t("baby.feeding.timer.running_elsewhere") %></span>
                  </button>
                <% else %>
                  <%= button_to person_baby_feeding_timer_path(person, side: "left"), method: :post, class: "rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-4 text-left text-sm font-semibold text-emerald-800 transition hover:bg-emerald-100" do %>
                    <span class="block">🤱 <%= t("baby.feeding.sides.left") %></span>
                    <span class="mt-1 block text-xs font-medium text-emerald-600"><%= t("baby.feeding.timer.start_hint") %></span>
                  <% end %>
                <% end %>

                <% if feeding_timer_started_at && feeding_timer_side == "right" %>
                  <%= button_to person_baby_feeding_timer_path(person), method: :delete, class: "rounded-2xl border border-emerald-300 bg-emerald-100 px-4 py-4 text-left text-sm font-semibold text-emerald-900 transition hover:bg-emerald-200" do %>
                    <span class="block">🤱 <%= t("baby.feeding.sides.right") %></span>
                    <span class="mt-1 block text-xs font-medium text-emerald-700"><%= feeding_timer_elapsed %> · <%= t("baby.feeding.timer.tap_to_stop") %></span>
                  <% end %>
                <% elsif feeding_timer_started_at %>
                  <button type="button" disabled class="rounded-2xl border border-slate-200 bg-slate-100 px-4 py-4 text-left text-sm font-semibold text-slate-400">
                    <span class="block">🤱 <%= t("baby.feeding.sides.right") %></span>
                    <span class="mt-1 block text-xs font-medium"><%= t("baby.feeding.timer.running_elsewhere") %></span>
                  </button>
                <% else %>
                  <%= button_to person_baby_feeding_timer_path(person, side: "right"), method: :post, class: "rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-4 text-left text-sm font-semibold text-emerald-800 transition hover:bg-emerald-100" do %>
                    <span class="block">🤱 <%= t("baby.feeding.sides.right") %></span>
                    <span class="mt-1 block text-xs font-medium text-emerald-600"><%= t("baby.feeding.timer.start_hint") %></span>
                  <% end %>
                <% end %>

                <button type="button" class="rounded-2xl border border-amber-200 bg-white px-4 py-4 text-left text-sm font-semibold text-amber-800 transition hover:bg-amber-50" data-feeding-mode-target="button" data-panel="bottle" data-active-classes="bg-amber-100 border-amber-300 text-amber-900 shadow-sm" data-inactive-classes="bg-white text-amber-800" data-action="feeding-mode#showPanel">
                  <span class="block"><%= t("baby.feeding.modes.bottle") %></span>
                  <span class="mt-1 block text-xs font-medium text-amber-600"><%= t("baby.bottle.button") %></span>
                </button>
              </div>
            </div>

            <div data-feeding-mode-target="panel" data-panel="bottle" class="hidden">
              <div class="mb-3 grid grid-cols-3 gap-3">
                <button type="button" class="rounded-2xl border border-emerald-200 bg-white px-4 py-4 text-left text-sm font-semibold text-emerald-800 transition hover:bg-emerald-50" data-feeding-mode-target="button" data-panel="breast" data-active-classes="bg-emerald-100 border-emerald-300 text-emerald-900 shadow-sm" data-inactive-classes="bg-white text-emerald-800" data-action="feeding-mode#showPanel">
                  <span class="block">🤱 <%= t("baby.feeding.sides.left") %></span>
                  <span class="mt-1 block text-xs font-medium text-emerald-600"><%= t("baby.feeding.modes.breast") %></span>
                </button>
                <button type="button" class="rounded-2xl border border-emerald-200 bg-white px-4 py-4 text-left text-sm font-semibold text-emerald-800 transition hover:bg-emerald-50" data-feeding-mode-target="button" data-panel="breast" data-active-classes="bg-emerald-100 border-emerald-300 text-emerald-900 shadow-sm" data-inactive-classes="bg-white text-emerald-800" data-action="feeding-mode#showPanel">
                  <span class="block">🤱 <%= t("baby.feeding.sides.right") %></span>
                  <span class="mt-1 block text-xs font-medium text-emerald-600"><%= t("baby.feeding.modes.breast") %></span>
                </button>
                <button type="button" class="rounded-2xl border border-amber-200 bg-white px-4 py-4 text-left text-sm font-semibold text-amber-800 transition hover:bg-amber-50" data-feeding-mode-target="button" data-panel="bottle" data-active-classes="bg-amber-100 border-amber-300 text-amber-900 shadow-sm" data-inactive-classes="bg-white text-amber-800" data-action="feeding-mode#showPanel">
                  <span class="block"><%= t("baby.feeding.modes.bottle") %></span>
                  <span class="mt-1 block text-xs font-medium text-amber-600"><%= t("baby.bottle.button") %></span>
                </button>
              </div>

              <%= form_with url: person_baby_bottle_action_path(person), class: "space-y-3" do |f| %>
                <div class="flex gap-2">
                  <%= f.number_field :amount_ml, min: 1, step: 1, placeholder: "120", class: "block w-full rounded-2xl border-amber-200 bg-white px-4 py-3 text-sm focus:border-amber-500 focus:ring-amber-500" %>
                  <%= f.submit t("baby.bottle.button"), class: "rounded-2xl bg-amber-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-amber-600" %>
                </div>
              <% end %>
            </div>
          </div>

          <div class="border-t border-slate-200 pt-4">
            <label class="mb-2 block text-sm font-semibold text-slate-700"><%= t("baby.diaper.title") %></label>
            <div class="mb-3 flex flex-wrap gap-2 text-xs">
              <% if person.time_since_last_diaper %>
                <span class="rounded-full border border-blue-200 bg-blue-50 px-3 py-1 font-semibold text-blue-800"><%= t("baby.last_diaper") %>: <%= capped_time_ago_in_words(person.time_since_last_diaper) %></span>
              <% end %>
            </div>
            <div class="grid grid-cols-3 gap-2">
              <%= button_to person_baby_diaper_action_path(person), params: { kind: "wet" }, class: "rounded-2xl border border-blue-200 bg-white px-3 py-3 text-left text-sm font-semibold text-blue-900 transition hover:bg-blue-100" do %>
                <span class="block"><%= t("baby.diaper.buttons.wet") %></span>
                <span class="mt-1 block text-xs font-medium text-blue-600"><%= t("entries.data_values.wet") %></span>
              <% end %>
              <%= button_to person_baby_diaper_action_path(person), params: { kind: "solid" }, class: "rounded-2xl border border-blue-200 bg-white px-3 py-3 text-left text-sm font-semibold text-blue-900 transition hover:bg-blue-100" do %>
                <span class="block"><%= t("baby.diaper.buttons.solid") %></span>
                <span class="mt-1 block text-xs font-medium text-blue-600"><%= t("entries.data_values.solid") %></span>
              <% end %>
              <%= button_to person_baby_diaper_action_path(person), params: { kind: "both" }, class: "rounded-2xl border border-blue-500 bg-gradient-to-br from-blue-500 to-blue-600 px-3 py-3 text-left text-sm font-semibold text-white transition hover:from-blue-600 hover:to-blue-700" do %>
                <span class="block"><%= t("baby.diaper.buttons.both") %></span>
                <span class="mt-1 block text-xs font-medium text-blue-100"><%= t("entries.data_values.wet") %> + <%= t("entries.data_values.solid") %></span>
              <% end %>
            </div>
          </div>

        </div>
      </div>

      <div class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-pink-600"><%= t("baby.protocol.title") %></p>
        <h2 class="mt-1 text-2xl font-bold text-slate-950"><%= t("dashboard.new_entry.title", name: person.name) %></h2>
        <p class="mt-2 text-sm leading-6 text-slate-600"><%= t("baby.notes.subtitle") %></p>
      </div>
    </div>
  </section>

  <section class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-sm ring-1 ring-black/5">
    <div class="mb-5 flex flex-col gap-3 border-b border-white/10 pb-5 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-pink-300"><%= t("baby.badge") %></p>
        <h2 class="mt-1 text-3xl font-black tracking-tight"><%= t("baby.protocol.title") %> - <%= person.name %></h2>
      </div>
      <span class="inline-flex rounded-full border border-white/15 px-3 py-1 text-xs font-semibold text-slate-300"><%= t(entries.count == 1 ? "baby.log.count" : "baby.log.count_plural", count: entries.count) %></span>
    </div>

    <%= render "entries/protocol_list", entries: entries %>
  </section>
</div>
