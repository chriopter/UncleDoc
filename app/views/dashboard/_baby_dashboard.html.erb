<div class="rounded-[2rem] border-2 border-pink-300 bg-pink-50/30 p-4 shadow-sm">
  <%# Baby Mode Heading %>
  <div class="mb-4 flex items-center gap-2">
    <span class="flex h-8 w-8 items-center justify-center rounded-full bg-pink-500 text-white">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.592-2.296 6.375 6.375 0 0 1 1.998 3.18M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106c0 .771-.146 1.508-.408 2.19M12 14a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" />
      </svg>
    </span>
    <span class="text-lg font-bold text-pink-700"><%= t("baby.badge") %></span>
  </div>
  
  <div class="grid gap-6 xl:grid-cols-[minmax(0,420px)_minmax(0,1fr)]">
    <%# Left column: Quick actions %>
    <div class="space-y-6">
      <%# Feeding tracker %>
      <div class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
        <div class="mb-5 space-y-2">
          <h2 class="text-2xl font-bold text-slate-950"><%= t("baby.feeding.title") %></h2>
          
          <% if person.time_since_last_feeding %>
            <div class="mt-3 rounded-xl bg-amber-50 border border-amber-200 px-4 py-3">
              <p class="text-xs text-amber-700 uppercase tracking-wider font-semibold"><%= t("baby.last_event") %></p>
              <p class="text-lg font-bold text-amber-900"><%= time_ago_in_words(person.time_since_last_feeding) %></p>
            </div>
          <% else %>
            <p class="text-sm text-slate-500 mt-2"><%= t("baby.feeding.empty") %></p>
          <% end %>
        </div>

        <%= button_to person_entries_path(person, entry: { entry_type: "baby_feeding", date: Date.today, note: t("baby.feeding.default_note"), metadata: {} }), 
            method: :post,
            class: "w-full rounded-2xl bg-emerald-500 px-5 py-4 text-base font-semibold text-white transition hover:bg-emerald-600 flex items-center justify-center gap-2" do %>
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <%= t("baby.feeding.button") %>
        <% end %>
      </div>

      <%# Diaper tracker with dropdown %>
      <div class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
        <div class="mb-5 space-y-2">
          <h2 class="text-2xl font-bold text-slate-950"><%= t("baby.diaper.title") %></h2>
          
          <% if person.time_since_last_diaper %>
            <div class="mt-3 rounded-xl bg-blue-50 border border-blue-200 px-4 py-3">
              <p class="text-xs text-blue-700 uppercase tracking-wider font-semibold"><%= t("baby.last_event") %></p>
              <p class="text-lg font-bold text-blue-900"><%= time_ago_in_words(person.time_since_last_diaper) %></p>
            </div>
          <% else %>
            <p class="text-sm text-slate-500 mt-2"><%= t("baby.diaper.empty") %></p>
          <% end %>
        </div>

        <%# Diaper Form with Consistency Dropdown %>
        <%= form_with model: [person, entry], class: "space-y-4" do |f| %>
          <%= f.hidden_field :entry_type, value: "baby_diaper" %>
          <%= f.hidden_field :date, value: Date.today %>
          <%= f.hidden_field :note, value: t("baby.diaper.default_note") %>
          
          <%# Consistency Dropdown %>
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-2"><%= t("baby.diaper.consistency") %></label>
            <%= f.select :consistency, 
                [
                  [t("baby.diaper.consistency_options.solid"), "solid"],
                  [t("baby.diaper.consistency_options.fluid"), "fluid"],
                  [t("baby.diaper.consistency_options.wet_only"), "none"],
                  [t("baby.diaper.consistency_options.both"), "both"]
                ],
                {},
                { 
                  name: "entry[metadata][consistency]",
                  class: "w-full rounded-xl border-slate-300 bg-white px-4 py-2 text-sm focus:border-blue-500 focus:ring-blue-500"
                } %>
          </div>
          
          <%# Rash Checkbox %>
          <div class="flex items-center gap-2">
            <%= f.check_box :rash, { name: "entry[metadata][rash]", class: "rounded border-slate-300 text-blue-600 focus:ring-blue-500" }, "true", "false" %>
            <label class="text-sm text-slate-700"><%= t("baby.diaper.rash") %></label>
          </div>
          
          <%= f.submit t("baby.diaper.button"), 
              class: "w-full rounded-2xl bg-blue-500 px-5 py-3 text-base font-semibold text-white transition hover:bg-blue-600 flex items-center justify-center gap-2" %>
        <% end %>
      </div>
    </div>

    <%# Right column: Log %>
    <div class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-sm ring-1 ring-black/5">
      <div class="mb-5 flex items-end justify-between gap-4">
        <div>
          <h2 class="text-2xl font-bold"><%= t("baby.protocol.title") %></h2>
        </div>
        <span class="rounded-full border border-white/15 px-3 py-1 text-xs font-semibold text-slate-300"><%= t("baby.log.count", count: entries.count) %></span>
      </div>

      <%= render "entries/baby_list", entries: entries %>
    </div>
  </div>
</div>
