<section class="space-y-6">
  <section class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm ring-1 ring-black/5">
    <div class="flex flex-col gap-3 border-b border-slate-200 bg-slate-950 px-5 py-4 text-white md:flex-row md:items-center md:justify-between">
      <h3 class="text-lg font-bold"><%= table[:name] %></h3>
      <div class="rounded-full border border-white/15 px-3 py-1 text-xs font-semibold text-slate-300">
        <%= table[:columns].join(", ") %>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
        <thead class="bg-slate-50 text-slate-600">
          <tr>
            <% table[:columns].each do |column| %>
              <th class="px-4 py-3 font-semibold"><%= column %></th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white text-slate-800">
          <% if table[:rows].any? %>
            <% table[:rows].each do |row| %>
              <tr>
                <% table[:columns].each do |column| %>
                  <td class="max-w-xs px-4 py-3 align-top text-xs leading-5 text-slate-700"><%= row[column].presence || "-" %></td>
                <% end %>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="<%= table[:columns].size %>" class="px-4 py-8 text-center text-sm text-slate-500"><%= t("db.table.empty") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</section>
