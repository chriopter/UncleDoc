<%= turbo_stream_from [person, :entries] %>

<div class="space-y-6">
  <section class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
    <div class="flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
      <div class="flex items-center gap-4">
        <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-amber-100 text-2xl font-black text-amber-800 shadow-inner">
          <%= person.name.first.upcase %>
        </div>
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("dashboard.protocol.label") %></p>
          <h1 class="mt-1 text-3xl font-black tracking-tight text-slate-950"><%= person.name %> <span class="text-xl font-medium text-slate-500"><%= person_age_label(person.birth_date) if person.birth_date %></span></h1>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600"><%= t("dashboard.new_entry.subtitle") %></p>
        </div>
      </div>

      <div class="flex items-start gap-3">
        <span class="inline-flex rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-800">
          <%= t(entries.count == 1 ? "dashboard.protocol.count" : "dashboard.protocol.count_plural", count: entries.count) %>
        </span>
      </div>

      <div class="w-full max-w-xl xl:w-[28rem]">
        <%= render "entries/inline_form", entry: entry, person: person %>
      </div>
    </div>
  </section>

  <%= render "dashboard/log_summary", person: person, summary: log_summary, state: log_summary_state %>

  <section class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-sm ring-1 ring-black/5">
    <div class="mb-5 flex flex-col gap-3 border-b border-white/10 pb-5 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-300"><%= t("dashboard.protocol.label") %></p>
        <h2 class="mt-1 text-3xl font-black tracking-tight"><%= t("dashboard.protocol.title", name: person.name) %></h2>
      </div>
      <span class="inline-flex rounded-full border border-white/15 px-3 py-1 text-xs font-semibold text-slate-300">
        <%= t(entries.count == 1 ? "dashboard.protocol.count" : "dashboard.protocol.count_plural", count: entries.count) %>
      </span>
    </div>

    <%= render "entries/protocol_list", entries: entries %>
  </section>
</div>
