<%= turbo_frame_tag "healthkit_records_table_frame" do %>
  <section class="bg-white">
    <div class="border-y border-slate-200 bg-white px-5 py-3 sm:px-6">
      <p class="text-xs font-medium text-slate-500">
        <%= t("db.table.loaded_count", count: table[:rendered_count]) %>
        <% if table[:count].present? %>
          · <%= t(table[:count] == 1 ? "db.table.count" : "db.table.count_plural", count: table[:count]) %>
        <% end %>
        <% if table[:order_column].present? %>
          · <%= t("db.table.sorted_by", column: table[:order_column]) %>
        <% end %>
      </p>
    </div>

    <div class="overflow-x-auto">
      <table class="w-max min-w-full divide-y divide-slate-200 text-left text-sm">
        <thead class="bg-slate-50 text-slate-500">
          <tr>
            <% table[:columns].each do |column| %>
              <th class="min-w-[10rem] px-4 py-3 text-xs font-semibold uppercase tracking-[0.12em] whitespace-nowrap"><%= column %></th>
            <% end %>
          </tr>
        </thead>
        <tbody id="db_table_rows" class="divide-y divide-slate-100 bg-white text-slate-800">
          <% if table[:rows].any? %>
            <%= render "dashboard/db_table_rows", table: table %>
          <% else %>
            <tr>
              <td colspan="<%= table[:columns].size %>" class="px-4 py-8 text-center text-sm text-slate-500"><%= t("db.table.empty") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <%= render "dashboard/db_table_loader_healthkit", table: table, person: person %>
  </section>
<% end %>
