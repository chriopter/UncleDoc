<section class="grid gap-6 xl:grid-cols-[minmax(0,1.2fr)_minmax(22rem,0.8fr)] xl:items-start">
  <%= render "dashboard/log_feed", person: @person, entries: @entries, sort: @entry_sort, available_filters: @available_log_filters %>

  <section class="flex h-[calc(100vh-6rem)] min-h-[32rem] w-full flex-col" data-controller="chat" data-chat-url="<%= person_chat_path(person_slug: @person.name) %>">
    <div class="flex items-center gap-3 rounded-t-[2rem] border border-slate-200/70 bg-[linear-gradient(180deg,_#0f172a_0%,_#111827_100%)] px-6 py-4">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-white/10 text-sm font-black text-white ring-1 ring-white/10">
        <%= @person.name.first.upcase %>
      </div>
      <div>
        <h2 class="text-lg font-bold text-white"><%= t("chat.title", name: @person.name) %></h2>
        <p class="text-xs text-slate-400"><%= t("chat.subtitle", count: @person.entries.count) %></p>
      </div>
    </div>

    <div class="flex-1 overflow-y-auto border-x border-slate-200/70 bg-[linear-gradient(180deg,_#111827_0%,_#0f172a_100%)] px-4 py-6 sm:px-6" data-chat-target="messages">
      <div class="flex justify-start">
        <div class="max-w-[80%] rounded-2xl rounded-tl-md bg-white/10 px-4 py-3 text-sm leading-relaxed text-slate-100">
          <div data-role="content" class="whitespace-pre-wrap"><%= t("chat.welcome", name: @person.name) %></div>
        </div>
      </div>
    </div>

    <div class="rounded-b-[2rem] border border-slate-200/70 bg-slate-950 px-4 py-4 sm:px-6">
      <form data-chat-target="form" data-action="submit->chat#send" class="flex items-end gap-3">
        <textarea
          data-chat-target="input"
          data-action="input->chat#autoResize keydown->chat#handleKeydown"
          rows="1"
          placeholder="<%= t("chat.placeholder") %>"
          class="flex-1 resize-none rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-slate-500 focus:border-amber-400 focus:outline-none focus:ring-1 focus:ring-amber-400"
        ></textarea>
        <button
          type="submit"
          data-chat-target="submit"
          class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-amber-500 text-white transition hover:bg-amber-400 disabled:opacity-40"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
          </svg>
        </button>
      </form>
    </div>
  </section>
</section>
