<section class="w-full space-y-6">
  <%# Header %>
  <div class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
    <div class="flex items-center gap-4">
      <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-amber-100 text-amber-800 text-xl font-bold">
        <%= @person.name.first.upcase %>
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700">Health Log</p>
        <h1 class="text-2xl font-black tracking-tight text-slate-950"><%= @person.name %></h1>
      </div>
    </div>
  </div>

  <%# Log Grid %>
  <div class="grid gap-6 xl:grid-cols-[minmax(0,420px)_minmax(0,1fr)]">
    <%# New Entry Form %>
    <div class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
      <div class="mb-5 space-y-2">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700">New Entry</p>
        <h2 class="text-2xl font-bold text-slate-950">Add health note</h2>
        <p class="text-sm leading-6 text-slate-600">Record date and notes about medical events.</p>
      </div>

      <%= render "entries/form", entry: @entry, person: @person %>
    </div>

    <%# Entries List %>
    <div class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-sm ring-1 ring-black/5">
      <div class="mb-5 flex items-end justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-300">Log</p>
          <h2 class="text-2xl font-bold">All Entries</h2>
        </div>
        <span class="rounded-full border border-white/15 px-3 py-1 text-xs font-semibold text-slate-300"><%= pluralize(@entries.count, "entry") %></span>
      </div>

      <%= render "entries/list", entries: @entries %>
    </div>
  </div>
</section>
