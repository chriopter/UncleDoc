<section class="w-full space-y-6">
  <section class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
    <div class="mb-4">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("dashboard.new_entry.label") %></p>
      <h2 class="mt-1 text-2xl font-bold text-slate-950"><%= t("dashboard.new_entry.title", name: @person.name) %></h2>
      <p class="mt-2 text-sm leading-6 text-slate-600"><%= t(@person.baby_mode? ? "baby.notes.subtitle" : "dashboard.new_entry.subtitle") %></p>
    </div>

    <%= render "entries/inline_form", entry: @entry, person: @person %>
  </section>

  <%= render "dashboard/log_feed", person: @person, entries: @entries, sort: @entry_sort %>
</section>
