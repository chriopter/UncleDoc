<section class="space-y-5">
  <%= render "dashboard/data_tabs", person: @person, active_tab: @data_tab %>

  <% if @data_tab == "healthkit" %>
    <%= render "dashboard/healthkit_panel" %>
  <% elsif @data_tab == "record" %>
    <%= render "dashboard/patient_record_panel", person: @person, prompt: @patient_record_prompt %>
  <% else %>
    <%= render "dashboard/log_feed", person: @person, entries: @entries, sort: @entry_sort, available_filters: @available_log_filters %>
  <% end %>
</section>
