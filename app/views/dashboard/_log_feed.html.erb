<%= turbo_stream_from [person, :entries] %>

<% available_dates = Array(local_assigns[:available_filters]&.dig(:dates)).compact %>

<section class="relative overflow-hidden rounded-[2rem] border border-amber-100/80 bg-[radial-gradient(circle_at_top_left,_rgba(251,191,36,0.16),_transparent_32%),linear-gradient(180deg,_rgba(255,255,255,0.97)_0%,_rgba(255,248,235,0.94)_100%)] p-4 text-slate-900 shadow-[0_24px_70px_-32px_rgba(120,53,15,0.22)] ring-1 ring-amber-100/70 sm:p-5">
  <div class="absolute inset-x-0 top-0 h-24 bg-gradient-to-r from-amber-200/40 via-white/20 to-transparent"></div>

  <div class="relative space-y-4">
    <div class="flex flex-col gap-4 rounded-[1.5rem] border border-white/80 bg-white/80 p-4 shadow-sm ring-1 ring-amber-100/60 backdrop-blur sm:flex-row sm:items-center sm:justify-between">
      <div class="flex min-w-0 items-center gap-3">
        <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-amber-100 text-base font-black text-amber-800 ring-1 ring-amber-200/80">
          <%= person.name.first.upcase %>
        </div>

        <div class="min-w-0">
          <% if person.baby_mode? %>
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-pink-600"><%= t("baby.log.label") %></p>
            <h1 class="truncate text-xl font-black tracking-tight text-slate-950 sm:text-2xl"><%= t("baby.log.title", name: person.name) %></h1>
          <% else %>
            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-amber-700"><%= t("dashboard.protocol.label") %></p>
            <h1 class="truncate text-xl font-black tracking-tight text-slate-950 sm:text-2xl"><%= t("dashboard.protocol.title", name: person.name) %></h1>
          <% end %>

          <% if entries.any? %>
            <p class="mt-1 text-xs text-slate-500">
              <%= t("person.overview.stats.last_activity") %> <%= l(entries.first.display_time, format: :long) %>
            </p>
          <% end %>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <div class="inline-flex rounded-full border border-amber-100 bg-amber-50/80 p-1 text-[11px] font-semibold text-slate-500">
          <%= link_to entry_sort_label("occurred"), person_log_path(person_slug: person.name, **log_filter_params(sort: "occurred")), class: "rounded-full px-3 py-1 transition #{entry_sort_mode(local_assigns[:sort] || params) == 'occurred' ? 'bg-white text-amber-800 shadow-sm ring-1 ring-amber-200/80' : 'hover:bg-white/70 hover:text-slate-900'}" %>
          <%= link_to entry_sort_label("entered"), person_log_path(person_slug: person.name, **log_filter_params(sort: "entered")), class: "rounded-full px-3 py-1 transition #{entry_sort_mode(local_assigns[:sort] || params) == 'entered' ? 'bg-white text-amber-800 shadow-sm ring-1 ring-amber-200/80' : 'hover:bg-white/70 hover:text-slate-900'}" %>
        </div>

        <% if person.baby_mode? %>
          <span class="inline-flex rounded-full border border-pink-200 bg-pink-50 px-3 py-1 text-xs font-semibold text-pink-700"><%= t("baby.badge") %></span>
          <span class="inline-flex rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-semibold text-slate-600"><%= t(entries.count == 1 ? "baby.log.count" : "baby.log.count_plural", count: entries.count) %></span>
        <% else %>
          <span class="inline-flex rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-800"><%= t(entries.count == 1 ? "dashboard.protocol.count" : "dashboard.protocol.count_plural", count: entries.count) %></span>
        <% end %>
      </div>
    </div>

    <div class="rounded-[1.5rem] border border-amber-100/80 bg-white/75 p-4 shadow-sm ring-1 ring-amber-100/50 backdrop-blur">
      <%= form_with url: person_log_path(person_slug: person.name), method: :get, local: true, class: "grid gap-3 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_auto] lg:items-end", data: { controller: "auto-submit" } do |form| %>
        <%= form.hidden_field :sort, value: entry_sort_mode(local_assigns[:sort] || params) %>

        <div>
          <%= form.label :date, t("entries.filters.date"), class: "mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500" %>
          <%= form.date_field :date,
              value: params[:date],
              min: available_dates.min&.iso8601,
              max: available_dates.max&.iso8601,
              class: "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 focus:border-amber-400 focus:ring-amber-400",
              data: { action: "change->auto-submit#submit" } %>
        </div>

        <div>
          <%= form.label :parseable_type, t("entries.filters.parseable_type"), class: "mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500" %>
          <%= form.select :parseable_type, options_for_select([[t("entries.filters.all_types"), nil]] + Array(local_assigns[:available_filters]&.dig(:parseable_type_options)), params[:parseable_type]), {}, class: "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 focus:border-amber-400 focus:ring-amber-400", data: { action: "change->auto-submit#submit" } %>
        </div>

        <div class="flex gap-2 lg:justify-end">
          <%= link_to t("entries.filters.reset"), person_log_path(person_slug: person.name, sort: entry_sort_mode(local_assigns[:sort] || params)), class: "rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-white hover:text-slate-950" %>
        </div>
      <% end %>
    </div>

    <div class="rounded-[1.5rem] border border-amber-100/80 bg-white/72 p-3 shadow-sm ring-1 ring-amber-100/40 sm:p-4">
      <% if person.baby_mode? %>
        <%= render "entries/baby_list", entries: entries %>
      <% else %>
        <%= render "entries/protocol_list", entries: entries %>
      <% end %>
    </div>
  </div>
</section>
