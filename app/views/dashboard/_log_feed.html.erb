<%= turbo_stream_from [person, :entries] %>

<% available_dates = Array(local_assigns[:available_filters]&.dig(:dates)).compact %>

<section class="space-y-6">
  <div class="grid grid-cols-1 items-stretch gap-6 md:grid-cols-3">
    <%= render "shared/overview_composer", person: person, card_classes: "md:col-span-1" %>

    <%= render "shared/widget", id: "log_header", color: "amber", card_classes: "md:col-span-2 flex flex-col" do %>
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex min-w-0 items-center gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-amber-100 text-sm font-black text-amber-800 ring-1 ring-amber-200/80">
            <%= person.name.first.upcase %>
          </div>
          <div class="min-w-0">
            <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("dashboard.protocol.label") %></p>
            <h1 class="truncate text-xl font-black tracking-tight text-slate-950"><%= t("dashboard.protocol.title", name: person.name) %></h1>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-2">
          <div class="inline-flex rounded-full border border-amber-100 bg-amber-50/80 p-1 text-[11px] font-semibold text-slate-500">
            <%= link_to entry_sort_label("occurred"), person_log_path(person_slug: person.name, **log_filter_params(sort: "occurred")), class: "rounded-full px-3 py-1 transition #{entry_sort_mode(local_assigns[:sort] || params) == 'occurred' ? 'bg-white text-amber-800 shadow-sm ring-1 ring-amber-200/80' : 'hover:bg-white/70 hover:text-slate-900'}" %>
            <%= link_to entry_sort_label("entered"), person_log_path(person_slug: person.name, **log_filter_params(sort: "entered")), class: "rounded-full px-3 py-1 transition #{entry_sort_mode(local_assigns[:sort] || params) == 'entered' ? 'bg-white text-amber-800 shadow-sm ring-1 ring-amber-200/80' : 'hover:bg-white/70 hover:text-slate-900'}" %>
          </div>

          <% if person.baby_mode? %>
            <span class="inline-flex rounded-full border border-pink-200 bg-pink-50 px-3 py-1 text-xs font-semibold text-pink-700"><%= t("baby.badge") %></span>
          <% end %>
          <span class="inline-flex rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-800"><%= t(entries.count == 1 ? "dashboard.protocol.count" : "dashboard.protocol.count_plural", count: entries.count) %></span>
        </div>
      </div>

      <div class="mt-auto border-t border-amber-100/80 pt-4 mt-4">
        <p class="mb-2 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400"><%= t("entries.filters.label") %></p>
        <%= form_with url: person_log_path(person_slug: person.name), method: :get, local: true, class: "grid gap-3 xl:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_minmax(0,1fr)_auto] xl:items-end", data: { controller: "auto-submit" } do |form| %>
          <%= form.hidden_field :sort, value: entry_sort_mode(local_assigns[:sort] || params) %>

          <div>
            <%= form.label :date, t("entries.filters.date"), class: "mb-1.5 block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500" %>
            <%= form.date_field :date,
                value: params[:date],
                min: available_dates.min&.iso8601,
                max: available_dates.max&.iso8601,
                class: "w-full rounded-xl border border-slate-200 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-400 focus:ring-2 focus:ring-amber-200",
                data: { action: "change->auto-submit#submit" } %>
          </div>

          <div>
            <%= form.label :source, t("entries.filters.source"), class: "mb-1.5 block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500" %>
            <%= form.select :source, options_for_select([[t("entries.filters.all_sources"), nil]] + Array(local_assigns[:available_filters]&.dig(:source_options)), params[:source]), {}, class: "w-full rounded-xl border border-slate-200 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-400 focus:ring-2 focus:ring-amber-200", data: { action: "change->auto-submit#submit" } %>
          </div>

          <div>
            <%= form.label :parseable_type, t("entries.filters.parseable_type"), class: "mb-1.5 block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500" %>
            <%= form.select :parseable_type, options_for_select([[t("entries.filters.all_types"), nil]] + Array(local_assigns[:available_filters]&.dig(:parseable_type_options)), params[:parseable_type]), {}, class: "w-full rounded-xl border border-slate-200 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-400 focus:ring-2 focus:ring-amber-200", data: { action: "change->auto-submit#submit" } %>
          </div>

          <div>
            <%= link_to t("entries.filters.reset"), person_log_path(person_slug: person.name, sort: entry_sort_mode(local_assigns[:sort] || params)), class: "inline-flex rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-white hover:text-slate-950" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%= render "shared/widget", id: "log_entries", color: "slate", card_classes: "" do %>
    <%= render "entries/protocol_list", entries: entries %>
  <% end %>
</section>
