<% if entry.present? && (document = entry.documents.first) %>
  <section class="grid overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm xl:grid-cols-[minmax(0,1fr)_minmax(24rem,0.42fr)]">
    <section class="min-w-0 border-b border-slate-200 xl:border-r xl:border-b-0">
      <div class="bg-slate-100 p-3">
        <% if document.image? %>
          <div class="overflow-hidden rounded-[1.5rem] bg-white p-2">
            <%= image_tag person_file_content_path(person_slug: entry.person.name, entry_id: entry.id), class: "mx-auto max-h-[70vh] w-auto rounded-xl object-contain" %>
          </div>
        <% else %>
          <iframe src="<%= person_file_content_path(person_slug: entry.person.name, entry_id: entry.id) %>" class="h-[82vh] w-full rounded-[1.5rem] border border-slate-200 bg-white" title="<%= entry.document_title.presence || document.filename.to_s %>"></iframe>
        <% end %>
      </div>
    </section>

    <aside class="min-w-0 p-5 xl:max-h-[calc(100vh-3rem)] xl:overflow-y-auto">
      <div class="flex items-center justify-between gap-3">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("files.label") %></p>

        <%= link_to t("files.viewer.back_to_files"), person_files_path(person_slug: entry.person.name, year: params[:year], doc_type: params[:doc_type]), class: "inline-flex shrink-0 items-center rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-600 transition hover:bg-white hover:text-slate-950" %>
      </div>

      <div class="mt-4 min-w-0">
        <h1 class="break-words text-xl font-black leading-tight text-slate-950"><%= entry.document_title.presence || document.filename.to_s %></h1>
        <p class="mt-2 text-sm leading-6 text-slate-500"><%= entry.person.name %> · <%= l(entry.display_time, format: :long) %></p>
      </div>

      <div class="mt-5 flex flex-wrap items-center gap-2 border-b border-slate-200 pb-5">
        <% unless entry.babywidget_generated? %>
          <%= button_to reparse_person_entry_path(entry.person, entry), method: :patch,
              class: "inline-flex items-center gap-2 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-sm font-semibold text-amber-800 transition hover:bg-amber-100",
              form_class: "contents" do %>
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992V4.356" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.49 9.023A8.25 8.25 0 1 0 21 12" />
            </svg>
            <span><%= t("files.reparse.document_button") %></span>
          <% end %>
        <% end %>

        <%= link_to t("entries.documents.open"), person_file_content_path(person_slug: entry.person.name, entry_id: entry.id), target: "_blank", class: "inline-flex items-center rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-600 transition hover:bg-white hover:text-slate-950" %>
      </div>

      <div class="mt-6 space-y-5">
        <section class="rounded-2xl border border-slate-200 bg-slate-50/70 p-4">
          <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("files.viewer.document_meta") %></p>
          <% if document_type_labels(entry).present? %>
            <p class="mt-2 text-sm font-semibold text-slate-900"><%= document_type_labels(entry).join(" + ") %></p>
          <% end %>
          <% if entry.invoice_total_label.present? %>
            <p class="mt-1 text-sm font-semibold text-emerald-700"><%= t("entries.document_metadata.invoice_total") %>: <%= entry.invoice_total_label %></p>
          <% end %>
          <p class="mt-1 text-xs text-slate-500"><%= document.filename.to_s %></p>
        </section>

        <section>
          <p class="mb-2 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("files.viewer.sidebar_label") %></p>
          <% if entry.fact_objects.present? %>
            <div class="rounded-2xl border border-slate-200 bg-white">
              <%= render "entries/data_details", entry: entry %>
            </div>
          <% else %>
            <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50/80 p-4 text-sm text-slate-500"><%= t("entries.parsed_data.empty") %></div>
          <% end %>
        </section>
      </div>
    </aside>
  </section>
<% else %>
  <section class="rounded-[2rem] border border-dashed border-slate-300 bg-slate-50/70 p-6 text-center text-sm text-slate-500">
    <p class="font-medium text-slate-700"><%= t("files.viewer.empty") %></p>
  </section>
<% end %>
