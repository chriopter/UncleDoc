<% if entry.present? && (document = entry.documents.first) %>
  <section class="grid gap-5 xl:grid-cols-[minmax(0,1.35fr)_minmax(20rem,0.65fr)]">
    <section class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white ring-1 ring-black/5">
      <div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-200 px-5 py-4">
        <div class="min-w-0">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("files.viewer.label") %></p>
          <h2 class="truncate text-lg font-bold text-slate-950"><%= entry.document_title.presence || document.filename.to_s %></h2>
        </div>
        <div class="flex items-center gap-2">
          <% unless entry.babywidget_generated? %>
            <%= button_to reparse_person_entry_path(entry.person, entry), method: :patch,
                class: "inline-flex items-center rounded-full border border-amber-200 bg-amber-50 px-3 py-1.5 text-xs font-semibold text-amber-800 transition hover:bg-amber-100",
                form_class: "contents" do %>
              <%= t("files.reparse.document_button") %>
            <% end %>
          <% end %>
          <%= link_to t("entries.documents.open"), person_file_content_path(person_slug: entry.person.name, entry_id: entry.id), target: "_blank", class: "inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-white" %>
        </div>
      </div>

      <div class="bg-slate-100 p-3">
        <% if document.image? %>
          <div class="overflow-hidden rounded-[1.5rem] bg-white p-2">
            <%= image_tag person_file_content_path(person_slug: entry.person.name, entry_id: entry.id), class: "mx-auto max-h-[70vh] w-auto rounded-xl object-contain" %>
          </div>
        <% else %>
          <iframe src="<%= person_file_content_path(person_slug: entry.person.name, entry_id: entry.id) %>" class="h-[70vh] w-full rounded-[1.5rem] border border-slate-200 bg-white" title="<%= entry.document_title.presence || document.filename.to_s %>"></iframe>
        <% end %>
      </div>
    </section>

    <aside class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5 xl:sticky xl:top-6 xl:max-h-[78vh] xl:overflow-y-auto">
      <div class="mb-4 flex items-start justify-between gap-3 border-b border-slate-200 pb-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("files.viewer.sidebar_label") %></p>
          <h3 class="mt-0.5 text-lg font-bold text-slate-950"><%= t("files.viewer.sidebar_title") %></h3>
        </div>
      </div>

      <div class="space-y-4">
        <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
          <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("files.viewer.document_meta") %></p>
          <p class="mt-2 text-sm font-semibold text-slate-900"><%= [entry.document_title, document_type_labels(entry).presence&.join(" + ")].compact.join(" • ") %></p>
          <% if entry.invoice_total_label.present? %>
            <p class="mt-1 text-sm font-semibold text-emerald-700"><%= t("entries.document_metadata.invoice_total") %>: <%= entry.invoice_total_label %></p>
          <% end %>
          <p class="mt-1 text-xs text-slate-500"><%= l(entry.display_time, format: :long) %></p>
          <p class="mt-1 text-xs text-slate-500"><%= document.filename.to_s %></p>
        </div>

        <% if entry.input.present? %>
          <div>
            <p class="mb-2 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("entries.raw_input.title") %></p>
            <p class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4 text-sm leading-relaxed text-slate-700 whitespace-pre-wrap break-words"><%= entry.input %></p>
          </div>
        <% end %>

        <div>
          <p class="mb-2 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("entries.parsed_data.title") %></p>
          <% if entry.fact_objects.present? %>
            <div class="rounded-2xl border border-slate-200 bg-white">
              <%= render "entries/data_details", entry: entry %>
            </div>
          <% else %>
            <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50/80 p-4 text-sm text-slate-500"><%= t("entries.parsed_data.empty") %></div>
          <% end %>
        </div>

        <div>
          <p class="mb-2 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500"><%= t("entries.db_row.toggle") %></p>
          <pre class="max-h-64 overflow-auto rounded-2xl border border-slate-200 bg-slate-950 p-4 text-xs leading-6 text-slate-200 whitespace-pre-wrap break-words"><%= JSON.pretty_generate(entry.extracted_data) %></pre>
        </div>
      </div>
    </aside>
  </section>
<% else %>
  <section class="rounded-[2rem] border border-dashed border-slate-300 bg-slate-50/70 p-6 text-center text-sm text-slate-500">
    <p class="font-medium text-slate-700"><%= t("files.viewer.empty") %></p>
  </section>
<% end %>
