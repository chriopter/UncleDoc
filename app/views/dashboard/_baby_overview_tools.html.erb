<% feeding_timer_started_at = baby_feeding_timer_started_at_for(person) %>
<% feeding_timer_side = baby_feeding_timer_side_for(person) %>
<% feeding_timer_elapsed = baby_feeding_timer_elapsed_label(feeding_timer_started_at) %>

<div class="rounded-[2rem] border border-pink-200 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
  <div class="mb-5 flex items-start justify-between gap-3">
    <div class="space-y-2">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-pink-600"><%= t("baby.badge") %></p>
      <h2 class="text-2xl font-bold text-slate-950"><%= t("baby.quick_actions.title") %></h2>
    </div>
  </div>

  <div class="space-y-4">
    <div class="rounded-[1.5rem] border border-emerald-200 bg-emerald-50/60 p-4" data-controller="feeding-mode" data-feeding-mode-default-value="breast">
      <div class="mb-3 flex items-center justify-between gap-3">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700"><%= t("baby.feeding.combined_title") %></p>
        <% if person.time_since_last_feeding %>
          <span class="whitespace-nowrap rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-800"><%= compact_time_ago_label(person.time_since_last_feeding) %></span>
        <% end %>
      </div>
      <% if feeding_timer_started_at %>
        <div class="mb-3">
          <span class="inline-flex rounded-full border border-emerald-200 bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-900"><%= t("baby.feeding.sides.#{feeding_timer_side}") %> · <%= feeding_timer_elapsed %></span>
        </div>
      <% end %>

      <div data-feeding-mode-target="panel" data-panel="breast">
        <div class="grid grid-cols-3 gap-2">
          <% if feeding_timer_started_at && feeding_timer_side == "left" %>
            <%= button_to person_baby_feeding_timer_path(person), method: :delete, class: "group rounded-2xl border border-emerald-300 bg-emerald-100 px-3 py-3 text-left text-sm font-semibold text-emerald-950 shadow-sm transition hover:bg-emerald-200" do %>
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-emerald-200 text-emerald-800">
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12.5 4.5 6.5 10l6 5.5" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 10h8" />
                </svg>
              </span>
              <div class="mt-2 flex items-center justify-between gap-2">
                <span><%= t("baby.feeding.sides.left") %></span>
                <span class="rounded-full border border-emerald-300 bg-white/70 px-2 py-0.5 text-[10px] font-bold text-emerald-900"><%= feeding_timer_elapsed %></span>
              </div>
            <% end %>
          <% elsif feeding_timer_started_at %>
            <button type="button" disabled class="rounded-2xl border border-slate-200 bg-slate-100 px-3 py-3 text-left text-sm font-semibold text-slate-500">
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-slate-200 text-slate-500">
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12.5 4.5 6.5 10l6 5.5" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 10h8" />
                </svg>
              </span>
              <span class="mt-2 block"><%= t("baby.feeding.sides.left") %></span>
            </button>
          <% else %>
            <%= button_to person_baby_feeding_timer_path(person, side: "left"), method: :post, class: "group rounded-2xl border border-emerald-200 bg-white px-3 py-3 text-left text-sm font-semibold text-emerald-900 transition hover:-translate-y-0.5 hover:bg-emerald-100" do %>
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-emerald-100 text-emerald-700 transition group-hover:bg-emerald-200">
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12.5 4.5 6.5 10l6 5.5" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 10h8" />
                </svg>
              </span>
              <span class="mt-2 block"><%= t("baby.feeding.sides.left") %></span>
            <% end %>
          <% end %>

          <% if feeding_timer_started_at && feeding_timer_side == "right" %>
            <%= button_to person_baby_feeding_timer_path(person), method: :delete, class: "group rounded-2xl border border-emerald-300 bg-emerald-100 px-3 py-3 text-left text-sm font-semibold text-emerald-950 shadow-sm transition hover:bg-emerald-200" do %>
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-emerald-200 text-emerald-800">
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 4.5 13.5 10l-6 5.5" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 10H5" />
                </svg>
              </span>
              <div class="mt-2 flex items-center justify-between gap-2">
                <span><%= t("baby.feeding.sides.right") %></span>
                <span class="rounded-full border border-emerald-300 bg-white/70 px-2 py-0.5 text-[10px] font-bold text-emerald-900"><%= feeding_timer_elapsed %></span>
              </div>
            <% end %>
          <% elsif feeding_timer_started_at %>
            <button type="button" disabled class="rounded-2xl border border-slate-200 bg-slate-100 px-3 py-3 text-left text-sm font-semibold text-slate-500">
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-slate-200 text-slate-500">
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 4.5 13.5 10l-6 5.5" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 10H5" />
                </svg>
              </span>
              <span class="mt-2 block"><%= t("baby.feeding.sides.right") %></span>
            </button>
          <% else %>
            <%= button_to person_baby_feeding_timer_path(person, side: "right"), method: :post, class: "group rounded-2xl border border-emerald-200 bg-white px-3 py-3 text-left text-sm font-semibold text-emerald-900 transition hover:-translate-y-0.5 hover:bg-emerald-100" do %>
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-emerald-100 text-emerald-700 transition group-hover:bg-emerald-200">
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 4.5 13.5 10l-6 5.5" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 10H5" />
                </svg>
              </span>
              <span class="mt-2 block"><%= t("baby.feeding.sides.right") %></span>
            <% end %>
          <% end %>

          <button type="button" class="group rounded-2xl border border-amber-200 bg-white px-3 py-3 text-left text-sm font-semibold text-amber-900 transition hover:-translate-y-0.5 hover:bg-amber-50" data-feeding-mode-target="button" data-panel="bottle" data-active-classes="bg-amber-100 border-amber-300 text-amber-900 shadow-sm -translate-y-0.5" data-inactive-classes="bg-white text-amber-900" data-action="feeding-mode#showPanel">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-amber-100 text-amber-700 transition group-hover:bg-amber-200">
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 3h4v2l1 1v8.5A2.5 2.5 0 0 1 10.5 17h-1A2.5 2.5 0 0 1 7 14.5V6l1-1V3Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 8h4" />
              </svg>
            </span>
            <span class="mt-2 block"><%= t("baby.feeding.modes.bottle") %></span>
          </button>
        </div>
      </div>

      <div data-feeding-mode-target="panel" data-panel="bottle" class="hidden">
        <div class="mb-2 grid grid-cols-3 gap-2">
          <button type="button" class="group rounded-2xl border border-emerald-200 bg-white px-3 py-3 text-left text-sm font-semibold text-emerald-900 transition hover:-translate-y-0.5 hover:bg-emerald-50" data-feeding-mode-target="button" data-panel="breast" data-active-classes="bg-emerald-100 border-emerald-300 text-emerald-900 shadow-sm -translate-y-0.5" data-inactive-classes="bg-white text-emerald-900" data-action="feeding-mode#showPanel">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-emerald-100 text-emerald-700 transition group-hover:bg-emerald-200">
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12.5 4.5 6.5 10l6 5.5" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 10h8" />
              </svg>
            </span>
            <span class="mt-2 block"><%= t("baby.feeding.sides.left") %></span>
          </button>
          <button type="button" class="group rounded-2xl border border-emerald-200 bg-white px-3 py-3 text-left text-sm font-semibold text-emerald-900 transition hover:-translate-y-0.5 hover:bg-emerald-50" data-feeding-mode-target="button" data-panel="breast" data-active-classes="bg-emerald-100 border-emerald-300 text-emerald-900 shadow-sm -translate-y-0.5" data-inactive-classes="bg-white text-emerald-900" data-action="feeding-mode#showPanel">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-emerald-100 text-emerald-700 transition group-hover:bg-emerald-200">
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 4.5 13.5 10l-6 5.5" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10H5" />
              </svg>
            </span>
            <span class="mt-2 block"><%= t("baby.feeding.sides.right") %></span>
          </button>
          <button type="button" class="group rounded-2xl border border-amber-200 bg-white px-3 py-3 text-left text-sm font-semibold text-amber-900 transition hover:-translate-y-0.5 hover:bg-amber-50" data-feeding-mode-target="button" data-panel="bottle" data-active-classes="bg-amber-100 border-amber-300 text-amber-900 shadow-sm -translate-y-0.5" data-inactive-classes="bg-white text-amber-900" data-action="feeding-mode#showPanel">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-amber-100 text-amber-700 transition group-hover:bg-amber-200">
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 3h4v2l1 1v8.5A2.5 2.5 0 0 1 10.5 17h-1A2.5 2.5 0 0 1 7 14.5V6l1-1V3Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 8h4" />
              </svg>
            </span>
            <span class="mt-2 block"><%= t("baby.feeding.modes.bottle") %></span>
          </button>
        </div>

        <%= form_with url: person_baby_bottle_action_path(person), class: "space-y-3" do |f| %>
          <div class="flex gap-2">
            <%= f.number_field :amount_ml, min: 1, step: 1, placeholder: "120", class: "block w-full rounded-2xl border-amber-200 bg-white px-4 py-3 text-sm focus:border-amber-500 focus:ring-amber-500" %>
            <%= f.submit t("baby.bottle.button"), class: "rounded-2xl bg-amber-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-amber-600" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="rounded-[1.5rem] border border-blue-200 bg-blue-50/60 p-4">
      <div class="mb-3 flex items-start justify-between gap-3">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-700"><%= t("baby.diaper.title") %></p>
        <% if person.time_since_last_diaper %>
          <span class="whitespace-nowrap rounded-full border border-blue-200 bg-white px-3 py-1 text-xs font-semibold text-blue-800"><%= compact_time_ago_label(person.time_since_last_diaper) %></span>
        <% end %>
      </div>
      <div class="grid grid-cols-3 gap-2">
        <%= button_to person_baby_diaper_action_path(person), params: { kind: "wet" }, class: "group rounded-2xl border border-blue-200 bg-white px-3 py-3 text-left text-sm font-semibold text-blue-900 transition hover:-translate-y-0.5 hover:bg-blue-100" do %>
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-blue-100 text-blue-700 transition group-hover:bg-blue-200">
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 3c2.3 2.8 3.8 4.7 3.8 6.6a3.8 3.8 0 1 1-7.6 0c0-1.9 1.5-3.8 3.8-6.6Z" />
            </svg>
          </span>
          <span class="mt-2 block"><%= t("baby.diaper.buttons.wet") %></span>
        <% end %>
        <%= button_to person_baby_diaper_action_path(person), params: { kind: "solid" }, class: "group rounded-2xl border border-blue-200 bg-white px-3 py-3 text-left text-sm font-semibold text-blue-900 transition hover:-translate-y-0.5 hover:bg-blue-100" do %>
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-blue-100 text-blue-700 transition group-hover:bg-blue-200">
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h8v8H6z" />
            </svg>
          </span>
          <span class="mt-2 block"><%= t("baby.diaper.buttons.solid") %></span>
        <% end %>
        <%= button_to person_baby_diaper_action_path(person), params: { kind: "both" }, class: "group rounded-2xl border border-blue-200 bg-gradient-to-br from-blue-500 to-blue-600 px-3 py-3 text-left text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:from-blue-600 hover:to-blue-700" do %>
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-white/20 text-white">
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 3c2.3 2.8 3.8 4.7 3.8 6.6a3.8 3.8 0 1 1-7.6 0c0-1.9 1.5-3.8 3.8-6.6Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 14h8" />
            </svg>
          </span>
          <span class="mt-2 block"><%= t("baby.diaper.buttons.both") %></span>
        <% end %>
      </div>
    </div>

  </div>
</div>
