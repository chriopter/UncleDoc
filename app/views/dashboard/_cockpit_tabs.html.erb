<% active_tab = local_assigns.fetch(:active_tab, "chat") %>

<nav class="flex w-fit max-w-full shrink-0 rounded-full border border-amber-100 bg-white/90 p-1 text-sm font-semibold shadow-sm ring-1 ring-black/5" aria-label="<%= t("dashboard.cockpit.tabs.label") %>">
  <%= link_to person_root_path(person_slug: person.name), class: "rounded-full px-4 py-2 transition #{active_tab == 'chat' ? 'bg-slate-950 text-white shadow-sm' : 'text-slate-600 hover:bg-amber-50 hover:text-slate-950'}" do %>
    <%= t("dashboard.cockpit.tabs.chat") %>
  <% end %>
  <%= link_to person_root_path(person_slug: person.name, tab: "overview"), class: "rounded-full px-4 py-2 transition #{active_tab == 'overview' ? 'bg-slate-950 text-white shadow-sm' : 'text-slate-600 hover:bg-amber-50 hover:text-slate-950'}" do %>
    <%= t("dashboard.cockpit.tabs.overview") %>
  <% end %>
</nav>
