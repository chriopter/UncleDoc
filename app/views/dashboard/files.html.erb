<%= turbo_stream_from [@person, :entries] %>

<section class="space-y-5">
  <div class="grid grid-cols-1 items-stretch gap-5 md:grid-cols-3">
    <%# Upload composer — left column %>
    <section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5 md:col-span-1 flex flex-col">
      <div class="mb-4 border-b border-slate-200 pb-3">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= t("files.upload_label") %></p>
        <h2 class="mt-0.5 text-lg font-bold text-slate-950"><%= t("files.upload_title") %></h2>
      </div>
      <%= render "entries/inline_form", entry: Entry.new, person: @person %>
    </section>

    <%# Header + filters — right column %>
    <section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5 md:col-span-2 flex flex-col">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex min-w-0 items-center gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-amber-100 text-sm font-black text-amber-800 ring-1 ring-amber-200/80">
            <%= @person.name.first.upcase %>
          </div>
          <div class="min-w-0">
            <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("files.label") %></p>
            <h1 class="truncate text-xl font-black tracking-tight text-slate-950"><%= t("files.title", name: @person.name) %></h1>
          </div>
        </div>

        <div class="flex items-center gap-2">
          <%= render "dashboard/files_stats", document_count: @document_count, document_entries: @document_entries %>
        </div>
      </div>

      <div class="mt-auto border-t border-slate-100 pt-4 mt-4">
        <p class="mb-2 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400"><%= t("entries.filters.label") %></p>
        <%= form_with url: person_files_path(person_slug: @person.name), method: :get, local: true, class: "flex flex-wrap items-end gap-3", data: { controller: "auto-submit" } do |form| %>
          <div>
            <%= form.label :year, t("files.filters.year"), class: "mb-1.5 block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500" %>
            <%= form.select :year,
                options_for_select([[t("files.filters.all_years"), nil]] + @available_file_filters[:years].map { |y| [y.to_s, y] }, params[:year]),
                {},
                class: "w-full rounded-xl border border-slate-200 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-400 focus:ring-2 focus:ring-amber-200",
                data: { action: "change->auto-submit#submit" } %>
          </div>

          <div>
            <%= form.label :doc_type, t("files.filters.doc_type"), class: "mb-1.5 block text-xs font-semibold uppercase tracking-[0.18em] text-slate-500" %>
            <%= form.select :doc_type,
                options_for_select(
                  [[t("files.filters.all_types"), nil]] + @available_file_filters[:types].map { |type| [t("files.document_types.#{type}", default: type.humanize), type] },
                  params[:doc_type]
                ),
                {},
                class: "w-full rounded-xl border border-slate-200 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-400 focus:ring-2 focus:ring-amber-200",
                data: { action: "change->auto-submit#submit" } %>
          </div>

          <div>
            <%= link_to t("entries.filters.reset"), person_files_path(person_slug: @person.name), class: "inline-flex rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-white hover:text-slate-950" %>
          </div>
        <% end %>
      </div>
    </section>
  </div>

  <div class="grid gap-5 xl:grid-cols-[minmax(0,0.95fr)_minmax(0,1.35fr)] xl:items-start">
    <section class="rounded-[2rem] border border-slate-200 bg-white p-5 ring-1 ring-black/5">
      <%= render "dashboard/files_list", document_entries: @document_entries, grouped_document_entries: @grouped_document_entries %>
    </section>

    <%= render "dashboard/document_viewer", entry: @selected_document_entry %>
  </div>
</section>
