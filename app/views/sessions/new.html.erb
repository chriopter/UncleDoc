<section class="mx-auto max-w-xl rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur md:p-8">
  <div class="space-y-6">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("auth.login.kicker") %></p>
      <h1 class="mt-2 text-3xl font-black tracking-tight text-slate-950"><%= t("auth.login.title") %></h1>
      <p class="mt-3 text-sm leading-6 text-slate-600"><%= t("auth.login.description") %></p>
    </div>

    <%= form_with url: session_url, class: "space-y-4" do |form| %>
      <div class="space-y-1.5">
        <%= form.label :email_address, t("auth.login.email_address"), class: "text-sm font-semibold text-slate-700" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: t("auth.login.email_placeholder"), value: params[:email_address], class: "w-full rounded-xl border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-500 focus:ring-2 focus:ring-amber-200" %>
      </div>

      <div class="space-y-1.5">
        <%= form.label :password, t("auth.login.password"), class: "text-sm font-semibold text-slate-700" %>
        <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: t("auth.login.password_placeholder"), maxlength: 72, class: "w-full rounded-xl border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-500 focus:ring-2 focus:ring-amber-200" %>
      </div>

      <div class="flex justify-end">
        <%= form.submit t("auth.login.submit"), class: "inline-flex items-center rounded-full bg-slate-950 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800" %>
      </div>
    <% end %>
  </div>
</section>
