<%# Standard widget card wrapper
  Required: id
  Optional: title, label, color (amber), dark (false), span (1/2/3), card_classes
%>
<% theme = widget_theme(local_assigns[:color] || "amber") %>
<% dark = local_assigns[:dark] %>
<% span_class = case local_assigns[:span].to_s
   when "2" then "md:col-span-2 xl:col-span-2"
   when "3" then "md:col-span-2 xl:col-span-3"
   else "" end %>

<div id="<%= local_assigns[:id] %>"
     class="rounded-[2rem] border p-5 shadow-sm ring-1 overflow-hidden sm:p-6
            <%= dark ? 'border-slate-200 bg-slate-950 text-white ring-black/5' : "#{theme[:border]} bg-white text-slate-900 #{theme[:ring]}" %>
            <%= span_class %> <%= local_assigns[:card_classes] %>">
  <% if local_assigns[:label] || local_assigns[:title] %>
    <div class="mb-4">
      <% if local_assigns[:label] %>
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] <%= dark ? theme[:label_dark] : theme[:label] %>"><%= label %></p>
      <% end %>
      <% if local_assigns[:title] %>
        <h3 class="mt-1 text-lg font-bold <%= dark ? 'text-white' : 'text-slate-950' %>"><%= title %></h3>
      <% end %>
    </div>
  <% end %>
  <%= yield %>
</div>
