<%# Shared Entries List Widget with AI Summary Button %>
<%# Usage: render "shared/entries_widget", person: person, entries: entries, log_summary: log_summary, log_summary_state: log_summary_state %>
<%= turbo_stream_from [person, :entries] %>

<div class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-sm ring-1 ring-black/5">
  <div class="mb-4 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-300"><%= t("dashboard.entries.label") %></p>
      <span class="rounded-full border border-amber-500/30 bg-amber-500/10 px-2.5 py-0.5 text-xs font-medium text-amber-300">
        <%= t(entries.count == 1 ? "dashboard.protocol.count" : "dashboard.protocol.count_plural", count: entries.count) %>
      </span>
    </div>
    <%= button_to person_log_summary_path(person_slug: person.name), method: :post, 
        class: "flex items-center gap-2 rounded-full border border-white/20 bg-white/5 px-3 py-1.5 text-xs font-medium text-amber-300 transition hover:bg-white/10 hover:text-amber-200",
        data: { turbo_stream: true } do %>
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z"/>
      </svg>
      <%= t("log_summary.button_short") %>
    <% end %>
  </div>

  <%= render "entries/protocol_list", entries: entries %>

  <%# AI Summary Output Area %>
  <%= turbo_frame_tag "log_summary_output" do %>
    <% if defined?(log_summary_state) && log_summary_state == :ready && log_summary.present? %>
      <div class="mt-6 rounded-xl border border-white/10 bg-white/5 p-4">
        <p class="text-sm font-semibold uppercase tracking-[0.15em] text-amber-300 mb-2"><%= t("log_summary.title") %></p>
        <p class="text-sm leading-relaxed text-white whitespace-pre-line"><%= log_summary %></p>
      </div>
    <% elsif defined?(log_summary_state) && log_summary_state.in?([:missing_model, :missing_api_key, :no_entries, :request_failed]) %>
      <div class="mt-6 rounded-xl border border-amber-500/20 bg-amber-500/10 px-4 py-3">
        <p class="text-sm text-amber-300">
          <% case log_summary_state %>
          <% when :missing_model %>
            <%= t("log_summary.states.missing_model") %>
          <% when :missing_api_key %>
            <%= t("log_summary.states.missing_api_key") %>
          <% when :no_entries %>
            <%= t("log_summary.states.no_entries") %>
          <% when :request_failed %>
            <%= t("log_summary.states.request_failed") %>
          <% end %>
        </p>
      </div>
    <% end %>
  <% end %>
</div>
