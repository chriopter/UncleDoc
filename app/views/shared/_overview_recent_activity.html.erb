<div id="overview_recent_activity" class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-sm ring-1 ring-black/5 <%= local_assigns[:card_classes] %>">
  <div class="mb-4 flex items-center justify-between gap-4">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-300"><%= t("person.overview.recent_activity") %></p>
      <h2 class="mt-1 text-2xl font-bold"><%= t("dashboard.entries.title", name: person.name) %></h2>
      <% if entries.any? %>
        <p class="mt-1 text-xs text-slate-400"><%= t("person.overview.stats.last_activity") %> <%= l(entries.first.display_time, format: :long) %></p>
      <% end %>
    </div>
    <div class="flex flex-col items-end gap-2">
      <div class="inline-flex rounded-full border border-white/10 bg-white/5 p-1 text-[11px] font-semibold text-slate-300">
        <%= link_to entry_sort_label("occurred"), person_overview_path(person_slug: person.name, sort: "occurred"), class: "rounded-full px-3 py-1 transition #{entry_sort_mode(local_assigns[:sort] || params) == 'occurred' ? 'bg-white text-slate-950 shadow-sm' : 'hover:bg-white/10'}" %>
        <%= link_to entry_sort_label("entered"), person_overview_path(person_slug: person.name, sort: "entered"), class: "rounded-full px-3 py-1 transition #{entry_sort_mode(local_assigns[:sort] || params) == 'entered' ? 'bg-white text-slate-950 shadow-sm' : 'hover:bg-white/10'}" %>
      </div>

      <%= link_to person_log_path(person_slug: person.name, sort: entry_sort_mode(local_assigns[:sort] || params)), class: "rounded-full border border-white/15 px-3 py-1.5 text-xs font-semibold text-amber-300 transition hover:bg-white/10 hover:text-amber-200" do %>
        <%= t("person.overview.view_log") %>
      <% end %>
    </div>
  </div>

  <% if entries.any? %>
    <div class="space-y-0">
      <% entries.limit(5).each do |recent_entry| %>
        <%= render "entries/compact_entry", entry: recent_entry %>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-2xl border border-dashed border-white/20 bg-white/5 px-4 py-10 text-center text-sm text-slate-300">
      <%= t("dashboard.protocol.empty") %>
    </div>
  <% end %>
</div>
