<% visible_entries = overview_recent_entries(person, sort_mode: "entered", period: "1w", limit: local_assigns[:entry_limit] || 5) %>

<%= render "shared/widget", id: "overview_recent_activity", color: "amber", card_classes: local_assigns[:card_classes] do %>
  <div class="mb-2 flex items-center justify-between">
    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700"><%= t("person.overview.recent_activity") %></p>
    <%= link_to t("person.overview.view_log"), person_log_path(person_slug: person.name, sort: "entered"), class: "text-[11px] font-semibold text-amber-700 hover:text-amber-900" %>
  </div>

  <% if visible_entries.any? %>
    <div class="space-y-0">
      <% visible_entries.each do |recent_entry| %>
        <%= render "entries/compact_entry", entry: recent_entry %>
      <% end %>
    </div>
  <% else %>
    <p class="py-6 text-center text-sm text-slate-400"><%= t("dashboard.protocol.empty") %></p>
  <% end %>
<% end %>
