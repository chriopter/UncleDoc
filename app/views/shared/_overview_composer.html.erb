<% composer_entry = local_assigns[:entry] || Entry.new(occurred_at: Time.current) %>

<%= render "shared/widget", id: "overview_composer", color: "amber", card_classes: "flex flex-col #{local_assigns[:card_classes]}" do %>
  <div class="mb-3 flex items-center gap-2">
    <h2 class="text-lg font-black tracking-tight text-slate-950"><%= person.name %></h2>
    <% if person.birth_date %>
      <span class="text-xs font-medium text-slate-400"><%= person_age_label(person.birth_date) %></span>
    <% end %>
    <% if person.baby_mode? %>
      <span class="rounded-full bg-pink-100 px-2 py-0.5 text-[10px] font-semibold text-pink-700"><%= t("baby.badge") %></span>
    <% end %>
  </div>
  <%= render "shared/overview_person_meta", person: person, entries: person.entries.recent_first %>
  <div class="flex flex-1 flex-col">
    <%= render "entries/form", entry: composer_entry, person: person %>
  </div>
<% end %>
