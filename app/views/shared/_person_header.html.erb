<%# Shared Person Header Widget - Compact Side-by-Side Layout %>
<%# Usage: render "shared/person_header", person: person, entry: entry %>
<div class="rounded-[2rem] border border-white/70 bg-white/90 p-4 sm:p-5 shadow-sm ring-1 ring-black/5 backdrop-blur">
  <div class="flex flex-col sm:flex-row sm:items-center gap-4">
    <%# Left: Person Info %>
    <div class="flex items-center gap-3 flex-shrink-0">
      <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-amber-100 text-amber-800 text-lg font-bold">
        <%= person.name.first.upcase %>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-700"><%= t("dashboard.protocol.label") %></p>
        <h1 class="text-xl font-black tracking-tight text-slate-950"><%= person.name %></h1>
      </div>
    </div>

    <%# Right: Add Entry Form %>
    <div class="flex-1 sm:border-l sm:border-slate-200 sm:pl-4">
      <%= render "entries/inline_form", entry: entry, person: person %>
    </div>
  </div>
</div>
