<%= turbo_stream.replace "overview_baby_actions" do %>
  <%= render "shared/baby_actions_widget", person: @person, card_classes: "h-full" %>
<% end %>

<%= turbo_stream.replace "overview_baby_tracking_feeding" do %>
  <%= render "shared/baby_feeding_tracker_widget", person: @person, card_classes: "flex-1" %>
<% end %>

<%= turbo_stream.replace "overview_baby_tracking_sleep" do %>
  <%= render "shared/baby_sleep_tracker_widget", person: @person, card_classes: "flex-1" %>
<% end %>

<%= turbo_stream.replace "overview_baby_tracking_diaper" do %>
  <%= render "shared/baby_diaper_tracker_widget", person: @person, card_classes: "flex-1" %>
<% end %>

<%= turbo_stream.replace "overview_recent_activity" do %>
  <%= render "shared/overview_recent_activity", person: @person, entries: @person.entries.recent_first, sort: params[:sort], card_classes: "h-full", entry_limit: 5 %>
<% end %>

<%= turbo_stream.replace "entries_list" do %>
  <%= render "entries/protocol_list", entries: @person.entries.recent_first %>
<% end %>

<%= turbo_stream.replace "overview_person_meta" do %>
  <%= render "shared/overview_person_meta", person: @person, entries: @person.entries.recent_first %>
<% end %>

<%= turbo_stream.replace "overview_planning" do %>
  <%= render "shared/planning_widget", person: @person, card_classes: "h-full" %>
<% end %>

<%= turbo_stream.replace "overview_weight_activity" do %>
  <%= render "shared/weight_activity_widget", person: @person, card_classes: "h-full" %>
<% end %>

<%= turbo_stream.replace "overview_height_activity" do %>
  <%= render "shared/height_activity_widget", person: @person, card_classes: "h-full" %>
<% end %>
