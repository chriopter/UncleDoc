<section class="space-y-6">
  <%= turbo_stream_from [person, :entries] %>

  <% bento_grid_classes = "grid gap-6 md:grid-cols-2 xl:grid-cols-6 xl:auto-rows-[8.5rem] xl:items-stretch" %>
  <% one_third_card = "xl:col-span-2 h-full" %>
  <% baby_primary_widget_classes = "#{one_third_card} xl:row-span-3" %>
  <% chart_widget_classes = "#{one_third_card} xl:row-span-2" %>

  <div class="<%= bento_grid_classes %>">
    <%= render "shared/baby_actions_widget", person: person, card_classes: baby_primary_widget_classes %>
    <%= render "shared/baby_feeding_tracker_widget", person: person, card_classes: baby_primary_widget_classes %>
    <%= render "shared/baby_diaper_tracker_widget", person: person, card_classes: baby_primary_widget_classes %>
    <%= render "shared/baby_sleep_tracker_widget", person: person, card_classes: baby_primary_widget_classes %>
    <%= render "shared/overview_recent_activity", person: person, entries: entries, sort: local_assigns[:sort], card_classes: "xl:col-span-4 xl:row-span-3 h-full", entry_limit: 5 %>

    <%= render "shared/weight_activity_widget", person: person, card_classes: chart_widget_classes %>
    <%= render "shared/height_activity_widget", person: person, card_classes: chart_widget_classes %>
  </div>
</section>
