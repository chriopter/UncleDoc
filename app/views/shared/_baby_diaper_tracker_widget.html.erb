<% recent_diapers = person.recent_diapers(3) %>
<%= render "shared/widget", id: "overview_baby_tracking_diaper", label: t("baby.badge"), title: t("baby.diaper.title"), color: "blue", card_classes: local_assigns[:card_classes] do %>
  <section class="flex flex-col rounded-[1.5rem] bg-gradient-to-br from-blue-50/60 via-white to-cyan-50/60 p-4">
    <% if person.time_since_last_diaper %>
      <div class="mb-4 flex justify-end">
        <span class="rounded-full bg-blue-100/80 px-3 py-1 text-[11px] font-semibold text-blue-800"><%= compact_time_ago_label(person.time_since_last_diaper) %></span>
      </div>
    <% end %>
    <% if recent_diapers.any? %>
      <div class="space-y-1.5 rounded-2xl bg-white/70 px-3 py-3 text-xs font-medium text-blue-900">
        <% recent_diapers.each do |entry| %>
          <div><%= l(entry.display_time, format: entry.display_time.to_date == Time.zone.today ? "%H:%M" : "%-d %b %H:%M") %>: <span class="text-blue-600"><%= diaper_event_label(entry) %></span></div>
        <% end %>
      </div>
    <% end %>
    <%= render "shared/baby_activity_chart", person: person, type: :diaper %>
  </section>
<% end %>
