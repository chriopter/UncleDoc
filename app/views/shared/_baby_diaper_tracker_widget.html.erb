<div id="overview_baby_tracking_diaper" class="rounded-[2rem] border border-blue-200 bg-white/95 p-6 text-slate-950 shadow-sm ring-1 ring-black/5 backdrop-blur <%= local_assigns[:card_classes] || chart_widget_card_classes %>">
  <section class="flex h-full flex-col rounded-[1.5rem] border border-blue-200 bg-gradient-to-br from-blue-50 via-white to-cyan-50 p-4">
    <div class="mb-4 flex items-start justify-between gap-3">
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-blue-600"><%= t("baby.badge") %></p>
        <h3 class="mt-1 text-lg font-bold text-slate-950"><%= t("baby.diaper.title") %></h3>
      </div>
      <% if person.time_since_last_diaper %>
        <span class="rounded-full border border-blue-200 bg-white px-3 py-1 text-[11px] font-semibold text-blue-800"><%= compact_time_ago_label(person.time_since_last_diaper) %></span>
      <% end %>
    </div>

    <div class="mt-auto grid grid-cols-3 gap-2">
      <%= button_to person_baby_diaper_action_path(person), params: { kind: "wet" }, class: "rounded-2xl border border-blue-200 bg-white px-3 py-3 text-left text-sm font-semibold text-blue-900 transition hover:bg-blue-100" do %>
        <span class="block"><%= t("baby.diaper.buttons.wet") %></span>
        <span class="mt-1 block text-[11px] text-blue-600"><%= t("entries.data_values.wet") %></span>
      <% end %>
      <%= button_to person_baby_diaper_action_path(person), params: { kind: "solid" }, class: "rounded-2xl border border-blue-200 bg-white px-3 py-3 text-left text-sm font-semibold text-blue-900 transition hover:bg-blue-100" do %>
        <span class="block"><%= t("baby.diaper.buttons.solid") %></span>
        <span class="mt-1 block text-[11px] text-blue-600"><%= t("entries.data_values.solid") %></span>
      <% end %>
      <%= button_to person_baby_diaper_action_path(person), params: { kind: "both" }, class: "rounded-2xl border border-blue-200 bg-gradient-to-br from-blue-500 to-blue-600 px-3 py-3 text-left text-sm font-semibold text-white transition hover:from-blue-600 hover:to-blue-700" do %>
        <span class="block"><%= t("baby.diaper.buttons.both") %></span>
        <span class="mt-1 block text-[11px] text-blue-100"><%= t("entries.data_values.wet") %> + <%= t("entries.data_values.solid") %></span>
      <% end %>
    </div>
  </section>
</div>
