<% todos = todo_entries(person) %>
<%= render "shared/widget", id: "overview_todos", label: t("entries.data_labels.todo"), title: t("person.overview.todos.title"), color: "emerald", dark: true, card_classes: local_assigns[:card_classes] do %>
  <section class="flex h-full flex-col rounded-[1.5rem] border border-emerald-300/20 bg-emerald-400/10 p-4">
    <% if todos.present? %>
      <div class="max-h-[22rem] space-y-2 overflow-y-auto pr-1">
        <% todos.each do |entry| %>
          <div class="flex items-start gap-3 rounded-2xl border border-white/10 bg-white/5 px-3 py-3 <%= entry.todo_done? ? 'opacity-60' : '' %>">
            <%= button_to toggle_todo_person_entry_path(entry.person, entry), method: :patch, class: "mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full border #{entry.todo_done? ? 'border-emerald-300 bg-emerald-300 text-slate-950' : 'border-white/20 bg-transparent text-white'}" do %>
              <% if entry.todo_done? %>
                <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8.5 6.2 11.5 13 4.5"/></svg>
              <% end %>
            <% end %>
            <div class="min-w-0 flex-1">
              <div class="text-sm font-semibold text-white"><%= entry.todo_title || entry.fact_summary %></div>
              <% if entry.todo_data["due_at"].present? %>
                <div class="mt-1 text-xs text-slate-300"><%= entry.todo_data["due_at"] %></div>
              <% elsif entry.todo_done_at.present? %>
                <div class="mt-1 text-xs text-slate-300"><%= t("person.overview.todos.done_at", time: l(entry.todo_done_at, format: :long)) %></div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="flex flex-1 items-center justify-center rounded-2xl border border-dashed border-emerald-300/20 bg-slate-950/30 px-4 py-10 text-center text-sm text-slate-300">
        <%= t("person.overview.todos.empty") %>
      </div>
    <% end %>
  </section>
<% end %>
