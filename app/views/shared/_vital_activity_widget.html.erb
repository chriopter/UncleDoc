<% current_range = overview_period_mode(params, type) %>
<% series = vital_activity_series(person, type, period: current_range) %>
<% color = case type.to_s
  when "temperature" then "rose"
  when "pulse" then "orange"
  else "sky"
  end %>
<% wt = widget_theme(color) %>
<%= render "shared/widget", id: "overview_#{type}_activity", label: t("entries.data_labels.#{type}"), title: t("person.overview.vitals.#{type}.title"), color: color, card_classes: local_assigns[:card_classes] do %>
  <div class="mb-3 flex items-center justify-between">
    <div class="inline-flex rounded-full border border-slate-200 bg-white/80 p-1 text-[11px] font-semibold text-slate-600">
      <% overview_period_options.each do |label, value| %>
        <%= link_to label, person_overview_path(person_slug: person.name, **overview_widget_params("#{type}_range": value)), class: "rounded-full px-3 py-1 transition #{current_range == value ? 'bg-white text-slate-950 shadow-sm' : 'hover:bg-white'}", data: { turbo_preserve_scroll: true } %>
      <% end %>
    </div>
    <% if series.present? %>
      <% latest = series.last %>
      <div class="text-[10px] font-semibold text-slate-500">
        <% if latest[:secondary] %>
          <%= latest[:value].to_i %>/<%= latest[:secondary].to_i %> <%= latest[:unit] %>
        <% else %>
          <%= number_with_precision(latest[:value], precision: latest[:value] % 1 == 0 ? 0 : 1, strip_insignificant_zeros: true) %> <%= latest[:unit] %>
        <% end %>
      </div>
    <% end %>
  </div>
  <% if series.present? %>
    <%= render "shared/line_chart", series: series, color: color, gradient_id: type.to_s %>
  <% else %>
    <div class="flex min-h-40 items-center justify-center rounded-2xl border border-dashed <%= wt[:border] %> <%= wt[:bg_accent] %> px-4 py-10 text-center text-sm text-slate-500"><%= t("person.overview.vitals.empty") %></div>
  <% end %>
<% end %>
