<% current_range = overview_period_mode(params, type) %>
<% series = vital_activity_series(person, type, period: current_range) %>
<% theme = case type.to_s
when "temperature"
  { label: "text-rose-700", border: "border-rose-200", bg: "bg-rose-50/50", line: ["#ef4444", "#fb7185", "#fecdd3"], point: "#fb7185" }
when "pulse"
  { label: "text-orange-700", border: "border-orange-200", bg: "bg-orange-50/50", line: ["#f97316", "#fb923c", "#fed7aa"], point: "#fb923c" }
else
  { label: "text-sky-700", border: "border-sky-200", bg: "bg-sky-50/50", line: ["#0284c7", "#38bdf8", "#bae6fd"], point: "#38bdf8" }
end %>
<% if series.present? %>
  <% min_value = series.map { |point| point[:value] }.min %>
  <% max_value = series.map { |point| point[:value] }.max %>
  <% latest = series.last %>
  <% line_points = weight_activity_line_points(series) %>
  <% plot_points = weight_activity_plot_points(series) %>
  <div id="overview_<%= type %>_activity" class="rounded-[2rem] border <%= theme[:border] %> bg-white p-6 text-slate-900 shadow-sm ring-1 ring-slate-100 <%= local_assigns[:card_classes] %>">
    <section class="flex flex-col gap-4 rounded-[1.5rem] border <%= theme[:border] %> <%= theme[:bg] %> p-4">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] <%= theme[:label] %>"><%= t("entries.data_labels.#{type}") %></p>
          <h3 class="mt-1 text-lg font-bold text-slate-950"><%= t("person.overview.vitals.#{type}.title") %></h3>
        </div>
        <div class="sm:text-right">
          <div class="mb-2 inline-flex rounded-full border border-slate-200 bg-white/80 p-1 text-[11px] font-semibold text-slate-600">
            <% overview_period_options.each do |label, value| %>
              <%= link_to label, person_overview_path(person_slug: person.name, **overview_widget_params("#{type}_range": value)), class: "rounded-full px-3 py-1 transition #{current_range == value ? 'bg-white text-slate-950 shadow-sm' : 'hover:bg-white'}" %>
            <% end %>
          </div>
          <div class="text-[10px] font-semibold text-slate-500">
            <% if latest[:secondary] %>
              <%= latest[:value].to_i %>/<%= latest[:secondary].to_i %> <%= latest[:unit] %>
            <% else %>
              <%= number_with_precision(latest[:value], precision: latest[:value] % 1 == 0 ? 0 : 1, strip_insignificant_zeros: true) %> <%= latest[:unit] %>
            <% end %>
          </div>
        </div>
      </div>

      <div class="rounded-2xl border <%= theme[:border] %> <%= theme[:bg] %> p-3">
        <div class="relative h-32">
          <div class="absolute inset-0 grid grid-rows-4">
            <% 4.times do %><div class="border-b <%= theme[:border] %> last:border-b-0"></div><% end %>
          </div>
          <svg viewBox="0 0 100 60" preserveAspectRatio="none" class="relative h-full w-full">
            <defs>
              <linearGradient id="<%= type %>-line-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="<%= theme[:line][0] %>" />
                <stop offset="55%" stop-color="<%= theme[:line][1] %>" />
                <stop offset="100%" stop-color="<%= theme[:line][2] %>" />
              </linearGradient>
            </defs>
            <polyline fill="none" stroke="url(#<%= type %>-line-gradient)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" points="<%= line_points %>" />
            <% plot_points.each do |point| %>
              <circle cx="<%= point[:x] %>" cy="<%= point[:y] %>" r="2.3" fill="#ffffff" stroke="<%= theme[:point] %>" stroke-width="1.3" />
            <% end %>
          </svg>
        </div>
        <div class="mt-2 grid gap-2" style="grid-template-columns: repeat(<%= series.length %>, minmax(0, 1fr));">
          <% series.each do |point| %>
            <div class="text-center">
              <div class="text-[11px] font-semibold text-slate-900">
                <% if point[:secondary] %>
                  <%= point[:value].to_i %>/<%= point[:secondary].to_i %>
                <% else %>
                  <%= number_with_precision(point[:value], precision: point[:value] % 1 == 0 ? 0 : 1, strip_insignificant_zeros: true) %>
                <% end %>
              </div>
              <div class="mt-1 text-[10px] font-semibold text-slate-500"><%= point[:short_label] %></div>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  </div>
<% else %>
  <div id="overview_<%= type %>_activity" class="rounded-[2rem] border <%= theme[:border] %> bg-white p-6 text-slate-900 shadow-sm ring-1 ring-slate-100 <%= local_assigns[:card_classes] %>">
    <section class="flex flex-col gap-4 rounded-[1.5rem] border <%= theme[:border] %> <%= theme[:bg] %> p-4">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] <%= theme[:label] %>"><%= t("entries.data_labels.#{type}") %></p>
          <h3 class="mt-1 text-lg font-bold text-slate-950"><%= t("person.overview.vitals.#{type}.title") %></h3>
        </div>
        <div class="inline-flex rounded-full border border-slate-200 bg-white/80 p-1 text-[11px] font-semibold text-slate-600">
          <% overview_period_options.each do |label, value| %>
            <%= link_to label, person_overview_path(person_slug: person.name, **overview_widget_params("#{type}_range": value)), class: "rounded-full px-3 py-1 transition #{current_range == value ? 'bg-white text-slate-950 shadow-sm' : 'hover:bg-white'}" %>
          <% end %>
        </div>
      </div>
      <div class="flex min-h-40 items-center justify-center rounded-2xl border border-dashed <%= theme[:border] %> <%= theme[:bg] %> px-4 py-10 text-center text-sm text-slate-500"><%= t("person.overview.vitals.empty") %></div>
    </section>
  </div>
<% end %>
