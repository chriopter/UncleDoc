<section class="space-y-6">
  <%= turbo_stream_from [person, :entries] %>

  <div class="grid gap-6 xl:grid-cols-3 xl:items-start">
    <div class="group rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
      <div class="space-y-6">
        <div>
          <div class="mb-5 flex items-start justify-between gap-4">
            <div class="flex items-center gap-4">
              <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-amber-100 text-xl font-black text-amber-800 shadow-inner">
                <%= person.name.first.upcase %>
              </div>
              <div>
                <h2 class="text-2xl font-bold text-slate-950"><%= person.name %> <span class="text-lg font-medium text-slate-500"><%= person_age_label(person.birth_date) if person.birth_date %></span></h2>
              </div>
            </div>

            <%= link_to settings_path(section: "users"), class: "mt-1 inline-flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full text-slate-300 transition hover:bg-slate-100 hover:text-slate-600 xl:opacity-0 xl:group-hover:opacity-100", aria: { label: t("person.overview.edit_person") }, title: t("person.overview.edit_person") do %>
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317a1.724 1.724 0 0 1 3.35 0 1.724 1.724 0 0 0 2.573 1.066 1.724 1.724 0 0 1 2.899 1.675 1.724 1.724 0 0 0 1.506 2.186 1.724 1.724 0 0 1 0 3.512 1.724 1.724 0 0 0-1.506 2.186 1.724 1.724 0 0 1-2.9 1.675 1.724 1.724 0 0 0-2.572 1.066 1.724 1.724 0 0 1-3.35 0 1.724 1.724 0 0 0-2.573-1.066 1.724 1.724 0 0 1-2.899-1.675 1.724 1.724 0 0 0-1.506-2.186 1.724 1.724 0 0 1 0-3.512 1.724 1.724 0 0 0 1.506-2.186 1.724 1.724 0 0 1 2.9-1.675 1.724 1.724 0 0 0 2.572-1.066Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 15.75A3.75 3.75 0 1 0 12 8.25a3.75 3.75 0 0 0 0 7.5Z" />
              </svg>
            <% end %>
          </div>

          <%= render "shared/overview_person_meta", person: person, entries: entries %>
        </div>

        <div class="border-t border-slate-200 pt-6">
          <%= render "entries/form", entry: entry, person: person %>
        </div>
      </div>
    </div>

    <% if person.baby_mode? %>
      <%= render "dashboard/baby_overview_tools", person: person %>
    <% else %>
      <%= render "shared/overview_recent_activity", person: person, entries: entries, sort: local_assigns[:sort], card_classes: "xl:col-span-2" %>
    <% end %>
  </div>

  <% if person.baby_mode? %>
    <%= render "shared/overview_recent_activity", person: person, entries: entries, sort: local_assigns[:sort] %>
  <% end %>
</section>
