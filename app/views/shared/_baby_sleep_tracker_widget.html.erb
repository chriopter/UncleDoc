<% recent_sleep_sessions = person.recent_sleep_sessions(3) %>

<div id="overview_baby_tracking_sleep" class="rounded-[2rem] border border-indigo-200 bg-white/95 p-6 text-slate-950 shadow-sm ring-1 ring-black/5 backdrop-blur <%= local_assigns[:card_classes] || 'xl:col-span-2 xl:row-span-3 h-full' %>">
  <section class="flex h-full flex-col rounded-[1.5rem] border border-indigo-200 bg-gradient-to-br from-indigo-50 via-white to-violet-50 p-4">
    <div class="mb-4 flex items-start justify-between gap-3">
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-indigo-600"><%= t("baby.badge") %></p>
        <h3 class="mt-1 text-lg font-bold text-slate-950"><%= t("baby.sleep.title") %></h3>
      </div>
      <% if person.time_since_last_sleep %>
        <span class="rounded-full border border-indigo-200 bg-white px-3 py-1 text-[11px] font-semibold text-indigo-800"><%= compact_time_ago_label(person.time_since_last_sleep) %></span>
      <% end %>
    </div>

    <% if recent_sleep_sessions.any? %>
      <div class="space-y-1.5 rounded-2xl border border-indigo-100 bg-white/80 px-3 py-3 text-xs font-medium text-indigo-900">
        <% recent_sleep_sessions.each do |entry| %>
          <% duration_minutes = entry.sleep_duration_minutes %>
          <% started_at = duration_minutes.present? ? entry.display_time - duration_minutes.minutes : entry.display_time %>
          <div>
            <span><%= feeding_session_label(started_at, entry.display_time) %></span>
            <% if duration_minutes.present? %>
              <span class="text-indigo-600">: <%= t("baby.sleep.timer.duration", duration: duration_minutes) %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= render "shared/baby_activity_chart", person: person, type: :sleep %>
  </section>
</div>
