<% sleep_timer_started_at = baby_sleep_timer_started_at_for(person) %>
<% sleep_timer_elapsed = baby_sleep_timer_elapsed_label(sleep_timer_started_at) %>

<div id="overview_baby_tracking_sleep" class="rounded-[2rem] border border-indigo-200 bg-white/95 p-6 text-slate-950 shadow-sm ring-1 ring-black/5 backdrop-blur <%= local_assigns[:card_classes] || chart_widget_card_classes %>">
  <section class="flex h-full flex-col rounded-[1.5rem] border border-indigo-200 bg-gradient-to-br from-indigo-50 via-white to-violet-50 p-4">
    <div class="mb-4 flex items-start justify-between gap-3">
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-indigo-600"><%= t("baby.badge") %></p>
        <h3 class="mt-1 text-lg font-bold text-slate-950"><%= t("baby.sleep.title") %></h3>
      </div>
      <% if person.time_since_last_sleep %>
        <span class="rounded-full border border-indigo-200 bg-white px-3 py-1 text-[11px] font-semibold text-indigo-800"><%= compact_time_ago_label(person.time_since_last_sleep) %></span>
      <% end %>
    </div>

    <% if sleep_timer_started_at %>
      <div class="mb-3 rounded-2xl border border-indigo-200 bg-indigo-100 px-3 py-2 text-sm font-semibold text-indigo-950 shadow-sm">
        <div><%= t("baby.sleep.timer.running_now") %> · <%= sleep_timer_elapsed %></div>
        <div class="mt-1 text-[11px] font-medium text-indigo-700"><%= l(sleep_timer_started_at, format: :short) %></div>
      </div>
      <%= button_to person_baby_sleep_timer_path(person), method: :delete, class: "mt-auto rounded-2xl border border-indigo-300 bg-indigo-100 px-4 py-4 text-left text-sm font-semibold text-indigo-950 transition hover:bg-indigo-200" do %>
        <span class="block"><%= t("baby.sleep.timer.stop") %></span>
        <span class="mt-1 block text-[11px] text-indigo-700"><%= sleep_timer_elapsed %></span>
      <% end %>
    <% else %>
      <%= button_to person_baby_sleep_timer_path(person), method: :post, class: "mt-auto rounded-2xl border border-indigo-200 bg-white px-4 py-4 text-left text-sm font-semibold text-indigo-900 transition hover:bg-indigo-100" do %>
        <span class="block"><%= t("baby.sleep.timer.start") %></span>
        <span class="mt-1 block text-[11px] text-indigo-600"><%= t("baby.sleep.timer.start_hint") %></span>
      <% end %>
    <% end %>
  </section>
</div>
