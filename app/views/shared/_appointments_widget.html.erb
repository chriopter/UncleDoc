<% appointments = appointment_entries(person) %>
<%= render "shared/widget", id: "overview_appointments", label: t("entries.data_labels.appointment"), title: t("person.overview.appointments.title"), color: "amber", dark: true, card_classes: local_assigns[:card_classes] do %>
  <section class="flex h-full flex-col rounded-[1.5rem] border border-amber-300/20 bg-amber-400/10 p-4">
    <% if appointments.present? %>
      <div class="space-y-2">
        <% appointments.each do |entry| %>
          <div class="rounded-2xl border border-white/10 bg-white/5 px-3 py-3">
            <div class="text-xs font-semibold uppercase tracking-[0.14em] text-amber-200"><%= t("person.overview.appointments.scheduled_for", time: l(entry.appointment_calendar_time, format: :long)) %></div>
            <% if entry.appointment_logged_at.to_date != entry.appointment_calendar_time.to_date %>
              <div class="mt-1 text-[11px] text-amber-100/80"><%= t("person.overview.appointments.logged_on", date: l(entry.appointment_logged_at.to_date, format: :long)) %></div>
            <% end %>
            <div class="mt-1 text-sm font-semibold text-white"><%= entry.fact_summary.presence || entry.appointment_title %></div>
            <% if entry.appointment_data["location"].present? %>
              <div class="mt-1 text-xs text-slate-300"><%= entry.appointment_data["location"] %></div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="flex flex-1 items-center justify-center rounded-2xl border border-dashed border-amber-300/20 bg-slate-950/30 px-4 py-10 text-center text-sm text-slate-300">
        <%= t("person.overview.appointments.empty") %>
      </div>
    <% end %>
  </section>
<% end %>
