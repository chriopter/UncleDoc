<% current_range = overview_period_mode(params, type) %>
<% series = baby_activity_series(person, type, period: current_range) %>
<% max_count = series.map { |point| point[:count] }.max.to_i %>
<% theme = case type
when :feeding
  {
    border: "border-emerald-200",
    bg: "bg-white/80",
    label: "text-emerald-700",
    range: "text-emerald-700",
    active_range: "bg-emerald-600 text-white shadow-sm",
    bar_shell: "bg-emerald-100",
    bar: "from-emerald-500 via-emerald-400 to-emerald-300",
    day: "text-emerald-900",
    subday: "text-emerald-600"
  }
when :sleep
  {
    border: "border-indigo-200",
    bg: "bg-white/80",
    label: "text-indigo-700",
    range: "text-indigo-700",
    active_range: "bg-indigo-600 text-white shadow-sm",
    bar_shell: "bg-indigo-100",
    bar: "from-indigo-500 via-violet-400 to-fuchsia-300",
    day: "text-indigo-900",
    subday: "text-indigo-600"
  }
else
  {
    border: "border-blue-200",
    bg: "bg-white/80",
    label: "text-blue-700",
    range: "text-blue-700",
    active_range: "bg-blue-600 text-white shadow-sm",
    bar_shell: "bg-blue-100",
    bar: "from-blue-500 via-sky-400 to-cyan-300",
    day: "text-blue-900",
    subday: "text-blue-600"
  }
end %>

<div class="mt-4 rounded-2xl border <%= theme[:border] %> <%= theme[:bg] %> p-3">
  <div class="mb-3 flex items-start justify-between gap-3">
    <div>
      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] <%= theme[:label] %>"><%= t("baby.activity.label") %></p>
      <p class="mt-1 text-sm font-semibold text-slate-950"><%= t("baby.activity.#{type}_title") %></p>
    </div>
    <div class="inline-flex rounded-full border border-black/5 bg-white p-1 text-[11px] font-semibold <%= theme[:range] %>">
      <% overview_period_options.each do |label, value| %>
        <%= link_to label, person_widgets_path(person, "#{type}_range": value), class: "rounded-full px-3 py-1 transition #{current_range == value ? theme[:active_range] : 'hover:bg-black/5'}" %>
      <% end %>
    </div>
  </div>

  <div class="grid gap-2" style="grid-template-columns: repeat(<%= series.length %>, minmax(0, 1fr));">
    <% series.each do |point| %>
      <div class="flex flex-col items-center gap-1.5">
        <div class="text-[11px] font-semibold text-slate-950"><%= point[:count] %></div>
        <div class="flex h-20 w-full items-end justify-center rounded-2xl <%= theme[:bar_shell] %> px-2 py-2">
          <div class="w-full rounded-xl bg-gradient-to-t <%= theme[:bar] %>" style="height: <%= baby_activity_bar_height(point[:count], max_count) %>%"></div>
        </div>
        <div class="text-center">
          <div class="text-[11px] font-semibold <%= theme[:day] %>"><%= point[:day_label] %></div>
          <div class="text-[10px] <%= theme[:subday] %>"><%= point[:short_label] %></div>
        </div>
      </div>
    <% end %>
  </div>
</div>
