<%# Shared line chart
  Required: series, color (string matching chart_theme keys)
  Optional: gradient_id (unique id for SVG gradient, defaults to color)
  series items: { value:, short_label:, unit:, secondary: (optional) }
%>
<% ct = chart_theme(color) %>
<% plot_points = weight_activity_plot_points(series) %>
<% smooth_line = chart_smooth_path(plot_points) %>
<% area_fill = chart_area_path(plot_points) %>
<% gid = local_assigns[:gradient_id] || color %>

<div class="rounded-2xl <%= ct[:bg] %> p-3">
  <div class="relative h-28">
    <%# Grid lines %>
    <div class="pointer-events-none absolute inset-x-0 inset-y-2 flex flex-col justify-between">
      <% 3.times do %><div class="h-px w-full bg-slate-900/[0.04]"></div><% end %>
    </div>
    <%# SVG for line and area only — no circles here to avoid distortion %>
    <svg viewBox="0 0 100 60" preserveAspectRatio="none" class="absolute inset-0 h-full w-full">
      <defs>
        <linearGradient id="<%= gid %>-line-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="<%= ct[:gradient][0] %>" />
          <stop offset="100%" stop-color="<%= ct[:gradient][1] %>" />
        </linearGradient>
        <linearGradient id="<%= gid %>-area-gradient" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="<%= ct[:gradient][1] %>" stop-opacity="0.12" />
          <stop offset="100%" stop-color="<%= ct[:gradient][2] %>" stop-opacity="0" />
        </linearGradient>
      </defs>
      <path d="<%= area_fill %>" fill="url(#<%= gid %>-area-gradient)" />
      <path d="<%= smooth_line %>" fill="none" stroke="url(#<%= gid %>-line-gradient)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke" />
    </svg>
    <%# Dots as HTML elements — always perfectly round %>
    <% plot_points.each do |point| %>
      <div class="absolute size-[7px] -translate-x-1/2 -translate-y-1/2 rounded-full border-2 border-white bg-[--dot-color] shadow-sm shadow-[--dot-color]/25"
           style="left: <%= point[:x] %>%; top: <%= (point[:y] / 60.0 * 100).round(2) %>%; --dot-color: <%= ct[:point] %>;"></div>
    <% end %>
  </div>
  <div class="mt-2 grid gap-1" style="grid-template-columns: repeat(<%= series.length %>, minmax(0, 1fr));">
    <% series.each do |point| %>
      <div class="text-center">
        <div class="text-[11px] font-semibold text-slate-900">
          <% if point[:secondary] %>
            <%= point[:value].to_i %>/<%= point[:secondary].to_i %>
          <% else %>
            <%= number_with_precision(point[:value], precision: point[:value] % 1 == 0 ? 0 : 1, strip_insignificant_zeros: true) %>
            <span class="text-[10px] font-medium <%= ct[:label_color] %>"><%= point[:unit] %></span>
          <% end %>
        </div>
        <div class="mt-0.5 text-[10px] text-slate-400"><%= point[:short_label] %></div>
      </div>
    <% end %>
  </div>
</div>
