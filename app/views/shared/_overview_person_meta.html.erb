<div id="overview_person_meta">
  <div class="space-y-3 text-sm text-slate-600">
    <div class="flex flex-wrap gap-2 pt-2">
      <% if person.baby_mode? %>
        <span class="rounded-full border border-pink-200 bg-pink-50 px-3 py-1 text-xs font-semibold text-pink-700"><%= t("baby.badge") %></span>
      <% end %>
      <% pending_count = entries.count(&:pending_parse?) %>
      <% if pending_count.positive? %>
        <span class="rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700"><%= t("person.overview.pending_parse", count: pending_count) %></span>
      <% end %>
      <% failed_count = entries.count(&:failed_parse?) %>
      <% if failed_count.positive? %>
        <span class="rounded-full border border-rose-200 bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-700"><%= t("person.overview.failed_parse", count: failed_count) %></span>
      <% end %>
    </div>
  </div>
</div>
