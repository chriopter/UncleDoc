<% current_range = overview_period_mode(params, type) %>
<% series = baby_activity_series(person, type, period: current_range) %>
<% max_count = series.map { |point| point[:count] }.max.to_i %>
<% theme = type == :feeding ? {
  border: "border-emerald-300/20",
  bg: "bg-emerald-400/10",
  label: "text-emerald-200",
  badge: "border-emerald-300/30 bg-white/10 text-emerald-100",
  bar: "from-emerald-500 via-emerald-400 to-emerald-300"
} : {
  border: "border-blue-300/20",
  bg: "bg-blue-400/10",
  label: "text-blue-200",
  badge: "border-blue-300/30 bg-white/10 text-blue-100",
  bar: "from-blue-500 via-sky-400 to-cyan-300"
} %>

<div id="overview_baby_activity_<%= type %>" class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-sm ring-1 ring-black/5 <%= local_assigns[:card_classes] %>">
  <section class="flex h-full flex-col rounded-[1.5rem] border <%= theme[:border] %> <%= theme[:bg] %> p-4">
    <div class="mb-3 flex items-start justify-between gap-3">
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] <%= theme[:label] %>"><%= t("baby.activity.label") %></p>
        <h3 class="mt-1 text-lg font-bold text-white"><%= t("baby.activity.#{type}_title") %></h3>
      </div>
      <div>
        <div class="inline-flex rounded-full border border-white/10 bg-white/5 p-1 text-[11px] font-semibold text-slate-300">
          <% overview_period_options.each do |label, value| %>
            <%= link_to label, person_overview_path(person_slug: person.name, **overview_widget_params("#{type}_range": value)), class: "rounded-full px-3 py-1 transition #{current_range == value ? 'bg-white text-slate-950 shadow-sm' : 'hover:bg-white/10'}" %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="grid flex-1 gap-2" style="grid-template-columns: repeat(<%= series.length %>, minmax(0, 1fr));">
      <% series.each do |point| %>
        <div class="flex flex-col items-center gap-1.5">
          <div class="text-[11px] font-semibold text-white"><%= point[:count] %></div>
          <div class="flex h-24 w-full items-end justify-center rounded-2xl bg-slate-950/40 px-2 py-2">
            <div class="w-full rounded-xl bg-gradient-to-t <%= theme[:bar] %>" style="height: <%= baby_activity_bar_height(point[:count], max_count) %>%"></div>
          </div>
          <div class="text-center">
            <div class="text-[11px] font-semibold text-slate-200"><%= point[:day_label] %></div>
            <div class="text-[10px] text-slate-400"><%= point[:short_label] %></div>
          </div>
        </div>
      <% end %>
    </div>
  </section>
</div>
