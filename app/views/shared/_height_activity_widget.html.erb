<% current_range = overview_period_mode(params, :height) %>
<% series = height_activity_series(person, period: current_range) %>
<% if series.present? %>
  <% min_value = series.map { |point| point[:value] }.min %>
  <% max_value = series.map { |point| point[:value] }.max %>
  <% latest = series.last %>
  <% line_points = weight_activity_line_points(series) %>
  <% plot_points = weight_activity_plot_points(series) %>

  <div id="overview_height_activity" class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-sm ring-1 ring-black/5 <%= local_assigns[:card_classes] || chart_widget_card_classes %>">
    <section class="flex h-full flex-col rounded-[1.5rem] border border-cyan-300/20 bg-cyan-400/10 p-4">
      <div class="mb-3 flex items-start justify-between gap-3">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-cyan-200"><%= t("entries.data_labels.height") %></p>
          <h3 class="mt-1 text-lg font-bold text-white"><%= t("person.overview.height.title") %></h3>
        </div>
        <div class="text-right">
          <div class="mb-2 inline-flex rounded-full border border-white/10 bg-white/5 p-1 text-[11px] font-semibold text-slate-300">
            <% overview_period_options.each do |label, value| %>
              <%= link_to label, person_widgets_path(person, height_range: value), class: "rounded-full px-3 py-1 transition #{current_range == value ? 'bg-white text-slate-950 shadow-sm' : 'hover:bg-white/10'}" %>
            <% end %>
          </div>
          <p class="text-[10px] font-semibold text-slate-300"><%= number_with_precision(min_value, precision: min_value % 1 == 0 ? 0 : 1, strip_insignificant_zeros: true) %> - <%= number_with_precision(max_value, precision: max_value % 1 == 0 ? 0 : 1, strip_insignificant_zeros: true) %> <%= latest[:unit] %></p>
        </div>
      </div>

      <div class="rounded-2xl border border-cyan-300/10 bg-slate-950/40 p-3">
        <div class="relative h-32">
          <div class="absolute inset-0 grid grid-rows-4">
            <% 4.times do %>
              <div class="border-b border-white/5 last:border-b-0"></div>
            <% end %>
          </div>

          <svg viewBox="0 0 100 60" preserveAspectRatio="none" class="relative h-full w-full">
            <defs>
              <linearGradient id="height-line-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#06b6d4" />
                <stop offset="55%" stop-color="#38bdf8" />
                <stop offset="100%" stop-color="#a5f3fc" />
              </linearGradient>
            </defs>
            <polyline fill="none" stroke="url(#height-line-gradient)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" points="<%= line_points %>" />
            <% plot_points.each do |point| %>
              <circle cx="<%= point[:x] %>" cy="<%= point[:y] %>" r="2.3" fill="#f8fafc" stroke="#38bdf8" stroke-width="1.3" />
            <% end %>
          </svg>
        </div>

        <div class="mt-2 grid gap-2" style="grid-template-columns: repeat(<%= series.length %>, minmax(0, 1fr));">
          <% series.each do |point| %>
            <div class="text-center">
              <div class="text-[11px] font-semibold text-white"><%= number_with_precision(point[:value], precision: point[:value] % 1 == 0 ? 0 : 1, strip_insignificant_zeros: true) %> <span class="text-[10px] font-medium text-cyan-200"><%= point[:unit] %></span></div>
              <div class="mt-1 text-[10px] font-semibold text-slate-200"><%= point[:short_label] %></div>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  </div>
<% else %>
  <div id="overview_height_activity" class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-sm ring-1 ring-black/5 <%= local_assigns[:card_classes] || chart_widget_card_classes %>">
    <section class="flex h-full flex-col rounded-[1.5rem] border border-cyan-300/20 bg-cyan-400/10 p-4">
      <div class="mb-4 flex items-start justify-between gap-3">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-cyan-200"><%= t("entries.data_labels.height") %></p>
          <h3 class="mt-1 text-lg font-bold text-white"><%= t("person.overview.height.title") %></h3>
        </div>
        <div class="inline-flex rounded-full border border-white/10 bg-white/5 p-1 text-[11px] font-semibold text-slate-300">
          <% overview_period_options.each do |label, value| %>
            <%= link_to label, person_widgets_path(person, height_range: value), class: "rounded-full px-3 py-1 transition #{current_range == value ? 'bg-white text-slate-950 shadow-sm' : 'hover:bg-white/10'}" %>
          <% end %>
        </div>
      </div>

      <div class="flex flex-1 items-center justify-center rounded-2xl border border-dashed border-cyan-300/20 bg-slate-950/30 px-4 py-10 text-center text-sm text-slate-300">
        <%= height_activity_available?(person) ? t("person.overview.height.empty_range") : t("person.overview.height.empty") %>
      </div>
    </section>
  </div>
<% end %>
