<% feeding_timer_started_at = baby_feeding_timer_started_at_for(person) %>
<% feeding_timer_side = baby_feeding_timer_side_for(person) %>
<% feeding_timer_elapsed = baby_feeding_timer_elapsed_label(feeding_timer_started_at) %>
<% sleep_timer_started_at = baby_sleep_timer_started_at_for(person) %>
<% sleep_timer_elapsed = baby_sleep_timer_elapsed_label(sleep_timer_started_at) %>
<%= render "shared/widget", id: "overview_baby_actions", label: t("baby.badge"), title: t("baby.quick_actions.title"), color: "pink", card_classes: local_assigns[:card_classes] || 'xl:col-span-2 xl:row-span-2 h-full' do %>
  <section class="flex h-full flex-col gap-3 rounded-[1.5rem] bg-gradient-to-br from-pink-50/70 via-white to-amber-50/70 p-1.5" data-controller="feeding-mode" data-feeding-mode-default-value="breast">
    <div class="rounded-[1.35rem] bg-white/80 p-4 shadow-sm ring-1 ring-emerald-100/80">
      <div class="mb-3 flex items-start justify-between gap-3">
        <div>
          <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700"><%= t("baby.feeding.combined_title") %></p>
            <% if person.time_since_last_feeding %>
              <p class="text-[11px] text-emerald-700"><%= compact_time_ago_label(person.time_since_last_feeding) %></p>
            <% end %>
          </div>
        </div>
        <% if feeding_timer_started_at %>
          <span class="rounded-full bg-emerald-100 px-2.5 py-1 text-[11px] font-semibold text-emerald-800"><%= feeding_timer_elapsed %></span>
        <% end %>
      </div>

      <div data-feeding-mode-target="panel" data-panel="breast" class="grid grid-cols-3 gap-2">
        <% if feeding_timer_started_at && feeding_timer_side == "left" %>
          <%= button_to person_baby_feeding_timer_path(person), method: :delete, class: "rounded-2xl bg-emerald-100 px-3 py-2.5 text-left text-xs font-semibold text-emerald-950 shadow-sm transition hover:bg-emerald-200" do %>
            <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-xl bg-emerald-200 text-emerald-800">&#10074;&#10074;</span><span><%= t("baby.feeding.sides.left") %></span></span>
          <% end %>
        <% elsif feeding_timer_started_at %>
          <button type="button" disabled class="rounded-2xl bg-slate-100 px-3 py-2.5 text-left text-xs font-semibold text-slate-500">
            <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-xl bg-slate-200">&#9654;</span><span><%= t("baby.feeding.sides.left") %></span></span>
          </button>
        <% else %>
          <%= button_to person_baby_feeding_timer_path(person, side: "left"), method: :post, class: "rounded-2xl bg-emerald-50 px-3 py-2.5 text-left text-xs font-semibold text-emerald-900 transition hover:bg-emerald-100" do %>
            <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-xl bg-white text-emerald-700 shadow-sm">&#9654;</span><span><%= t("baby.feeding.sides.left") %></span></span>
          <% end %>
        <% end %>

        <% if feeding_timer_started_at && feeding_timer_side == "right" %>
          <%= button_to person_baby_feeding_timer_path(person), method: :delete, class: "rounded-2xl bg-emerald-100 px-3 py-2.5 text-left text-xs font-semibold text-emerald-950 shadow-sm transition hover:bg-emerald-200" do %>
            <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-xl bg-emerald-200 text-emerald-800">&#10074;&#10074;</span><span><%= t("baby.feeding.sides.right") %></span></span>
          <% end %>
        <% elsif feeding_timer_started_at %>
          <button type="button" disabled class="rounded-2xl bg-slate-100 px-3 py-2.5 text-left text-xs font-semibold text-slate-500">
            <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-xl bg-slate-200">&#9654;</span><span><%= t("baby.feeding.sides.right") %></span></span>
          </button>
        <% else %>
          <%= button_to person_baby_feeding_timer_path(person, side: "right"), method: :post, class: "rounded-2xl bg-emerald-50 px-3 py-2.5 text-left text-xs font-semibold text-emerald-900 transition hover:bg-emerald-100" do %>
            <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-xl bg-white text-emerald-700 shadow-sm">&#9654;</span><span><%= t("baby.feeding.sides.right") %></span></span>
          <% end %>
        <% end %>

        <button type="button" class="rounded-2xl bg-amber-50 px-3 py-2.5 text-left text-xs font-semibold text-amber-900 transition hover:bg-amber-100" data-feeding-mode-target="button" data-panel="bottle" data-action="feeding-mode#showPanel">
          <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-xl bg-white text-amber-700 shadow-sm">&#129371;</span><span><%= t("baby.feeding.modes.bottle") %></span></span>
        </button>
      </div>

      <div data-feeding-mode-target="panel" data-panel="bottle" class="hidden space-y-2">
        <%= form_with url: person_baby_bottle_action_path(person), class: "flex gap-2" do |f| %>
          <%= f.number_field :amount_ml, min: 1, step: 1, placeholder: "ml", class: "block min-w-0 flex-1 rounded-2xl border-0 bg-amber-50 px-3 py-2 text-xs focus:border-amber-500 focus:ring-amber-500" %>
          <%= f.submit t("baby.bottle.button"), class: "rounded-2xl bg-amber-500 px-3 py-2 text-xs font-semibold text-white transition hover:bg-amber-600" %>
        <% end %>
        <button type="button" class="w-full rounded-2xl bg-emerald-50 px-3 py-2.5 text-left text-xs font-semibold text-emerald-900 transition hover:bg-emerald-100" data-feeding-mode-target="button" data-panel="breast" data-action="feeding-mode#showPanel">
          <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-xl bg-white text-emerald-700 shadow-sm">&#8592;</span><span><%= t("baby.feeding.modes.breast") %></span></span>
        </button>
      </div>
    </div>

    <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-1">
      <div class="rounded-[1.35rem] bg-white/80 p-4 shadow-sm ring-1 ring-indigo-100/80">
        <div class="mb-3 flex items-start justify-between gap-3">
          <div>
            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-indigo-700"><%= t("baby.sleep.title") %></p>
              <% if person.time_since_last_sleep %>
                <p class="text-[11px] text-indigo-700"><%= compact_time_ago_label(person.time_since_last_sleep) %></p>
              <% end %>
            </div>
          </div>
          <% if sleep_timer_started_at %>
            <span class="rounded-full bg-indigo-100 px-2.5 py-1 text-[11px] font-semibold text-indigo-800"><%= sleep_timer_elapsed %></span>
          <% end %>
        </div>
        <% if sleep_timer_started_at %>
          <%= button_to person_baby_sleep_timer_path(person), method: :delete, class: "w-full rounded-2xl bg-indigo-100 px-3 py-2.5 text-left text-xs font-semibold text-indigo-950 shadow-sm transition hover:bg-indigo-200" do %>
            <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-xl bg-indigo-200 text-indigo-800">&#10074;&#10074;</span><span><%= t("baby.sleep.timer.stop") %></span></span>
          <% end %>
        <% else %>
          <%= button_to person_baby_sleep_timer_path(person), method: :post, class: "w-full rounded-2xl bg-indigo-50 px-3 py-2.5 text-left text-xs font-semibold text-indigo-900 transition hover:bg-indigo-100" do %>
            <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-xl bg-white text-indigo-700 shadow-sm">&#9654;</span><span><%= t("baby.sleep.timer.start") %></span></span>
          <% end %>
        <% end %>
      </div>

      <div class="rounded-[1.35rem] bg-white/80 p-4 shadow-sm ring-1 ring-blue-100/80">
        <div class="mb-3">
          <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-700"><%= t("baby.diaper.title") %></p>
            <% if person.time_since_last_diaper %>
              <p class="text-[11px] text-blue-700"><%= compact_time_ago_label(person.time_since_last_diaper) %></p>
            <% end %>
          </div>
        </div>
        <div class="grid grid-cols-3 gap-2">
          <%= button_to person_baby_diaper_action_path(person), params: { kind: "wet" }, class: "rounded-2xl bg-blue-50 px-3 py-2.5 text-left text-xs font-semibold text-blue-900 transition hover:bg-blue-100" do %>
            <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-xl bg-white text-blue-700 shadow-sm">W</span><span><%= t("baby.diaper.buttons.wet") %></span></span>
          <% end %>
          <%= button_to person_baby_diaper_action_path(person), params: { kind: "solid" }, class: "rounded-2xl bg-blue-50 px-3 py-2.5 text-left text-xs font-semibold text-blue-900 transition hover:bg-blue-100" do %>
            <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-xl bg-white text-blue-700 shadow-sm">S</span><span><%= t("baby.diaper.buttons.solid") %></span></span>
          <% end %>
          <%= button_to person_baby_diaper_action_path(person), params: { kind: "both" }, class: "rounded-2xl bg-gradient-to-br from-blue-500 to-blue-600 px-3 py-2.5 text-left text-xs font-semibold text-white transition hover:from-blue-600 hover:to-blue-700" do %>
            <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-xl bg-white/20 text-white">+</span><span><%= t("baby.diaper.buttons.both") %></span></span>
          <% end %>
        </div>
      </div>
    </div>
  </section>
<% end %>
