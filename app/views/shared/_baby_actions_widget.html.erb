<% feeding_timer_started_at = baby_feeding_timer_started_at_for(person) %>
<% feeding_timer_side = baby_feeding_timer_side_for(person) %>
<% feeding_timer_elapsed = baby_feeding_timer_elapsed_label(feeding_timer_started_at) %>
<% sleep_timer_started_at = baby_sleep_timer_started_at_for(person) %>
<% sleep_timer_elapsed = baby_sleep_timer_elapsed_label(sleep_timer_started_at) %>

<div id="overview_baby_actions" class="rounded-[2rem] border border-pink-200 bg-white/95 p-4 text-slate-950 shadow-sm ring-1 ring-black/5 backdrop-blur <%= local_assigns[:card_classes] || 'xl:col-span-2 xl:row-span-2 h-full' %>">
  <section class="flex h-full flex-col rounded-[1.5rem] border border-pink-200 bg-gradient-to-br from-pink-50 via-white to-amber-50 p-3" data-controller="feeding-mode" data-feeding-mode-default-value="breast">
    <div class="mb-3 flex items-start justify-between gap-3">
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-pink-600"><%= t("baby.badge") %></p>
        <h3 class="mt-1 text-base font-bold text-slate-950"><%= t("baby.quick_actions.title") %></h3>
      </div>
    </div>

    <div class="flex flex-1 flex-col gap-3">
      <div class="rounded-[1.25rem] border border-emerald-200 bg-emerald-50/70 p-3">
        <div class="mb-2 flex items-start justify-between gap-3">
          <div>
            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700"><%= t("baby.feeding.combined_title") %></p>
              <% if person.time_since_last_feeding %>
                <p class="text-[11px] text-emerald-700"><%= compact_time_ago_label(person.time_since_last_feeding) %></p>
              <% end %>
            </div>
          </div>
          <% if feeding_timer_started_at %>
            <span class="rounded-full border border-emerald-200 bg-emerald-100 px-2 py-0.5 text-[11px] font-semibold text-emerald-800"><%= feeding_timer_elapsed %></span>
          <% end %>
        </div>

        <div data-feeding-mode-target="panel" data-panel="breast" class="grid grid-cols-3 gap-2">
          <% if feeding_timer_started_at && feeding_timer_side == "left" %>
            <%= button_to person_baby_feeding_timer_path(person), method: :delete, class: "rounded-xl border border-emerald-300 bg-emerald-100 px-3 py-2 text-left text-xs font-semibold text-emerald-950 shadow-sm transition hover:bg-emerald-200" do %>
              <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-emerald-200 text-emerald-800">&#10074;&#10074;</span><span><%= t("baby.feeding.sides.left") %></span></span>
            <% end %>
          <% elsif feeding_timer_started_at %>
            <button type="button" disabled class="rounded-xl border border-slate-200 bg-slate-100 px-3 py-2 text-left text-xs font-semibold text-slate-500">
              <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-slate-200">&#9654;</span><span><%= t("baby.feeding.sides.left") %></span></span>
            </button>
          <% else %>
            <%= button_to person_baby_feeding_timer_path(person, side: "left"), method: :post, class: "rounded-xl border border-emerald-200 bg-white px-3 py-2 text-left text-xs font-semibold text-emerald-900 transition hover:bg-emerald-100" do %>
              <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-emerald-100 text-emerald-700">&#9654;</span><span><%= t("baby.feeding.sides.left") %></span></span>
            <% end %>
          <% end %>

          <% if feeding_timer_started_at && feeding_timer_side == "right" %>
            <%= button_to person_baby_feeding_timer_path(person), method: :delete, class: "rounded-xl border border-emerald-300 bg-emerald-100 px-3 py-2 text-left text-xs font-semibold text-emerald-950 shadow-sm transition hover:bg-emerald-200" do %>
              <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-emerald-200 text-emerald-800">&#10074;&#10074;</span><span><%= t("baby.feeding.sides.right") %></span></span>
            <% end %>
          <% elsif feeding_timer_started_at %>
            <button type="button" disabled class="rounded-xl border border-slate-200 bg-slate-100 px-3 py-2 text-left text-xs font-semibold text-slate-500">
              <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-slate-200">&#9654;</span><span><%= t("baby.feeding.sides.right") %></span></span>
            </button>
          <% else %>
            <%= button_to person_baby_feeding_timer_path(person, side: "right"), method: :post, class: "rounded-xl border border-emerald-200 bg-white px-3 py-2 text-left text-xs font-semibold text-emerald-900 transition hover:bg-emerald-100" do %>
              <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-emerald-100 text-emerald-700">&#9654;</span><span><%= t("baby.feeding.sides.right") %></span></span>
            <% end %>
          <% end %>

          <button type="button" class="rounded-xl border border-amber-200 bg-white px-3 py-2 text-left text-xs font-semibold text-amber-900 transition hover:bg-amber-50" data-feeding-mode-target="button" data-panel="bottle" data-action="feeding-mode#showPanel">
            <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-amber-100 text-amber-700">&#129371;</span><span><%= t("baby.feeding.modes.bottle") %></span></span>
          </button>
        </div>

        <div data-feeding-mode-target="panel" data-panel="bottle" class="hidden space-y-2">
          <%= form_with url: person_baby_bottle_action_path(person), class: "flex gap-2" do |f| %>
            <%= f.number_field :amount_ml, min: 1, step: 1, placeholder: "ml", class: "block min-w-0 flex-1 rounded-xl border-amber-200 bg-white px-3 py-2 text-xs focus:border-amber-500 focus:ring-amber-500" %>
            <%= f.submit t("baby.bottle.button"), class: "rounded-xl bg-amber-500 px-3 py-2 text-xs font-semibold text-white transition hover:bg-amber-600" %>
          <% end %>
          <button type="button" class="w-full rounded-xl border border-emerald-200 bg-white px-3 py-2 text-left text-xs font-semibold text-emerald-900 transition hover:bg-emerald-50" data-feeding-mode-target="button" data-panel="breast" data-action="feeding-mode#showPanel">
            <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-emerald-100 text-emerald-700">&#8592;</span><span><%= t("baby.feeding.modes.breast") %></span></span>
          </button>
        </div>
      </div>

      <div class="grid gap-3">
        <div class="rounded-[1.25rem] border border-indigo-200 bg-indigo-50/70 p-3">
          <div class="mb-2 flex items-start justify-between gap-3">
            <div>
              <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-indigo-700"><%= t("baby.sleep.title") %></p>
                <% if person.time_since_last_sleep %>
                  <p class="text-[11px] text-indigo-700"><%= compact_time_ago_label(person.time_since_last_sleep) %></p>
                <% end %>
              </div>
            </div>
            <% if sleep_timer_started_at %>
              <span class="rounded-full border border-indigo-200 bg-indigo-100 px-2 py-0.5 text-[11px] font-semibold text-indigo-800"><%= sleep_timer_elapsed %></span>
            <% end %>
          </div>

          <% if sleep_timer_started_at %>
            <%= button_to person_baby_sleep_timer_path(person), method: :delete, class: "w-full rounded-xl border border-indigo-300 bg-indigo-100 px-3 py-2 text-left text-xs font-semibold text-indigo-950 shadow-sm transition hover:bg-indigo-200" do %>
              <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-indigo-200 text-indigo-800">&#10074;&#10074;</span><span><%= t("baby.sleep.timer.stop") %></span></span>
            <% end %>
          <% else %>
            <%= button_to person_baby_sleep_timer_path(person), method: :post, class: "w-full rounded-xl border border-indigo-200 bg-white px-3 py-2 text-left text-xs font-semibold text-indigo-900 transition hover:bg-indigo-100" do %>
              <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-indigo-100 text-indigo-700">&#9654;</span><span><%= t("baby.sleep.timer.start") %></span></span>
            <% end %>
          <% end %>
        </div>

        <div class="rounded-[1.25rem] border border-blue-200 bg-blue-50/70 p-3">
          <div class="mb-2">
            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-700"><%= t("baby.diaper.title") %></p>
              <% if person.time_since_last_diaper %>
                <p class="text-[11px] text-blue-700"><%= compact_time_ago_label(person.time_since_last_diaper) %></p>
              <% end %>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-2">
            <%= button_to person_baby_diaper_action_path(person), params: { kind: "wet" }, class: "rounded-xl border border-blue-200 bg-white px-3 py-2 text-left text-xs font-semibold text-blue-900 transition hover:bg-blue-100" do %>
              <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-blue-100 text-blue-700">W</span><span><%= t("baby.diaper.buttons.wet") %></span></span>
            <% end %>
            <%= button_to person_baby_diaper_action_path(person), params: { kind: "solid" }, class: "rounded-xl border border-blue-200 bg-white px-3 py-2 text-left text-xs font-semibold text-blue-900 transition hover:bg-blue-100" do %>
              <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-blue-100 text-blue-700">S</span><span><%= t("baby.diaper.buttons.solid") %></span></span>
            <% end %>
            <%= button_to person_baby_diaper_action_path(person), params: { kind: "both" }, class: "rounded-xl border border-blue-200 bg-gradient-to-br from-blue-500 to-blue-600 px-3 py-2 text-left text-xs font-semibold text-white transition hover:from-blue-600 hover:to-blue-700" do %>
              <span class="flex items-center gap-2"><span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-white/20 text-white">+</span><span><%= t("baby.diaper.buttons.both") %></span></span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
