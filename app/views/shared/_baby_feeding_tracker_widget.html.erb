<% recent_timed_feedings = person.recent_timed_feedings(3) %>

<div id="overview_baby_tracking_feeding" class="rounded-[2rem] border border-emerald-200 bg-white/95 p-6 text-slate-950 shadow-sm ring-1 ring-black/5 backdrop-blur <%= local_assigns[:card_classes] || 'xl:col-span-2 xl:row-span-3 h-full' %>">
  <section class="flex h-full flex-col rounded-[1.5rem] border border-emerald-200 bg-gradient-to-br from-emerald-50 via-white to-amber-50 p-4">
    <div class="mb-4 flex items-start justify-between gap-3">
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-emerald-600"><%= t("baby.badge") %></p>
        <h3 class="mt-1 text-lg font-bold text-slate-950"><%= t("baby.feeding.combined_title") %></h3>
      </div>
    </div>

    <% if recent_timed_feedings.any? %>
      <div class="space-y-1.5 rounded-2xl border border-emerald-100 bg-white/80 px-3 py-3 text-xs font-medium text-emerald-900">
        <% recent_timed_feedings.each do |entry| %>
          <% duration_minutes = entry.feeding_duration_minutes %>
          <% started_at = duration_minutes.present? ? entry.display_time - duration_minutes.minutes : entry.display_time %>
          <div>
            <span><%= feeding_session_label(started_at, entry.display_time) %></span>
            <% if duration_minutes.present? %>
              <span class="text-emerald-600">: <%= t("baby.feeding.timer.duration", duration: duration_minutes) %></span>
            <% end %>
            <% if entry.feeding_side.present? %>
              <span class="font-semibold text-emerald-800">, <%= t("baby.feeding.sides.#{entry.feeding_side}") %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= render "shared/baby_activity_chart", person: person, type: :feeding %>
  </section>
</div>
