<% feeding_timer_started_at = baby_feeding_timer_started_at_for(person) %>
<% feeding_timer_side = baby_feeding_timer_side_for(person) %>
<% feeding_timer_elapsed = baby_feeding_timer_elapsed_label(feeding_timer_started_at) %>
<% feeding_started_at = person.last_feeding_started_at %>
<% feeding_stopped_at = person.last_feeding_stopped_at %>

<div id="overview_baby_tracking_feeding" class="rounded-[2rem] border border-emerald-200 bg-white/95 p-6 text-slate-950 shadow-sm ring-1 ring-black/5 backdrop-blur <%= local_assigns[:card_classes] || chart_widget_card_classes %>">
  <section class="flex h-full flex-col rounded-[1.5rem] border border-emerald-200 bg-gradient-to-br from-emerald-50 via-white to-amber-50 p-4" data-controller="feeding-mode" data-feeding-mode-default-value="breast">
    <div class="mb-4 flex items-start justify-between gap-3">
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-emerald-600"><%= t("baby.badge") %></p>
        <h3 class="mt-1 text-lg font-bold text-slate-950"><%= t("baby.feeding.combined_title") %></h3>
      </div>
    </div>

    <div class="mb-4 flex flex-wrap gap-2 text-[11px] font-semibold">
      <% if feeding_started_at %>
        <span class="rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-emerald-800"><%= t("baby.feeding.started_ago") %>: <%= compact_time_ago_label(feeding_started_at) %></span>
      <% end %>
      <% if feeding_stopped_at %>
        <span class="rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-amber-800"><%= t("baby.feeding.stopped_ago") %>: <%= compact_time_ago_label(feeding_stopped_at) %></span>
      <% end %>
    </div>

    <% if feeding_timer_started_at %>
      <div class="mb-3 rounded-2xl border border-emerald-200 bg-emerald-100 px-3 py-2 text-sm font-semibold text-emerald-950 shadow-sm">
        <div><%= t("baby.feeding.sides.#{feeding_timer_side}") %> · <%= feeding_timer_elapsed %></div>
        <div class="mt-1 text-[11px] font-medium text-emerald-700"><%= l(feeding_timer_started_at, format: :short) %></div>
      </div>
    <% end %>

    <div class="mt-auto space-y-3">
      <div data-feeding-mode-target="panel" data-panel="breast" class="space-y-3">
        <div class="grid grid-cols-3 gap-2">
          <% if feeding_timer_started_at && feeding_timer_side == "left" %>
            <%= button_to person_baby_feeding_timer_path(person), method: :delete, class: "rounded-2xl border border-emerald-300 bg-emerald-100 px-3 py-3 text-left text-sm font-semibold text-emerald-950 transition hover:bg-emerald-200" do %>
              <span class="block"><%= t("baby.feeding.sides.left") %></span>
              <span class="mt-1 block text-[11px] text-emerald-700"><%= t("baby.feeding.timer.tap_to_stop") %></span>
            <% end %>
          <% elsif feeding_timer_started_at %>
            <button type="button" disabled class="rounded-2xl border border-slate-200 bg-slate-100 px-3 py-3 text-left text-sm font-semibold text-slate-500">
              <span class="block"><%= t("baby.feeding.sides.left") %></span>
              <span class="mt-1 block text-[11px]"><%= t("baby.feeding.timer.running_elsewhere") %></span>
            </button>
          <% else %>
            <%= button_to person_baby_feeding_timer_path(person, side: "left"), method: :post, class: "rounded-2xl border border-emerald-200 bg-white px-3 py-3 text-left text-sm font-semibold text-emerald-900 transition hover:bg-emerald-100" do %>
              <span class="block"><%= t("baby.feeding.sides.left") %></span>
              <span class="mt-1 block text-[11px] text-emerald-600"><%= t("baby.feeding.timer.start_hint") %></span>
            <% end %>
          <% end %>

          <% if feeding_timer_started_at && feeding_timer_side == "right" %>
            <%= button_to person_baby_feeding_timer_path(person), method: :delete, class: "rounded-2xl border border-emerald-300 bg-emerald-100 px-3 py-3 text-left text-sm font-semibold text-emerald-950 transition hover:bg-emerald-200" do %>
              <span class="block"><%= t("baby.feeding.sides.right") %></span>
              <span class="mt-1 block text-[11px] text-emerald-700"><%= t("baby.feeding.timer.tap_to_stop") %></span>
            <% end %>
          <% elsif feeding_timer_started_at %>
            <button type="button" disabled class="rounded-2xl border border-slate-200 bg-slate-100 px-3 py-3 text-left text-sm font-semibold text-slate-500">
              <span class="block"><%= t("baby.feeding.sides.right") %></span>
              <span class="mt-1 block text-[11px]"><%= t("baby.feeding.timer.running_elsewhere") %></span>
            </button>
          <% else %>
            <%= button_to person_baby_feeding_timer_path(person, side: "right"), method: :post, class: "rounded-2xl border border-emerald-200 bg-white px-3 py-3 text-left text-sm font-semibold text-emerald-900 transition hover:bg-emerald-100" do %>
              <span class="block"><%= t("baby.feeding.sides.right") %></span>
              <span class="mt-1 block text-[11px] text-emerald-600"><%= t("baby.feeding.timer.start_hint") %></span>
            <% end %>
          <% end %>

          <button type="button" class="rounded-2xl border border-amber-200 bg-white px-3 py-3 text-left text-sm font-semibold text-amber-900 transition hover:bg-amber-50" data-feeding-mode-target="button" data-panel="bottle" data-active-classes="bg-amber-100 border-amber-300 text-amber-900 shadow-sm" data-inactive-classes="bg-white text-amber-900" data-action="feeding-mode#showPanel">
            <span class="block"><%= t("baby.feeding.modes.bottle") %></span>
            <span class="mt-1 block text-[11px] text-amber-600"><%= t("baby.bottle.button") %></span>
          </button>
        </div>
      </div>

      <div data-feeding-mode-target="panel" data-panel="bottle" class="hidden space-y-3">
        <div class="grid grid-cols-3 gap-2">
          <button type="button" class="rounded-2xl border border-emerald-200 bg-white px-3 py-3 text-left text-sm font-semibold text-emerald-900 transition hover:bg-emerald-50" data-feeding-mode-target="button" data-panel="breast" data-active-classes="bg-emerald-100 border-emerald-300 text-emerald-900 shadow-sm" data-inactive-classes="bg-white text-emerald-900" data-action="feeding-mode#showPanel">
            <span class="block"><%= t("baby.feeding.sides.left") %></span>
            <span class="mt-1 block text-[11px] text-emerald-600"><%= t("baby.feeding.modes.breast") %></span>
          </button>
          <button type="button" class="rounded-2xl border border-emerald-200 bg-white px-3 py-3 text-left text-sm font-semibold text-emerald-900 transition hover:bg-emerald-50" data-feeding-mode-target="button" data-panel="breast" data-active-classes="bg-emerald-100 border-emerald-300 text-emerald-900 shadow-sm" data-inactive-classes="bg-white text-emerald-900" data-action="feeding-mode#showPanel">
            <span class="block"><%= t("baby.feeding.sides.right") %></span>
            <span class="mt-1 block text-[11px] text-emerald-600"><%= t("baby.feeding.modes.breast") %></span>
          </button>
          <button type="button" class="rounded-2xl border border-amber-200 bg-white px-3 py-3 text-left text-sm font-semibold text-amber-900 transition hover:bg-amber-50" data-feeding-mode-target="button" data-panel="bottle" data-active-classes="bg-amber-100 border-amber-300 text-amber-900 shadow-sm" data-inactive-classes="bg-white text-amber-900" data-action="feeding-mode#showPanel">
            <span class="block"><%= t("baby.feeding.modes.bottle") %></span>
            <span class="mt-1 block text-[11px] text-amber-600"><%= t("baby.bottle.button") %></span>
          </button>
        </div>

        <%= form_with url: person_baby_bottle_action_path(person), class: "space-y-3" do |f| %>
          <div class="flex gap-2">
            <%= f.number_field :amount_ml, min: 1, step: 1, placeholder: "120", class: "block w-full rounded-2xl border-amber-200 bg-white px-4 py-3 text-sm focus:border-amber-500 focus:ring-amber-500" %>
            <%= f.submit t("baby.bottle.button"), class: "rounded-2xl bg-amber-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-amber-600" %>
          </div>
        <% end %>
      </div>
    </div>
  </section>
</div>
