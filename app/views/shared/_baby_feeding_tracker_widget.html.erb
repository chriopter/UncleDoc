<% recent_timed_feedings = person.recent_timed_feedings(3) %>
<%= render "shared/widget", id: "overview_baby_tracking_feeding", label: t("baby.badge"), title: t("baby.feeding.combined_title"), color: "emerald", card_classes: local_assigns[:card_classes] do %>
  <section class="flex flex-col rounded-[1.5rem] bg-gradient-to-br from-emerald-50/60 via-white to-amber-50/60 p-4">
    <% if recent_timed_feedings.any? %>
      <div class="space-y-1.5 rounded-2xl bg-white/70 px-3 py-3 text-xs font-medium text-emerald-900">
        <% recent_timed_feedings.each do |entry| %>
          <% duration_minutes = entry.feeding_duration_minutes %>
          <% started_at = duration_minutes.present? ? entry.display_time - duration_minutes.minutes : entry.display_time %>
          <div>
            <span><%= feeding_session_label(started_at, entry.display_time) %></span>
            <% if duration_minutes.present? %>
              <span class="text-emerald-600">: <%= t("baby.feeding.timer.duration", duration: duration_minutes) %></span>
            <% end %>
            <% if entry.feeding_side.present? %>
              <span class="font-semibold text-emerald-800">, <%= t("baby.feeding.sides.#{entry.feeding_side}") %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
    <%= render "shared/baby_activity_chart", person: person, type: :feeding %>
  </section>
<% end %>
