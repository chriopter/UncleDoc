<% notes = note_entries(person) %>
<%= render "shared/widget", id: "overview_notes", label: t("entries.data_labels.note"), title: t("person.overview.notes.title"), color: "fuchsia", dark: true, card_classes: local_assigns[:card_classes] do %>
  <section class="flex h-full flex-col rounded-[1.5rem] border border-fuchsia-300/20 bg-fuchsia-400/10 p-4">
    <% if notes.present? %>
      <div class="space-y-2">
        <% notes.each do |entry| %>
          <div class="rounded-2xl border border-white/10 bg-white/5 px-3 py-3">
            <div class="text-sm font-semibold text-white"><%= entry.fact_summary.presence || entry.input %></div>
            <% if entry.note_data["quality"].present? %>
              <div class="mt-1 text-xs text-slate-300"><%= entry.note_data["quality"] %></div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="flex flex-1 items-center justify-center rounded-2xl border border-dashed border-fuchsia-300/20 bg-slate-950/30 px-4 py-10 text-center text-sm text-slate-300">
        <%= t("person.overview.notes.empty") %>
      </div>
    <% end %>
  </section>
<% end %>
