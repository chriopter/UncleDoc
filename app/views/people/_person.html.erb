<article id="<%= dom_id(person) %>" class="rounded-3xl border border-white/10 bg-white/5 p-4 shadow-sm backdrop-blur">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h3 class="text-lg font-bold text-white"><%= person.name %></h3>
      <p class="mt-1 text-sm text-slate-300">
        Birth date:
        <%= person.birth_date.present? ? l(person.birth_date, format: :long) : "Unknown" %>
      </p>
      <p class="mt-2 text-xs uppercase tracking-[0.18em] text-slate-400">Created <%= time_ago_in_words(person.created_at) %> ago</p>
    </div>

    <%= button_to "Delete", person_path(person), method: :delete, class: "rounded-full border border-white/15 px-3 py-2 text-xs font-semibold text-white transition hover:border-rose-300 hover:bg-rose-400/10", form: { data: { turbo_confirm: "Delete #{person.name}?" } } %>
  </div>
</article>
