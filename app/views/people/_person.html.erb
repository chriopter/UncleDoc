<article id="<%= dom_id(person) %>" class="rounded-3xl border border-white/10 bg-white/5 p-4 shadow-sm backdrop-blur">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h3 class="text-lg font-bold text-white"><%= person.name %></h3>
      <p class="mt-1 text-sm text-slate-300">
        <%= t("people.person.birth_date_label") %>
        <%= formatted_date(person.birth_date) %>
      </p>
      <p class="mt-2 text-xs uppercase tracking-[0.18em] text-slate-400"><%= t("people.person.created_ago", time: time_ago_in_words(person.created_at)) %></p>
    </div>

    <%= button_to t("actions.delete"), person_path(person), method: :delete, class: "rounded-full border border-white/15 px-3 py-2 text-xs font-semibold text-white transition hover:border-rose-300 hover:bg-rose-400/10", form: { data: { turbo_confirm: t("people.person.delete_confirm", name: person.name) } } %>
  </div>
</article>
