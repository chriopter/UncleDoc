<%= turbo_frame_tag "person_form" do %>
  <%= form_with model: person, class: "space-y-3" do |form| %>
    <% if person.errors.any? %>
      <div class="rounded-xl border border-rose-200 bg-rose-50 px-3.5 py-2.5 text-sm text-rose-800">
        <p class="font-semibold"><%= t("people.form.error_message") %></p>
        <p><%= person.errors.full_messages.to_sentence %></p>
      </div>
    <% end %>

    <div class="grid gap-3 sm:grid-cols-2">
      <div class="space-y-1.5">
        <%= form.label :name, t("activerecord.attributes.person.name"), class: "text-sm font-semibold text-slate-700" %>
        <%= form.text_field :name, placeholder: t("people.form.placeholder_name"), class: "w-full rounded-xl border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-500 focus:ring-2 focus:ring-amber-200" %>
      </div>
      <div class="space-y-1.5">
        <%= form.label :birth_date, t("activerecord.attributes.person.birth_date"), class: "text-sm font-semibold text-slate-700" %>
        <%= form.datetime_local_field :birth_date, value: person.birth_date&.strftime("%Y-%m-%dT%H:%M"), class: "w-full rounded-xl border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-500 focus:ring-2 focus:ring-amber-200" %>
      </div>
    </div>

    <div class="grid gap-3 sm:grid-cols-2">
      <div class="space-y-1.5">
        <%= form.label :locale, t("settings.users.language_label"), class: "text-sm font-semibold text-slate-700" %>
        <%= form.select :locale, [[t("settings.users.use_workspace_default"), ""], [t("settings.language.english"), "en"], [t("settings.language.german"), "de"]], {}, class: "w-full rounded-xl border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-500 focus:ring-2 focus:ring-amber-200" %>
      </div>
      <div class="space-y-1.5">
        <%= form.label :date_format, t("settings.users.date_format_label"), class: "text-sm font-semibold text-slate-700" %>
        <%= form.select :date_format, [[t("settings.users.use_workspace_default"), ""], [t("settings.date_format.long"), "long"], [t("settings.date_format.compact"), "compact"]], {}, class: "w-full rounded-xl border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-500 focus:ring-2 focus:ring-amber-200" %>
      </div>
    </div>

    <%= form.fields_for :user do |user_form| %>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="space-y-1.5 sm:col-span-2">
          <%= user_form.label :email_address, t("settings.users.email_label"), class: "text-sm font-semibold text-slate-700" %>
          <%= user_form.email_field :email_address, autocomplete: "username", class: "w-full rounded-xl border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-500 focus:ring-2 focus:ring-amber-200" %>
        </div>
        <div class="space-y-1.5">
          <%= user_form.label :password, t("settings.users.password_label"), class: "text-sm font-semibold text-slate-700" %>
          <%= user_form.password_field :password, autocomplete: "new-password", maxlength: 72, placeholder: t("settings.users.password_placeholder"), class: "w-full rounded-xl border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-500 focus:ring-2 focus:ring-amber-200" %>
        </div>
        <div class="space-y-1.5">
          <%= user_form.label :password_confirmation, t("settings.users.password_confirmation_label"), class: "text-sm font-semibold text-slate-700" %>
          <%= user_form.password_field :password_confirmation, autocomplete: "new-password", maxlength: 72, class: "w-full rounded-xl border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 outline-none transition focus:border-amber-500 focus:ring-2 focus:ring-amber-200" %>
        </div>
      </div>

      <div>
        <%= user_form.label :admin, class: "inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-slate-50 px-3.5 py-2.5 text-xs font-semibold text-slate-700" do %>
          <%= user_form.check_box :admin, class: "h-3.5 w-3.5 rounded border-slate-300 text-amber-600 focus:ring-amber-500" %>
          <span><%= t("settings.users.admin_label") %></span>
        <% end %>
      </div>
    <% end %>

    <div class="flex justify-end">
      <%= form.submit t("people.form.submit"), class: "inline-flex items-center rounded-full bg-slate-950 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800" %>
    </div>
  <% end %>
<% end %>
