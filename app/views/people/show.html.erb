<section class="w-full space-y-6">
  <%# Profile Card %>
  <div class="rounded-[2rem] border border-white/70 bg-white/90 p-6 shadow-sm ring-1 ring-black/5 backdrop-blur">
    <div class="flex items-center gap-6">
      <div class="flex h-20 w-20 items-center justify-center rounded-3xl bg-amber-100 text-amber-800 text-3xl font-bold">
        <%= @person.name.first.upcase %>
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700">Family Member</p>
        <h1 class="text-3xl font-black tracking-tight text-slate-950"><%= @person.name %></h1>
        <p class="mt-1 text-slate-600">
          <% if @person.birth_date %>
            Born <%= formatted_date(@person.birth_date) %> · <%= (@person.birth_date - Date.today).abs / 365 %> years old
          <% else %>
            Birth date not set
          <% end %>
        </p>
      </div>
    </div>
  </div>

  <%# Stats Grid %>
  <div class="grid gap-4 md:grid-cols-3">
    <div class="rounded-2xl border border-white/70 bg-white/80 p-5 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Log Entries</p>
      <p class="mt-1 text-3xl font-black text-slate-950"><%= @entry_count %></p>
      <p class="text-sm text-slate-600">Health notes recorded</p>
    </div>

    <div class="rounded-2xl border border-white/70 bg-white/80 p-5 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Member Since</p>
      <p class="mt-1 text-lg font-bold text-slate-950"><%= @person.created_at.strftime("%B %Y") %></p>
      <p class="text-sm text-slate-600"><%= time_ago_in_words(@person.created_at) %> ago</p>
    </div>

    <div class="rounded-2xl border border-white/70 bg-white/80 p-5 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Last Activity</p>
      <% if @entries.any? %>
        <p class="mt-1 text-lg font-bold text-slate-950"><%= time_ago_in_words(@entries.first.created_at) %> ago</p>
        <p class="text-sm text-slate-600">Most recent entry</p>
      <% else %>
        <p class="mt-1 text-lg font-bold text-slate-950">No entries</p>
        <p class="text-sm text-slate-600">Start logging health data</p>
      <% end %>
    </div>
  </div>

  <%# Recent Entries %>
  <div class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-sm ring-1 ring-black/5">
    <div class="mb-5 flex items-end justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-300">Recent Activity</p>
        <h2 class="text-2xl font-bold">Latest Entries</h2>
      </div>
      <%= link_to "View Log", root_path(person_slug: @person.name), class: "rounded-full bg-amber-500/20 px-4 py-2 text-sm font-semibold text-amber-300 hover:bg-amber-500/30 transition" %>
    </div>

    <% if @entries.any? %>
      <div class="space-y-3">
        <% @entries.each do |entry| %>
          <%= render "entries/entry", entry: entry %>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-3xl border border-dashed border-white/20 bg-white/5 px-6 py-10 text-center text-slate-300">
        No entries yet. <%= link_to "Go to Log", root_path(person_slug: @person.name), class: "text-amber-300 hover:text-amber-200 underline" %> to add health notes.
      </div>
    <% end %>
  </div>
</section>
