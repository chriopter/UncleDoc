<section class="w-full space-y-6">
  <%# Baby Mode Dashboard - Only shown when baby_mode is enabled %>
  <% if @person.baby_mode? %>
    <%= render "dashboard/baby_dashboard", person: @person, entry: Entry.new, entries: @person.entries.recent_first %>
  <% end %>

  <%# Fully Integrated Widget: Info + Add Entry + Recent Activity %>
  <div class="rounded-[2rem] border border-white/70 bg-white/90 shadow-sm ring-1 ring-black/5 backdrop-blur overflow-hidden">
    <div class="grid xl:grid-cols-[minmax(0,280px)_minmax(0,1fr)]">
      <%# Left: Basic Info with Baby Toggle %>
      <div class="p-5 border-b xl:border-b-0 xl:border-r border-slate-200">
        <div class="flex items-start justify-between mb-3">
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-amber-100 text-amber-800 text-lg font-bold">
              <%= @person.name.first.upcase %>
            </div>
            <h2 class="text-lg font-bold text-slate-950"><%= @person.name %></h2>
          </div>
          
          <%# Baby Toggle %>
          <%= form_with model: @person, method: :patch, local: false, data: { turbo_frame: "_top" }, class: "flex-shrink-0" do |f| %>
            <%= f.hidden_field :baby_mode, value: !@person.baby_mode %>
            <label class="relative inline-flex items-center cursor-pointer">
              <%= f.check_box :baby_mode, class: "sr-only peer", onchange: "this.form.requestSubmit()" %>
              <div class="w-9 h-5 bg-slate-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-pink-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-pink-500"></div>
            </label>
          <% end %>
        </div>
        
        <div class="space-y-1 text-sm">
          <% if @person.birth_date %>
            <p class="text-slate-600">
              <%= formatted_date(@person.birth_date) %> · <%= (@person.birth_date - Date.today).abs / 365 %> <%= t("person.overview.years_old") %>
            </p>
          <% else %>
            <p class="text-slate-500 text-xs"><%= t("person.overview.birth_date_not_set") %></p>
          <% end %>
          <% if @entries.any? %>
            <p class="text-slate-500 text-xs pt-2">
              <%= t("person.overview.stats.last_activity") %> <%= time_ago_in_words(@entries.first.created_at) %>
            </p>
          <% end %>
        </div>
      </div>

      <%# Right: Add Entry Form + Recent Activity (Integrated) %>
      <div class="bg-slate-950 text-white">
        <%# Add Entry Section - Compact %>
        <div class="px-5 py-3 border-b border-white/10">
          <%= render "entries/inline_form", entry: @entry || Entry.new, person: @person %>
        </div>

        <%# Recent Activity Section - Compact, max 5 entries, one line each %>
        <div class="px-5 pb-5 pt-3">
          <div class="mb-3 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-300"><%= t("person.overview.recent_activity") %></p>
              <span class="rounded-full border border-amber-500/30 bg-amber-500/10 px-2 py-0.5 text-[10px] font-medium text-amber-300">
                <%= t(@entries.count == 1 ? "dashboard.protocol.count" : "dashboard.protocol.count_plural", count: @entries.count) %>
              </span>
            </div>
            <%= link_to person_log_path(person_slug: @person.name), class: "text-[10px] font-medium text-amber-300 hover:text-amber-200 transition" do %>
              <%= t("person.overview.view_log") %> →
            <% end %>
          </div>

          <% if @entries.any? %>
            <div class="space-y-0">
              <% @entries.limit(5).each do |entry| %>
                <%= render "entries/compact_entry", entry: entry %>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-3 text-slate-400 text-xs">
              <%= t("dashboard.protocol.empty") %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
