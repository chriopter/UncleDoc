#!/usr/bin/env ruby
require "bundler"
require "fileutils"
require "open-uri"
require "open3"

APP_ROOT = File.expand_path("..", __dir__)
RUBY_DOWNLOADS_URL = "https://www.ruby-lang.org/en/downloads/"
ANSI_PATTERN = /\e\[[\d;]*m/
COLORS = {
  current: "\e[32m",
  updated: "\e[36m",
  updateable: "\e[33m",
  behind_major: "\e[31m",
  mixed: "\e[35m",
  reset: "\e[0m"
}.freeze

def sh(*command)
  system(*command, exception: true)
end

def capture(*command)
  Open3.capture2e(*command)
end

def expected_ruby
  File.read(".ruby-version").strip.delete_prefix("ruby-")
end

def ensure_expected_ruby!
  return if RUBY_VERSION == expected_ruby

  abort("Ruby #{expected_ruby} required (using #{RUBY_VERSION})")
end

def latest_ruby
  @latest_ruby ||= begin
    body = URI.open(RUBY_DOWNLOADS_URL, read_timeout: 5).read
    body[/The current stable version is\s+(\d+\.\d+\.\d+)/, 1] || "unknown"
  rescue StandardError
    "unknown"
  end
end

def lockfile
  @lockfile ||= Bundler::LockfileParser.new(Bundler.read_file("Gemfile.lock"))
end

def installed_gems
  lockfile.specs.to_h { |spec| [ spec.name, spec.version.to_s ] }
end

def direct_gems
  lockfile.dependencies.keys.sort
end

def outdated_gems
  output, = capture("bundle", "outdated", "--parseable")

  output.lines.filter_map do |line|
    match = line.match(/\A(?<name>\S+) \(newest (?<latest>[^,]+), installed (?<current>[^\),]+)/)
    next unless match

    [ match[:name], { current: match[:current], latest: match[:latest] } ]
  end.to_h
end

def outdated_importmap
  output, = capture("bin/importmap", "outdated")

  output.lines.filter_map do |line|
    next if line.include?("No outdated packages found") || line.start_with?("Ignoring ")

    match = line.strip.match(/\A(?<name>\S+)\s+\((?<current>\S+)\s+<\s+(?<latest>[^\)]+)\)/)
    next unless match

    [ match[:name], { current: match[:current], latest: match[:latest] } ]
  end.to_h
end

def major(version)
  version.to_s.split(".").first.to_i
end

def status_for(before:, current:, target:)
  return :current if target.nil? || target == "unknown" || current == target
  return :behind_major if major(current) < major(target)
  return :updated if before && before != current

  :updateable
end

def paint(status)
  "#{COLORS.fetch(status)}#{status.to_s.tr("_", "-")}#{COLORS[:reset]}"
end

def visible_length(text)
  text.to_s.gsub(ANSI_PATTERN, "").length
end

def pad(text, width)
  text = text.to_s
  text.ljust(width + text.length - visible_length(text))
end

def print_table(title, rows)
  puts "\n#{title}"
  return puts("  none") if rows.empty?

  headers = [ "Type", "Name", "Status", "Current", "Target" ]
  table = [ headers, *rows ]
  widths = headers.each_index.map { |index| table.map { |row| visible_length(row[index]) }.max }
  divider = "+-#{widths.map { |width| "-" * width }.join("-+-")}-+"

  puts divider
  puts "| #{headers.each_with_index.map { |text, index| text.ljust(widths[index]) }.join(" | ")} |"
  puts divider
  rows.each do |row|
    puts "| #{row.each_with_index.map { |text, index| pad(text, widths[index]) }.join(" | ")} |"
  end
  puts divider
end

def aggregate_status(statuses)
  return :behind_major if statuses.include?(:behind_major)
  return :updateable if statuses.include?(:updateable)
  return :updated if statuses.include?(:updated)

  :current
end

def counts_text(statuses)
  [ :current, :updated, :updateable, :behind_major ].filter_map do |status|
    count = statuses.count(status)
    next if count.zero?

    "#{count} #{status.to_s.tr('_', '-')}"
  end.join(", ")
end

def package_row(type, name, before:, current:, target:)
  status = status_for(before: before, current: current, target: target)
  [ type, name, paint(status), current, target || current ]
end

def aggregate_row(type, name, entries)
  statuses = entries.map { |entry| entry[:status] }
  current_text = entries.empty? ? "0 current" : counts_text(statuses)
  target_text = if entries.empty?
    "all latest"
  elsif statuses.include?(:behind_major)
    "major updates available"
  elsif statuses.include?(:updateable)
    "updates available"
  elsif statuses.include?(:updated)
    "updated this run"
  else
    "all latest"
  end

  [ type, name, paint(aggregate_status(statuses)), current_text, target_text ]
end

def aggregate_entries(names, before_versions, after_versions, outdated_versions)
  names.map do |name|
    before = before_versions[name]
    current = after_versions[name] || before || "-"
    target = outdated_versions.dig(name, :latest) || current
    { status: status_for(before: before, current: current, target: target) }
  end
end

FileUtils.chdir(APP_ROOT) do
  ensure_expected_ruby!

  before_gems = installed_gems

  puts "\n== Updating gems =="
  sh("bundle", "update", "--all")
  sh("bundle", "update", "--bundler")
  sh("bundle", "update", "--ruby")

  puts "\n== Updating importmap packages =="
  sh("bin/importmap", "update")

  puts "\n== Preparing app =="
  sh("bin/rails", "db:prepare")
  sh("bin/rails", "log:clear", "tmp:clear")
  sh("touch", "tmp/restart.txt")

  puts "\n== Running quality checks =="
  sh("bin/quality")

  after_gems = installed_gems
  gem_updates = outdated_gems
  importmap_updates = outdated_importmap

  rows = []
  rows << package_row("runtime", "ruby", before: RUBY_VERSION, current: RUBY_VERSION, target: latest_ruby)
  rows << package_row(
    "gem",
    "rails",
    before: before_gems["rails"],
    current: after_gems["rails"],
    target: gem_updates.dig("rails", :latest) || after_gems["rails"]
  )

  other_gems = direct_gems - [ "rails" ]
  rows << aggregate_row("gem", "other gems", aggregate_entries(other_gems, before_gems, after_gems, gem_updates))
  importmap_names = importmap_updates.keys.sort
  rows << aggregate_row("js", "importmap", aggregate_entries(importmap_names, {}, {}, importmap_updates))

  print_table("Dependency summary", rows)

  puts "\nRails version: #{`bundle exec rails -v`.strip}"
  puts "Next: git diff"
end
