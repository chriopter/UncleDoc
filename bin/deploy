#!/usr/bin/env bash
set -euo pipefail

current_branch=$(git branch --show-current)
destination="${1:-}"

choose_destination() {
  echo "Current branch: $current_branch"
  echo
  echo "Deploy to:"

  PS3="Choose [1]: "
  options=("lan")

  select selected in "${options[@]}"; do
    case "$selected" in
      lan)
        destination="$selected"
        break
        ;;
      *)
        echo "Invalid selection"
        ;;
    esac
  done
}

validate_destination() {
  case "$destination" in
    lan)
      ;;
    *)
      echo "Unsupported destination: $destination"
      echo "Usage: bin/deploy [lan]"
      exit 1
      ;;
  esac
}

if [[ -z "$destination" ]]; then
  choose_destination
fi

validate_destination

echo "Deploy branch '$current_branch' to LAN?"
echo -n "Press Enter to continue or Ctrl+C to cancel: "
read -r

echo "Deploying to $destination from branch '$current_branch'..."
exec bin/kamal_op deploy -d "$destination"
